{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://www.capitalbench.org/schemas/portfolio_submission_v1.json",
  "title": "CapitalBench Portfolio Submission v1",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "round_id": {
      "type": "string"
    },
    "model_id": {
      "type": "string"
    },
    "provider": {
      "type": "string",
      "enum": ["openai", "anthropic", "google", "xai"]
    },
    "mode": {
      "type": "string",
      "enum": ["closed_capability"]
    },
    "portfolio": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "option_id": {
            "type": "string"
          },
          "allocation_pct": {
            "type": "integer",
            "minimum": 5,
            "maximum": 100,
            "multipleOf": 5
          },
          "rationale": {
            "type": "string"
          }
        },
        "required": ["option_id", "allocation_pct", "rationale"]
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "portfolio_rationale": {
      "type": "string"
    },
    "rationale_summary": {
      "type": "string"
    },
    "key_risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "round_id",
    "model_id",
    "provider",
    "mode",
    "portfolio",
    "confidence",
    "portfolio_rationale",
    "rationale_summary",
    "key_risks"
  ]
}
