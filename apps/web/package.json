{
  "name": "@capitalbench/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev --host 0.0.0.0",
    "api:generate": "node scripts/generate-api-read-model.mjs",
    "api:key": "node scripts/api-key.mjs",
    "api:test": "node scripts/generate-api-read-model.mjs && node --test tests/data-api.test.mjs",
    "build": "node scripts/generate-api-read-model.mjs && astro check && astro build",
    "email:campaign": "node scripts/email-campaign.mjs",
    "email:test": "node --test tests/email-system.test.mjs",
    "seo:check": "node scripts/validate-seo.mjs",
    "preview": "astro preview --host 0.0.0.0"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/react": "^4.2.1",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@fontsource/ibm-plex-serif": "^5.2.7",
    "@supabase/supabase-js": "^2.49.4",
    "astro": "^5.6.1",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.2",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.19"
  }
}
