---
import {
  calculationLabel,
  calculationValue,
  categoryLabel,
  contextPills,
  insightDefinition,
  insightHref,
  insightTimeframeLabel,
  sourcePills
} from "../lib/insights.js";

interface Props {
  insights?: any[];
  kicker?: string;
  title: string;
  description?: string;
  viewAllHref?: string;
  viewAllLabel?: string;
  id?: string;
  compact?: boolean;
  featured?: boolean;
}

type InsightCalculation = {
  name?: string;
  value?: number | string | null;
  unit?: string | null;
};

type InsightLink = {
  label: string;
  href?: string | null;
};

const {
  insights = [],
  kicker = "Benchmark insights",
  title,
  description,
  viewAllHref = "/insights",
  viewAllLabel = "All insights",
  id,
  compact = false,
  featured = false
} = Astro.props;
const visibleInsights = insights.filter(Boolean).slice(0, compact ? 2 : 3);
---

{visibleInsights.length > 0 && (
  <section class:list={["context-insights", featured && "context-insights-featured", compact && "context-insights-compact"]} id={id} aria-labelledby={id ? `${id}-title` : undefined}>
    <div class="context-insights-head">
      <div>
        <span class="panel-kicker">{kicker}</span>
        <h2 id={id ? `${id}-title` : undefined}>{title}</h2>
        {description && <p>{description}</p>}
      </div>
      <a class="section-profile-link" href={viewAllHref}>{viewAllLabel}</a>
    </div>

    <div
      class:list={["insight-card-grid", compact && "insight-card-grid-compact"]}
      tabindex={featured ? 0 : undefined}
      aria-label={featured ? `${title} insight rail` : undefined}
    >
      {visibleInsights.map((insight) => {
        const calculations: InsightCalculation[] = Array.isArray(insight.calculations) ? insight.calculations.slice(0, 3) : [];
        const evidence: InsightLink[] = Array.isArray(insight.evidence) ? insight.evidence.slice(0, 2) : [];
        return (
          <article class="insight-card">
            <header>
              <span>{categoryLabel(insight.category)}</span>
              <strong title="Timeframe for this insight">{insightTimeframeLabel(insight)}</strong>
            </header>
            <div class="insight-context-strip" aria-label={`${insight.title} context`}>
              {contextPills(insight).map((pill) => <span>{pill}</span>)}
            </div>
            <h3><a href={insightHref(insight)}>{insight.title}</a></h3>
            <p>{insight.summary}</p>
            <p class="insight-definition">{insightDefinition(insight)}</p>
            <div class="insight-card-meta">
              {sourcePills(insight).map((pill) => <span>{pill}</span>)}
            </div>
            {calculations.length > 0 && (
              <dl class="insight-calculation-list">
                {calculations.map((calculation) => (
                  <div>
                    <dt>{calculationLabel(calculation.name)}</dt>
                    <dd>{calculationValue(calculation)}</dd>
                  </div>
                ))}
              </dl>
            )}
            <footer class="insight-card-footer">
              <span>Why it matters</span>
              <p>{insight.why_it_matters}</p>
              <div>
                <a href={insightHref(insight)}>Open insight</a>
                {evidence.map((item) => item.href ? <a href={item.href}>{item.label}</a> : <em>{item.label}</em>)}
              </div>
            </footer>
          </article>
        );
      })}
    </div>
  </section>
)}
