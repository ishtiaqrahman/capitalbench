---
import Badge from "./Badge.astro";
import { dateOnly } from "../lib/format";

interface Props {
  roundId: string;
  status: "pending" | "resolved" | "archived";
  decisionDeadline: string;
  entryDate?: string;
  exitDate: string;
  officialRunId: string;
}

const { roundId, status, decisionDeadline, entryDate, exitDate, officialRunId } = Astro.props;
const tone = status === "resolved" ? "green" : status === "pending" ? "amber" : "neutral";
const publicStatus = status === "resolved" ? "scored" : status;
---

<section class="status-strip" aria-label="Current benchmark status">
  <div class="status-item">
    <span>Test</span>
    <strong>{roundId}</strong>
    <Badge tone={tone}>{publicStatus}</Badge>
  </div>
  <div class="status-item">
    <span>Picks Saved By</span>
    <strong>{dateOnly(decisionDeadline)}</strong>
  </div>
  <div class="status-item">
    <span>Start Date</span>
    <strong>{entryDate ?? "Not set"}</strong>
  </div>
  <div class="status-item">
    <span>End Date</span>
    <strong>{exitDate}</strong>
  </div>
  <div class="status-item">
    <span>Run ID</span>
    <strong>{officialRunId}</strong>
  </div>
</section>
