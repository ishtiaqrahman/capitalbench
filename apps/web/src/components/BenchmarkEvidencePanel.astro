---
import {
  CalendarDays,
  ClipboardCheck,
  Gauge,
  GitCompareArrows,
  ShieldCheck,
  Target
} from "lucide-react";

type BenchmarkTrack = "weekly" | "monthly";

interface Props {
  evidence?: any;
  track?: BenchmarkTrack;
  tracks?: BenchmarkTrack[];
  benchmarkSet?: any;
  compact?: boolean;
  title?: string;
  description?: string;
}

const { evidence, track, tracks, benchmarkSet, compact = false, title, description } = Astro.props;
const selectedTracks: BenchmarkTrack[] = tracks ?? (track ? [track] : ["monthly", "weekly"]);

function trackLabel(value: BenchmarkTrack): string {
  return value === "weekly" ? "Weekly" : "Monthly";
}

function countLabel(count: number, singular: string, plural = `${singular}s`): string {
  return `${count} ${count === 1 ? singular : plural}`;
}

function maturityForSet(trackSummary: any, set: any) {
  if (!set) return trackSummary?.sample_maturity;
  const count = Number(set.comparison?.comparison_round_count ?? 0);
  const threshold = Number(set.qualification_threshold ?? trackSummary?.qualification_threshold ?? (set.track === "weekly" ? 6 : 3));
  const established = set.track === "weekly" ? 12 : 6;
  if (count >= established) {
    return {
      key: "more_established",
      label: "More established",
      description: "This comparison set has enough shared rounds for stronger pattern reads, while still needing ongoing live validation."
    };
  }
  if (count >= threshold) {
    return {
      key: "qualified_forming",
      label: "Qualified but still forming",
      description: "This comparison set has crossed the current benchmark threshold, but the sample is still early for strong performance claims."
    };
  }
  return {
    key: "early",
    label: "Early",
    description: `This set needs ${Math.max(0, threshold - count)} more shared ${set.track === "weekly" ? "weekly" : "monthly"} ${threshold - count === 1 ? "round" : "rounds"} to become the current benchmark.`
  };
}

function availableBaselineLabels(trackSummary: any): string {
  const labels = (trackSummary?.baselines ?? [])
    .filter((baseline: any) => baseline.available)
    .map((baseline: any) => baseline.key === "oracle" ? "Oracle" : baseline.label);
  return labels.length ? labels.join(", ") : "Not enough completed data";
}

const factIcons = {
  evidence: ShieldCheck,
  trackEvidence: CalendarDays,
  equalRun: GitCompareArrows,
  protocol: ClipboardCheck,
  scoreScale: Gauge,
  baselines: Target
};

function evidenceFacts(trackSummary: any, set: any) {
  const trackName = trackLabel(trackSummary.track);
  const maturity = maturityForSet(trackSummary, set);
  const sharedRoundCount = Number(set?.comparison?.comparison_round_count ?? trackSummary.equal_run_comparison?.shared_round_count ?? 0);
  const sharedModelCount = Number(set?.comparison?.comparison_model_count ?? trackSummary.equal_run_comparison?.shared_model_count ?? 0);
  const threshold = Number(set?.qualification_threshold ?? trackSummary.qualification_threshold ?? 0);
  const isEqualRun = Boolean(set ? sharedRoundCount > 0 : trackSummary.equal_run_comparison?.available);
  const equalRunLabel = isEqualRun
    ? `${sharedModelCount || trackSummary.model_count} models on the same ${countLabel(sharedRoundCount, "round")}`
    : "Not available yet";
  const evidenceCount = set
    ? `${countLabel(sharedRoundCount, "shared round")} in this set`
    : `${countLabel(trackSummary.resolved_round_count, "resolved round")} / ${countLabel(trackSummary.resolved_model_result_count, "model result")}`;
  const qualificationLabel = set
    ? sharedRoundCount >= threshold
      ? `Qualified at ${threshold}+ shared rounds`
      : `${Math.max(0, threshold - sharedRoundCount)} more to qualify`
    : trackSummary.equal_run_comparison?.is_qualified
      ? `Current threshold met at ${threshold}+ rounds`
      : `Threshold: ${threshold} shared rounds`;

  return [
    {
      key: "evidence",
      icon: factIcons.evidence,
      label: "Evidence level",
      value: maturity?.label ?? "Not available",
      detail: maturity?.description ?? "Evidence level appears after completed results exist."
    },
    {
      key: "track-evidence",
      icon: factIcons.trackEvidence,
      label: set ? "Set evidence" : `${trackName} evidence`,
      value: evidenceCount,
      detail: qualificationLabel
    },
    {
      key: "equal-run",
      icon: factIcons.equalRun,
      label: "Equal-run comparison",
      value: equalRunLabel,
      detail: "Ranked models are compared only on rounds every model in the roster completed."
    },
    {
      key: "protocol",
      icon: factIcons.protocol,
      label: "Protocol",
      value: trackSummary.protocol_mix?.label ?? "Not available",
      detail: trackSummary.protocol_mix?.description ?? "Round protocol appears after scoring."
    },
    {
      key: "score-scale",
      icon: factIcons.scoreScale,
      label: "Score scale",
      value: "Oracle-relative",
      detail: "100 means matching the hindsight best asset in the same scored window."
    },
    {
      key: "baselines",
      icon: factIcons.baselines,
      label: "Baselines shown",
      value: availableBaselineLabels(trackSummary),
      detail: "Practical references are shown beside the impossible hindsight ceiling when available."
    }
  ];
}

const trackSummaries = selectedTracks
  .map((key) => evidence?.tracks?.[key])
  .filter(Boolean);
const panelTitle = title ?? (benchmarkSet ? "Evidence Behind This Set" : "Benchmark Evidence Level");
const panelDescription =
  description ??
  (benchmarkSet
    ? `This ${trackLabel(benchmarkSet.track).toLowerCase()} set is generated from completed shared rounds, not manually curated copy.`
    : "Generated from completed rounds, benchmark-set rules, protocols, and available baselines so every score carries its own context.");
---

{trackSummaries.length > 0 && (
  <aside class:list={["benchmark-evidence-panel", compact && "benchmark-evidence-panel-compact"]} aria-label={panelTitle}>
    <div class="benchmark-evidence-head">
      <div>
        <span class="panel-kicker">Evidence context</span>
        <h2>{panelTitle}</h2>
        <p>{panelDescription}</p>
      </div>
      <a class="section-profile-link" href="/scoring/#capitalbench-score">Score methodology</a>
    </div>

    <div class:list={["benchmark-evidence-grid", trackSummaries.length === 1 && "benchmark-evidence-grid-single"]}>
      {trackSummaries.map((trackSummary: any) => {
        const setForTrack = benchmarkSet?.track === trackSummary.track ? benchmarkSet : null;
        const maturity = maturityForSet(trackSummary, setForTrack);
        const facts = evidenceFacts(trackSummary, setForTrack);
        return (
          <article class={`benchmark-evidence-card benchmark-evidence-card-${maturity?.key ?? "unknown"}`}>
            <div class="benchmark-evidence-card-title">
              <span>{trackSummary.label} benchmark</span>
              <strong>{maturity?.label ?? "Not available"}</strong>
            </div>
            <div class="benchmark-evidence-facts">
              {facts.map((fact) => {
                const Icon = fact.icon;
                return (
                <div class={`benchmark-evidence-fact benchmark-evidence-fact-${fact.key}`}>
                  <span class="benchmark-evidence-icon" aria-hidden="true"><Icon size={24} strokeWidth={2.1} /></span>
                  <span class="benchmark-evidence-label">{fact.label}</span>
                  <strong>{fact.value}</strong>
                  <em>{fact.detail}</em>
                </div>
                );
              })}
            </div>
            <p class="benchmark-evidence-caveat">{trackSummary.caveat}</p>
          </article>
        );
      })}
    </div>
  </aside>
)}
