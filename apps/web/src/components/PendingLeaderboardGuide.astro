---
import ScoreCountdown from "./ScoreCountdown";

interface Props {
  kind: "latest" | "official" | "stability";
  roundId?: string;
  exitDate?: string;
  scoreEtaUtc?: string;
  scoreEtaSource?: "automation" | "derived";
  status?: "pending" | "resolved" | "archived";
  initialNowIso?: string;
}

const {
  kind,
  roundId = "The latest round",
  exitDate = "the declared exit date",
  scoreEtaUtc,
  scoreEtaSource,
  status = "pending",
  initialNowIso
} = Astro.props;

const copy = {
  latest: {
    kicker: "Pending result",
    title: "Scores Are Not Ready Yet",
    body:
      `${roundId} has saved model portfolios and starting prices. Scores appear after ending prices are collected.`,
    columns: ["Model", "Provider", "Pick", "Holdings", "Portfolio return", "S&P 500", "Vs S&P 500"],
    sort: "Return versus S&P 500 descending, then lower regret, higher confidence, and model id.",
    cta: "Review model portfolios"
  },
  official: {
    kicker: "Overall results",
    title: "What Appears After Completed Tests",
    body:
      "This table averages each model's public score across completed tests where that model participated. New models enter future tests only; old outcomes are not backfilled.",
    columns: ["Model", "Provider", "Completed tests", "Average vs S&P 500", "Hit rate", "Cumulative score"],
    sort: "Average return versus S&P 500 descending, then cumulative score and hit rate.",
    cta: "View current test"
  },
  stability: {
    kicker: "Consistency checks",
    title: "What Consistency Shows",
    body:
      "Consistency rows summarize repeated calls with the same saved input. They measure whether a model tends to make the same pick.",
    columns: ["Model", "Provider", "Completed tests", "Average repeated score", "Consistency", "Most common pick score"],
    sort: "Average repeated score descending, then consistency and most-common-pick score.",
    cta: "Read how it works"
  }
}[kind];

const href =
  kind === "latest"
    ? "#official-picks"
    : kind === "stability"
      ? "/methodology#execution"
      : "/rounds/CB-2026-05-10-1M";
---

<section class={`leaderboard-guide guide-${kind}`} aria-label="Pending leaderboard explanation">
  <div class="guide-primary">
    <span class="panel-kicker">{copy.kicker}</span>
    <h2>{copy.title}</h2>
    <p>{copy.body}</p>
    {kind === "latest" && (
      <ScoreCountdown
        client:visible
        variant="panel"
        label="Scores expected"
        scoreEtaUtc={scoreEtaUtc}
        source={scoreEtaSource}
        status={status}
        exitDate={exitDate}
        initialNowIso={initialNowIso}
      />
    )}
    <div class="guide-process" aria-label="Leaderboard publication sequence">
      <span>Portfolios saved</span>
      <span>Ending prices pending</span>
      <span>Scores published</span>
    </div>
    <a class="action-link" href={href}>{copy.cta}</a>
  </div>
  <div class="guide-side">
    <div class="guide-secondary">
      <span class="metric-label">Published Columns</span>
      <div class="column-chips">
        {copy.columns.map((column) => <span>{column}</span>)}
      </div>
    </div>
    <div class="guide-secondary">
      <span class="metric-label">Sort Rule</span>
      <p>{copy.sort}</p>
    </div>
  </div>
</section>
