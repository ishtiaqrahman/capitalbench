---
import ScoreCountdown from "./ScoreCountdown";

interface Props {
  kind: "latest" | "official" | "stability";
  roundId?: string;
  exitDate?: string;
  scoreEtaUtc?: string;
  scoreEtaSource?: "automation" | "derived";
  status?: "pending" | "resolved" | "archived";
  initialNowIso?: string;
}

const {
  kind,
  roundId = "The latest round",
  exitDate = "the declared exit date",
  scoreEtaUtc,
  scoreEtaSource,
  status = "pending",
  initialNowIso
} = Astro.props;

const copy = {
  latest: {
    kicker: "Pending result",
    title: "Why There Is No Score Yet",
    body:
      `${roundId} has official allocations and entry prices, but the latest leaderboard stays empty until exit prices are collected and scored.`,
    columns: ["Model", "Provider", "Decision", "Holdings", "Portfolio return", "S&P 500", "Alpha"],
    sort: "Alpha versus S&P 500 descending, then lower regret, higher confidence, and model id.",
    cta: "Review official allocations"
  },
  official: {
    kicker: "Cumulative official",
    title: "What Appears After Resolved Rounds",
    body:
      "This table averages one-shot official alpha across resolved rounds where each model participated. New models enter future rounds only; old outcomes are not backfilled.",
    columns: ["Model", "Provider", "Resolved rounds", "Average alpha", "Hit rate", "Cumulative log alpha"],
    sort: "Average official alpha descending, then cumulative log alpha and hit rate.",
    cta: "View current round"
  },
  stability: {
    kicker: "Repeated-call track",
    title: "What Stability Will Show",
    body:
      "Stability rows summarize repeated calls with the same frozen inputs. They measure consistency and repeated-run alpha, separately from official one-shot performance.",
    columns: ["Model", "Provider", "Resolved rounds", "Avg repeated alpha", "Consistency", "Modal decision alpha"],
    sort: "Average repeated alpha descending, then consistency and modal-pick alpha.",
    cta: "Read methodology"
  }
}[kind];

const href =
  kind === "latest"
    ? "#official-picks"
    : kind === "stability"
      ? "/methodology#execution"
      : "/rounds/CB-2026-05-10-1M";
---

<section class={`leaderboard-guide guide-${kind}`} aria-label="Pending leaderboard explanation">
  <div class="guide-primary">
    <span class="panel-kicker">{copy.kicker}</span>
    <h2>{copy.title}</h2>
    <p>{copy.body}</p>
    {kind === "latest" && (
      <ScoreCountdown
        client:visible
        variant="panel"
        label="Scores expected"
        scoreEtaUtc={scoreEtaUtc}
        source={scoreEtaSource}
        status={status}
        exitDate={exitDate}
        initialNowIso={initialNowIso}
      />
    )}
    <div class="guide-process" aria-label="Leaderboard publication sequence">
      <span>Allocations locked</span>
      <span>Exit prices pending</span>
      <span>Scores published</span>
    </div>
    <a class="action-link" href={href}>{copy.cta}</a>
  </div>
  <div class="guide-side">
    <div class="guide-secondary">
      <span class="metric-label">Published Columns</span>
      <div class="column-chips">
        {copy.columns.map((column) => <span>{column}</span>)}
      </div>
    </div>
    <div class="guide-secondary">
      <span class="metric-label">Sort Rule</span>
      <p>{copy.sort}</p>
    </div>
  </div>
</section>
