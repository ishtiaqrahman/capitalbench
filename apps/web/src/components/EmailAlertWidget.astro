---
import { BellRing, X } from "lucide-react";

interface Props {
  context: "home" | "round" | "leaderboard";
}

const { context } = Astro.props;
const source = `score_alert_${context}`;
const copy = {
  home: {
    label: "Score alerts",
    title: "Get new scores when they publish.",
    description: "New weekly and monthly results, no spam."
  },
  round: {
    label: "Round alerts",
    title: "Get notified when this round is scored.",
    description: "One email when new results publish."
  },
  leaderboard: {
    label: "Score alerts",
    title: "Get weekly and monthly score updates.",
    description: "Occasional benchmark results, no spam."
  }
}[context];
---

<aside
  class="score-alert-widget"
  data-score-alert-widget
  data-context={context}
  data-source={source}
  aria-label="Score alerts"
  hidden
>
  <button
    class="score-alert-chip"
    type="button"
    data-score-alert-chip
    aria-expanded="false"
    aria-controls={`score-alert-panel-${context}`}
  >
    <BellRing size={16} aria-hidden="true" />
    <span>{copy.label}</span>
  </button>

  <section
    class="score-alert-panel"
    id={`score-alert-panel-${context}`}
    data-score-alert-panel
    aria-labelledby={`score-alert-title-${context}`}
    hidden
  >
    <div class="score-alert-copy">
      <span class="panel-kicker">{copy.label}</span>
      <h2 id={`score-alert-title-${context}`}>{copy.title}</h2>
      <p>{copy.description}</p>
    </div>

    <button class="score-alert-close" type="button" data-score-alert-close aria-label="Dismiss score alerts">
      <X size={15} aria-hidden="true" />
    </button>

    <form class="score-alert-form" data-email-signup data-score-alert-form>
      <input type="hidden" name="source" value={source} />
      <label class="sr-only" for={`score-alert-email-${context}`}>Email address</label>
      <input
        id={`score-alert-email-${context}`}
        type="email"
        name="email"
        inputmode="email"
        autocomplete="email"
        placeholder="Email address"
        required
      />
      <label class="email-signup-trap" aria-hidden="true">
        Company
        <input type="text" name="company" tabindex="-1" autocomplete="off" />
      </label>
      <button type="submit">Subscribe</button>
      <p class="email-signup-status" data-email-signup-status aria-live="polite"></p>
      <p class="score-alert-consent">Occasional CapitalBench emails. Unsubscribe anytime.</p>
    </form>
  </section>
</aside>

<script is:inline>
  if (!window.__capitalbenchScoreAlertWidget) {
    window.__capitalbenchScoreAlertWidget = true;

    const SUBSCRIBED_KEY = "capitalbench_email_subscribed";
    const DISMISSED_UNTIL_KEY = "capitalbench_email_dismissed_until";
    const EXPANDED_SESSION_KEY = "capitalbench_email_widget_expanded_session";
    const DISMISS_MS = 30 * 24 * 60 * 60 * 1000;
    const MIN_ACTIVE_MS = 30 * 1000;
    const MIN_SCROLL_PROGRESS = 0.2;

    const safeStorage = {
      get(storage, key) {
        try {
          return storage.getItem(key);
        } catch {
          return null;
        }
      },
      set(storage, key, value) {
        try {
          storage.setItem(key, value);
        } catch {
          // Storage can be unavailable in private or restricted browser modes.
        }
      },
      remove(storage, key) {
        try {
          storage.removeItem(key);
        } catch {
          // Storage can be unavailable in private or restricted browser modes.
        }
      }
    };

    function emitMetric(action, detail = {}) {
      const payload = {
        event: action,
        component: "score_alert_widget",
        ...detail
      };
      window.dispatchEvent(new CustomEvent("capitalbench:email_event", { detail: payload }));
      window.dataLayer?.push(payload);
    }

    function isDismissed() {
      const dismissedUntil = Number(safeStorage.get(window.localStorage, DISMISSED_UNTIL_KEY) || 0);
      if (!dismissedUntil) return false;
      if (Date.now() < dismissedUntil) return true;
      safeStorage.remove(window.localStorage, DISMISSED_UNTIL_KEY);
      return false;
    }

    function scrollProgress() {
      const scrollable = Math.max(1, document.documentElement.scrollHeight - window.innerHeight);
      return Math.min(1, Math.max(0, window.scrollY / scrollable));
    }

    function userIsTyping() {
      const active = document.activeElement;
      return active instanceof HTMLInputElement || active instanceof HTMLTextAreaElement || active instanceof HTMLSelectElement;
    }

    function setupWidget(widget) {
      const chip = widget.querySelector("[data-score-alert-chip]");
      const panel = widget.querySelector("[data-score-alert-panel]");
      const close = widget.querySelector("[data-score-alert-close]");
      const form = widget.querySelector("[data-score-alert-form]");
      const context = widget.dataset.context || "home";
      let visible = false;
      let expanded = false;
      let seenMetricSent = false;
      let activeStart = Date.now();

      function shouldSuppress() {
        return (
          safeStorage.get(window.localStorage, SUBSCRIBED_KEY) === "true" ||
          isDismissed() ||
          window.innerHeight < 520
        );
      }

      function hasScrolledEnough() {
        return scrollProgress() >= MIN_SCROLL_PROGRESS;
      }

      function show(reason) {
        if (visible || shouldSuppress() || !hasScrolledEnough()) return;
        widget.hidden = false;
        visible = true;
        if (!seenMetricSent) {
          seenMetricSent = true;
          emitMetric("score_alert_seen", { context, reason });
        }
      }

      function expand(reason) {
        if (expanded || shouldSuppress() || !hasScrolledEnough() || userIsTyping()) return;
        if (safeStorage.get(window.sessionStorage, EXPANDED_SESSION_KEY) === "true") {
          show(reason);
          return;
        }
        show(reason);
        panel.hidden = false;
        chip.setAttribute("aria-expanded", "true");
        widget.dataset.state = "expanded";
        expanded = true;
        safeStorage.set(window.sessionStorage, EXPANDED_SESSION_KEY, "true");
        emitMetric("score_alert_expanded", { context, reason });
      }

      function collapse() {
        panel.hidden = true;
        chip.setAttribute("aria-expanded", "false");
        widget.dataset.state = "collapsed";
        expanded = false;
      }

      function dismiss(reason) {
        safeStorage.set(window.localStorage, DISMISSED_UNTIL_KEY, String(Date.now() + DISMISS_MS));
        widget.hidden = true;
        visible = false;
        collapse();
        emitMetric("score_alert_dismissed", { context, reason });
      }

      function complete(source) {
        safeStorage.set(window.localStorage, SUBSCRIBED_KEY, "true");
        widget.dataset.state = "subscribed";
        setTimeout(() => {
          widget.hidden = true;
          visible = false;
        }, 1600);
        emitMetric("score_alert_submitted", { context, source });
      }

      chip?.addEventListener("click", () => {
        if (expanded) collapse();
        else expand("chip_click");
      });

      close?.addEventListener("click", () => dismiss("close_button"));

      form?.addEventListener("submit", () => {
        activeStart = Date.now();
      });

      window.addEventListener("capitalbench:email_subscribed", (event) => {
        const source = event.detail?.source || "";
        if (!source.startsWith("score_alert_")) {
          safeStorage.set(window.localStorage, SUBSCRIBED_KEY, "true");
          return;
        }
        complete(source);
      });

      window.addEventListener("click", (event) => {
        const link = event.target instanceof Element ? event.target.closest("a") : null;
        const href = link?.getAttribute("href") || "";
        if (href.includes("/leaderboards") || href.includes("/rounds") || href.includes("proof") || href.includes("current-picks")) {
          safeStorage.set(window.sessionStorage, "capitalbench_email_intent_click", "true");
        }
      }, { capture: true });

      const onScroll = () => {
        const progress = scrollProgress();
        if (progress >= MIN_SCROLL_PROGRESS) show("scroll");
        if (progress > 0.55) expand("deep_scroll");
        if (Date.now() - activeStart > MIN_ACTIVE_MS && progress > 0.35) expand("active_time_and_scroll");
      };

      window.addEventListener("scroll", onScroll, { passive: true });

      const intentSelectors = [
        ".published-score-panel",
        "#current-picks",
        ".track-summary-heading",
        ".timeline-lanes",
        "#proof-and-data"
      ];
      const intentTargets = intentSelectors
        .flatMap((selector) => Array.from(document.querySelectorAll(selector)))
        .filter(Boolean);

      if ("IntersectionObserver" in window && intentTargets.length > 0) {
        const observer = new IntersectionObserver((entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting && entry.intersectionRatio > 0.28) {
              expand("context_section");
              observer.disconnect();
              break;
            }
          }
        }, { threshold: [0.28] });
        intentTargets.forEach((target) => observer.observe(target));
      }

      if (context === "round" || context === "leaderboard") {
        window.setTimeout(() => show("context_page"), 900);
        window.setTimeout(() => expand("context_page"), 7000);
      }

      if (safeStorage.get(window.sessionStorage, "capitalbench_email_intent_click") === "true") {
        window.setTimeout(() => expand("prior_intent_click"), 1200);
      }

      window.setInterval(onScroll, 5000);
    }

    document.querySelectorAll("[data-score-alert-widget]").forEach(setupWidget);
  }
</script>
