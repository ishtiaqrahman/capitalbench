---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import RoundsTable from "../../components/RoundsTable";
import { staticRoundRecords } from "../../lib/localRoundRecords";
import { datasetSchema } from "../../lib/seo";

const roundRows = staticRoundRecords();
const roundsDataset = datasetSchema({
  name: "CapitalBench public test index",
  description:
    "A public index of CapitalBench market tests, deadlines, time periods, run IDs, scoring status, and proof pages.",
  path: "/rounds",
  datePublished: "2026-05-12",
  keywords: ["LLM benchmark rounds", "market benchmark", "AI evaluation", "CapitalBench"],
  variableMeasured: ["round status", "decision deadline", "entry date", "exit date", "official run id"]
});
---

<BaseLayout
  title="CapitalBench Test Rounds"
  description="Index of CapitalBench market tests with dates, model portfolios, scoring status, and proof links."
  structuredData={roundsDataset}
>
  <PageHeader
    eyebrow="Test index"
    title="Test Rounds"
    summary="Each test saves the market brief, asset list, prompt, model portfolios, and proof hashes before scoring."
  />
  <section class="section">
    <RoundsTable client:visible fallbackRows={roundRows} />
  </section>
</BaseLayout>
