---
import { existsSync, readdirSync, readFileSync } from "node:fs";
import { join, resolve } from "node:path";
import { parse as parseYaml } from "yaml";
import BaseLayout from "../../layouts/BaseLayout.astro";
import StatusCards from "../../components/StatusCards.astro";
import LeaderboardTable from "../../components/LeaderboardTable";
import OfficialPicksTable from "../../components/OfficialPicksTable";
import RoundPerformanceChart from "../../components/RoundPerformanceChart";
import ScoreReturnChart from "../../components/ScoreReturnChart.astro";
import HashTable from "../../components/HashTable";
import TableIsland from "../../components/TableIsland";
import {
  auditHashes,
  entryPrices,
  type EntryPrice,
  type HashRecord,
  modelLabel,
  officialSubmissions,
  providerLabel,
  type SubmissionRecord,
  type UniverseOption,
  type WeeklyPerformanceRecord,
  universeOptions
} from "../../data/fallback";
import { allocationThemeClass, formatAllocationPct, optionDisplayName, optionShortDisplayName } from "../../lib/allocations";
import { dateOnly, pct } from "../../lib/format";
import {
  repoRootPath,
  staticRoundAllocations,
  staticRoundLeaderboard,
  staticRoundRecords,
  staticRoundReturns,
  staticScoringPrices
} from "../../lib/localRoundRecords";
import { buildScoreReturnChartData } from "../../lib/scoreReturnChart";
import { datasetSchema } from "../../lib/seo";
import { buildRunConcentration, type ConcentrationAsset } from "../../lib/runConcentration";
import { roundTrack, trackLabel } from "../../lib/tracks";

const repoRoot = repoRootPath();

export function getStaticPaths() {
  return staticRoundRecords().map((round) => ({ params: { round_id: round.round_id }, props: { round } }));
}

const { round } = Astro.props;
const roundRoot = resolve(repoRoot, "rounds", round.round_id);
const officialRunId = round.official_run_id;
const fallbackRoundSubmissions = officialSubmissions.filter(
  (submission) => submission.round_id === round.round_id && submission.run_id === officialRunId
);

type ParsedOption = {
  id?: string;
  name?: string;
  symbol?: string | null;
  asset_class?: string;
  category?: string;
  option_group?: string;
  risk_bucket?: string;
  exposure_description?: string;
  include_in_universe?: boolean;
  is_cash?: boolean;
  is_benchmark?: boolean;
};

type ModelOutput = {
  round_id: string;
  model_id: string;
  provider: string;
  mode: string;
  selected_option_id?: string;
  portfolio?: Array<{
    option_id: string;
    allocation_pct?: number;
    allocation_bps?: number;
    rationale?: string;
  }>;
  portfolio_rationale?: string;
  confidence: number;
  rationale_summary: string;
  key_risks: string[];
  run_type?: string;
  [key: string]: unknown;
};

function outputAllocations(output: ModelOutput): Array<{ option_id: string; allocation_pct: number; allocation_bps: number; rationale?: string }> {
  if (output.portfolio && output.portfolio.length > 0) {
    return output.portfolio.map((item) => {
      const allocationBps = item.allocation_bps ?? Number(item.allocation_pct ?? 0) * 100;
      return {
        option_id: item.option_id,
        allocation_pct: allocationBps / 100,
        allocation_bps: allocationBps,
        rationale: item.rationale
      };
    });
  }
  if (!output.selected_option_id) return [];
  return [
    {
      option_id: output.selected_option_id,
      allocation_pct: 100,
      allocation_bps: 10000,
      rationale: output.rationale_summary
    }
  ];
}

function outputPickLabel(output: ModelOutput): string {
  return outputAllocations(output)
    .map((item) => `${item.option_id} ${formatAllocationPct(item.allocation_pct)}`)
    .join(" / ");
}

function outputPrimaryAllocation(output: ModelOutput) {
  return [...outputAllocations(output)].sort((a, b) => b.allocation_bps - a.allocation_bps)[0];
}

function readRoundText(...segments: string[]): string {
  const path = join(roundRoot, ...segments);
  if (!existsSync(path)) return "";
  return readFileSync(path, "utf-8").trim();
}

function parseRoundYaml<T>(...segments: string[]): T | null {
  const text = readRoundText(...segments);
  if (!text) return null;
  try {
    return parseYaml(text) as T;
  } catch {
    return null;
  }
}

function parseRoundJson<T>(...segments: string[]): T | null {
  const text = readRoundText(...segments);
  if (!text) return null;
  try {
    return JSON.parse(text) as T;
  } catch {
    return null;
  }
}

function parseCsvLine(line: string): string[] {
  const cells: string[] = [];
  let cell = "";
  let inQuotes = false;
  for (let index = 0; index < line.length; index += 1) {
    const char = line[index];
    const next = line[index + 1];
    if (char === '"' && inQuotes && next === '"') {
      cell += '"';
      index += 1;
    } else if (char === '"') {
      inQuotes = !inQuotes;
    } else if (char === "," && !inQuotes) {
      cells.push(cell);
      cell = "";
    } else {
      cell += char;
    }
  }
  cells.push(cell);
  return cells;
}

function parseCsv(text: string): Array<Record<string, string>> {
  const lines = text.trim().split(/\r?\n/).filter(Boolean);
  const [headerLine, ...rowLines] = lines;
  if (!headerLine) return [];
  const headers = parseCsvLine(headerLine);
  return rowLines.map((line) => {
    const cells = parseCsvLine(line);
    return Object.fromEntries(headers.map((header, index) => [header, cells[index] ?? ""]));
  });
}

function priceValue(row: Record<string, string>): number | null {
  for (const key of ["price", "adj_close", "adjClose", "close"]) {
    const raw = row[key];
    if (raw !== undefined && raw !== "") {
      const value = Number(raw);
      return Number.isFinite(value) ? value : null;
    }
  }
  return null;
}

function loadRoundEntryPrices(): EntryPrice[] {
  const text = readRoundText("prices", "entry_prices.csv");
  if (!text) return entryPrices;
  return parseCsv(text)
    .map((row) => ({
      option_id: row.option_id,
      symbol: row.symbol ?? "",
      date: row.date ?? "",
      price: priceValue(row),
      source: row.source || row.price_source || (row.adj_close || row.adjClose ? "adj_close" : "close")
    }))
    .filter((row): row is EntryPrice => Boolean(row.option_id) && row.price !== null);
}

function loadRoundAuditHashes(): HashRecord[] {
  const payload = parseRoundJson<{ files?: Record<string, string> } | HashRecord[]>("hashes.json");
  if (Array.isArray(payload)) return payload;
  if (payload?.files) {
    return Object.entries(payload.files).map(([path, sha256]) => ({ path, sha256 }));
  }
  return auditHashes;
}

function loadRoundWeeklyPerformance(): WeeklyPerformanceRecord[] {
  const text = readRoundText("runs", officialRunId, "results", "weekly_performance.csv");
  if (!text) return [];
  return parseCsv(text)
    .map((row): WeeklyPerformanceRecord => ({
      round_id: row.round_id,
      run_id: row.run_id,
      model_id: row.model_id,
      provider: row.provider,
      target_date: row.target_date,
      price_date: row.price_date,
      days_elapsed: Number(row.days_elapsed),
      run_type: row.run_type,
      submission_format: row.submission_format === "portfolio" ? "portfolio" : "single_pick",
      selected_option_id: row.selected_option_id,
      holding_count: Number(row.holding_count || 1),
      model_return: Number(row.model_return),
      sp500_return: Number(row.sp500_return),
      alpha_vs_sp500: Number(row.alpha_vs_sp500),
      price_status: row.price_status,
      published: row.published !== "false"
    }))
    .filter(
      (row) =>
        Boolean(row.round_id && row.run_id && row.model_id && row.target_date) &&
        Number.isFinite(row.model_return) &&
        Number.isFinite(row.sp500_return) &&
        Number.isFinite(row.alpha_vs_sp500)
    );
}

function optionFromParsed(option: ParsedOption, index: number): UniverseOption {
  const optionId = option.id ?? "UNKNOWN";
  return {
    option_id: optionId,
    name: option.name ?? "Unknown",
    symbol: option.symbol ?? "",
    asset_class: option.asset_class ?? "unknown",
    option_group: option.option_group ?? "unknown",
    risk_bucket: option.risk_bucket ?? "unknown",
    is_cash: Boolean(option.is_cash),
    is_benchmark: Boolean(option.is_benchmark) || optionId.toUpperCase() === "SP500",
    sort_order: index + 1
  };
}

function stripMarkdownHeading(text: string, heading: string): string {
  return text.startsWith(heading) ? text.slice(heading.length).trim() : text;
}

function renderRoundMetadata(manifest: Record<string, unknown>, researchManifest: Record<string, unknown> | null): string {
  const researchCutoff = researchManifest?.research_cutoff_utc ? String(researchManifest.research_cutoff_utc) : "TBD";
  const rows = [
    `Round ID: ${manifest.round_id ?? round.round_id}`,
    `Decision date: ${manifest.decision_date ?? round.decision_date}`,
    `Research cutoff UTC: ${researchCutoff}`,
    `Decision deadline UTC: ${manifest.decision_deadline ?? round.decision_deadline_utc}`,
    `Horizon: ${manifest.horizon ?? round.horizon}`,
    `Entry date: ${manifest.entry_date ?? round.entry_date}`,
    `Exit date: ${manifest.exit_date ?? round.exit_date}`,
    `Entry rule: ${manifest.entry_rule ?? "TBD"}`,
    `Exit rule: ${manifest.exit_rule ?? "TBD"}`,
    "Scoring benchmark: S&P 500 / SPY",
    "Return calculation: adjusted close prices are used when available."
  ];
  return rows.map((line) => `- ${line}`).join("\n");
}

function renderOptionsForPrompt(options: ParsedOption[]): string {
  return options
    .filter((option) => option.include_in_universe !== false)
    .map((option) =>
      [
        "Allowed option:",
        `ID: ${option.id ?? "UNKNOWN"}`,
        `Name: ${option.name ?? "Unknown"}`,
        `Symbol: ${option.symbol || "N/A"}`,
        `Asset class: ${option.asset_class ?? "unknown"}`,
        `Category: ${option.category ?? "unknown"}`,
        `Group: ${option.option_group ?? "unknown"}`,
        `Risk bucket: ${option.risk_bucket ?? "unknown"}`,
        `Description: ${option.exposure_description ?? ""}`
      ].join("\n")
    )
    .join("\n\n");
}

function modelSuffix(output: ModelOutput, allowedOptionIds: string): string {
  if (output.portfolio && output.portfolio.length > 0) {
    return [
      "For this specific call, return only JSON using exactly these identifiers:",
      `- round_id: ${output.round_id}`,
      `- model_id: ${output.model_id}`,
      `- provider: ${output.provider}`,
      `- mode: ${output.mode}`,
      `- allowed portfolio option_id values: ${allowedOptionIds}`
    ].join("\n");
  }
  return [
    "For this specific call, return only JSON using exactly these identifiers:",
    `- round_id: ${output.round_id}`,
    `- model_id: ${output.model_id}`,
    `- provider: ${output.provider}`,
    `- mode: ${output.mode}`,
    `- allowed selected_option_id values: ${allowedOptionIds}`
  ].join("\n");
}

function loadModelOutputs(): ModelOutput[] {
  const parsedDir = join(roundRoot, "runs", officialRunId, "submissions", "parsed");
  if (!existsSync(parsedDir)) {
    return fallbackRoundSubmissions.map((submission) => ({
      ...submission,
      mode: "closed_capability"
    }));
  }
  return readdirSync(parsedDir)
    .filter((filename: string) => filename.endsWith(".json"))
    .sort()
    .map((filename: string) => JSON.parse(readFileSync(join(parsedDir, filename), "utf-8")) as ModelOutput);
}

function submissionFromOutput(output: ModelOutput): SubmissionRecord {
  const allocations = outputAllocations(output);
  const hasPortfolio = Boolean(output.portfolio?.length);
  const selectedOptionId =
    output.selected_option_id ??
    [...allocations].sort((a, b) => b.allocation_bps - a.allocation_bps)[0]?.option_id ??
    "";
  return {
    round_id: output.round_id,
    run_id: officialRunId,
    model_id: output.model_id,
    provider: output.provider,
    submission_format: hasPortfolio ? "portfolio" : "single_pick",
    selected_option_id: selectedOptionId,
    holding_count: allocations.length,
    portfolio: output.portfolio,
    portfolio_rationale: output.portfolio_rationale,
    confidence: Number(output.confidence),
    rationale_summary: output.rationale_summary,
    key_risks: output.key_risks ?? []
  };
}

function holderSummary(asset: ConcentrationAsset, maxItems = 4): string {
  const visible = asset.holders
    .slice(0, maxItems)
    .map((holder) => `${modelLabel(holder.modelId)} ${formatAllocationPct(holder.allocationPct)}`);
  const hiddenCount = asset.holders.length - visible.length;
  return `${visible.join(" / ")}${hiddenCount > 0 ? ` / +${hiddenCount} more` : ""}`;
}

function effectiveSpreadLabel(value: number): string {
  if (!Number.isFinite(value) || value <= 0) return "0 assets";
  return `${value.toFixed(1)} assets`;
}

const promptInstructions = readRoundText("prompt.md");
const modelInputText = readRoundText("model_input.md");
const briefingText = readRoundText("briefing.md");
const optionsYamlText = readRoundText("options.yaml");
const manifestYamlText = readRoundText("manifest.yaml");
const hashesJsonText = readRoundText("hashes.json");
const trailingReturnsText = stripMarkdownHeading(
  readRoundText("market_data", "universe_trailing_returns.md"),
  "# Full-Universe Trailing Returns"
);
const manifestData = parseRoundYaml<Record<string, unknown>>("manifest.yaml") ?? {};
const researchManifest = parseRoundYaml<Record<string, unknown>>("research", "research_manifest.yaml");
const optionsData = parseRoundYaml<{ options?: ParsedOption[] }>("options.yaml");
const parsedOptions = optionsData?.options ?? [];
const roundUniverseOptions = parsedOptions.length ? parsedOptions.map(optionFromParsed) : universeOptions;
const roundOptionsById = Object.fromEntries(roundUniverseOptions.map((option) => [option.option_id, option]));
const roundEntryPrices = loadRoundEntryPrices();
const roundAuditHashes = loadRoundAuditHashes();
const weeklyPerformanceRows = loadRoundWeeklyPerformance();
const resultRows = staticRoundLeaderboard(round.round_id, officialRunId);
const resultWinner = resultRows[0];
const resultReturns = staticRoundReturns(round.round_id, officialRunId);
const allocationResultRows = staticRoundAllocations(round.round_id, officialRunId);
const roundScoreChart = buildScoreReturnChartData({
  leaderboard: resultRows,
  returns: resultReturns,
  optionsById: roundOptionsById,
  allocations: allocationResultRows
});
const scoringPriceRows = staticScoringPrices(round.round_id, officialRunId);
const renderedOptionsForPrompt = renderOptionsForPrompt(parsedOptions);
const allowedOptionIds = parsedOptions
  .filter((option) => option.include_in_universe !== false)
  .map((option) => option.id)
  .filter(Boolean)
  .join(", ");
const renderedRoundMetadata = renderRoundMetadata(manifestData, researchManifest);
const briefingContainsTrailingReturns = briefingText.includes("# Full-Universe Trailing Returns");
const reconstructedSharedPromptPacket = [
  `${promptInstructions}\n\n## Round Metadata\n\n${renderedRoundMetadata}\n\n## Briefing\n\n${briefingText}`,
  trailingReturnsText && !briefingContainsTrailingReturns ? `## Full-Universe Trailing Returns\n\n${trailingReturnsText}` : "",
  `## Options\n\n${renderedOptionsForPrompt}\n`
]
  .filter(Boolean)
  .join("\n\n");
const sharedPromptPacket = modelInputText || reconstructedSharedPromptPacket;
const modelOutputs = loadModelOutputs();
const roundSubmissions = modelOutputs.map(submissionFromOutput);
const runConcentration = buildRunConcentration(roundSubmissions, roundOptionsById);
const topConcentrationAssets = runConcentration.assets.slice(0, 8);
const inputArtifacts = [
  { label: "Base Instructions", path: "prompt.md", text: promptInstructions },
  { label: "Round Manifest", path: "manifest.yaml", text: manifestYamlText },
  { label: "Briefing", path: "briefing.md", text: briefingText },
  { label: "Full-Universe Trailing Returns", path: "market_data/universe_trailing_returns.md", text: trailingReturnsText },
  { label: "Rendered Options In Prompt", path: "options.yaml rendered for model prompt", text: renderedOptionsForPrompt },
  { label: "Source Options YAML", path: "options.yaml", text: optionsYamlText },
  { label: "Round Hashes", path: "hashes.json", text: hashesJsonText }
].filter((artifact) => artifact.text);
const pickCounts = roundSubmissions.reduce<Record<string, number>>((counts, submission) => {
  if (!submission.selected_option_id) return counts;
  counts[submission.selected_option_id] = (counts[submission.selected_option_id] ?? 0) + 1;
  return counts;
}, {});
const consensusPick = Object.entries(pickCounts).sort((a, b) => b[1] - a[1])[0]?.[0] ?? "Pending";
const consensusCount = pickCounts[consensusPick] ?? 0;
const consensusOption = roundUniverseOptions.find((option) => option.option_id === consensusPick);
const consensusPrice = roundEntryPrices.find((price) => price.option_id === consensusPick);
const universeOptionCount = roundUniverseOptions.filter((option) => option.option_id).length;
const decisionNoun = round.submission_format === "portfolio" ? "allocations" : "picks";
const decisionNounSingular = round.submission_format === "portfolio" ? "portfolio" : "pick";
const allocationDisplayNote =
  round.submission_format === "single_pick"
    ? "This test used the original single-pick format. Each valid pick is displayed as a one-holding 100% portfolio while the validated JSON remains unchanged."
    : "This test used the portfolio format. The weights below are the submitted model portfolios.";
const statusLabel = round.status === "resolved" ? "Scored" : round.status === "archived" ? "Archived" : "Pending";
const track = roundTrack(round);
const benchmarkTrackLabel = trackLabel(track);
const roundStateTitle = round.status === "resolved" ? "Final Score Published" : "Score Pending";
const pageTitle = round.status === "resolved" ? `${round.round_id} Result And Proof` : `${round.round_id} Proof Files`;
const pageDescription =
  round.status === "resolved"
    ? `${round.title}: final model portfolio scores, S&P 500 return, Portfolio Minus S&P 500, entry and exit prices, prompt packet, and proof hashes for the ${round.horizon} market test.`
    : `${round.title}: model portfolios, model-facing inputs, prompt packet, starting prices, pending status, and published proof hashes for the ${round.horizon} market test.`;
const roundDataset = datasetSchema({
  name: `${round.round_id} CapitalBench proof dataset`,
  description: `${round.title}: saved model-facing inputs, prompt artifacts, model portfolios, starting prices, status, and published proof hashes.`,
  path: `/rounds/${round.round_id}`,
  datePublished: "2026-05-12",
  temporalCoverage: `${round.entry_date}/${round.exit_date}`,
  keywords: ["LLM market benchmark", "AI market decision", "round audit", round.round_id, "CapitalBench"],
  variableMeasured: [
    "model pick",
    "confidence",
    "model-facing prompt",
    "input artifact",
    "starting price",
    "ending price status",
    "SHA-256 input hash",
    "Portfolio Minus S&P 500"
  ]
});
const priceColumns = [
  { key: "option_id", label: "Option" },
  { key: "symbol", label: "Symbol" },
  { key: "entry_date", label: "Entry Date" },
  { key: "entry_price", label: "Entry Price", align: "right" as const },
  ...(round.status === "resolved"
    ? [
        { key: "exit_date", label: "Exit Date" },
        { key: "exit_price", label: "Exit Price", align: "right" as const },
        { key: "return", label: "Return", align: "right" as const }
      ]
    : []),
  { key: "source", label: "Source" }
];
const priceTableRows = scoringPriceRows.map((row) => ({
  ...row,
  return: row.return === undefined ? "" : pct(row.return)
}));
const resultReturnRows = resultReturns.slice(0, 12).map((row) => ({
  rank: row.rank,
  option_id: row.option_id,
  label: row.label,
  symbol: row.asset_symbol,
  return: pct(row.return),
  entry_price: row.entry_price,
  exit_price: row.exit_price
}));
const assetReturnColumns = [
  { key: "rank", label: "Rank", align: "right" as const },
  { key: "option_id", label: "Option" },
  { key: "label", label: "Name" },
  { key: "symbol", label: "Symbol" },
  { key: "return", label: "Return", align: "right" as const },
  { key: "entry_price", label: "Entry", align: "right" as const },
  { key: "exit_price", label: "Exit", align: "right" as const }
];
const attributionRows = allocationResultRows.map((row) => ({
  model: modelLabel(row.model_id),
  option_id: row.option_id,
  allocation: formatAllocationPct(row.allocation_pct),
  option_return: pct(row.option_return),
  contribution: pct(row.return_contribution)
}));
const attributionColumns = [
  { key: "model", label: "Model" },
  { key: "option_id", label: "Holding" },
  { key: "allocation", label: "Allocation", align: "right" as const },
  { key: "option_return", label: "Asset Return", align: "right" as const },
  { key: "contribution", label: "Contribution", align: "right" as const }
];
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  structuredData={roundDataset}
>
  <section class="dashboard-header">
    <div class="dashboard-title">
      <p class="eyebrow">{round.status === "resolved" ? "Final benchmark result" : "Test proof files"}</p>
      <h1>{round.round_id}</h1>
      <div class="round-meta-row compact" aria-label="Round track">
        <span>{benchmarkTrackLabel} test</span>
        <span>{round.horizon}</span>
      </div>
      <p>{round.description}</p>
    </div>
    <aside class="header-note">
      {round.status === "resolved"
        ? "Scores are published from the saved files for this test."
        : "Model portfolios are saved before scoring. Final returns wait for ending prices."}
    </aside>
  </section>

  {round.status === "resolved" && resultWinner && (
    <section class="section result-section" id="results">
      <div class="result-hero result-hero-round">
        <div>
          <span class="panel-kicker">Official result</span>
          <h2>{modelLabel(resultWinner.model_id)} Won This {benchmarkTrackLabel} Test</h2>
          <p>
            Scored from {dateOnly(round.entry_date)} close to {dateOnly(round.exit_date)} close. This page shows raw
            portfolio return, S&amp;P 500 comparison, and the maximum possible return for the saved asset universe.
          </p>
        </div>
        <div class="result-metrics" aria-label="Round final score summary">
          <article>
            <span>Winner</span>
            <strong>{modelLabel(resultWinner.model_id)}</strong>
            <em>{providerLabel(resultWinner.provider)}</em>
          </article>
          <article>
            <span>Window</span>
            <strong>{dateOnly(round.entry_date)}</strong>
            <em>to {dateOnly(round.exit_date)}</em>
          </article>
          <article>
            <span>Models</span>
            <strong>{resultRows.length}</strong>
            <em>scored portfolios</em>
          </article>
          <article>
            <span>Assets</span>
            <strong>{universeOptionCount}</strong>
            <em>eligible choices</em>
          </article>
        </div>
      </div>

      {roundScoreChart.rows.length > 0 && (
        <div class="published-score-panel round-score-panel">
          <ScoreReturnChart chart={roundScoreChart} label={`${benchmarkTrackLabel} result`} />
        </div>
      )}

      <div class="panel">
        <div class="panel-header">
          <div>
            <span class="panel-kicker">Final leaderboard</span>
            <h2>Official Scores</h2>
            <p>Rows show portfolio return, S&amp;P 500 comparison, and regret versus the maximum possible return.</p>
          </div>
        </div>
        <LeaderboardTable client:visible fallbackRows={resultRows} kind="latest" disableFetch />
      </div>
    </section>
  )}

  <StatusCards
    roundId={round.round_id}
    status={round.status}
    decisionDeadline={round.decision_deadline_utc}
    entryDate={round.entry_date}
    exitDate={round.exit_date}
    officialRunId={round.official_run_id}
  />

  <section class="phase-band compact" aria-label="Test lifecycle">
    <ol class="phase-list">
      <li class="phase-complete">
        <span>1</span>
        <strong>Inputs saved</strong>
        <p>{roundAuditHashes.length} public proof hashes are available.</p>
      </li>
      <li class="phase-complete">
        <span>2</span>
        <strong>Portfolios collected</strong>
        <p>{roundSubmissions.length} valid model {decisionNoun}.</p>
      </li>
      <li class="phase-complete">
        <span>3</span>
        <strong>Start priced</strong>
        <p>{roundEntryPrices.length} starting-price rows published.</p>
      </li>
      <li class={round.status === "resolved" ? "phase-complete" : "phase-current"}>
        <span>4</span>
        <strong>{round.status === "resolved" ? "Scores published" : "Ending prices pending"}</strong>
        <p>
          {round.status === "resolved"
            ? "The scoreboard is available for this completed test."
            : `Scores publish after ${round.exit_date} prices are available.`}
        </p>
      </li>
    </ol>
  </section>

  <nav class="round-tabs" aria-label="Test sections">
    <a href="#overview">Overview</a>
    <a href="#consensus">Consensus</a>
    {round.status === "resolved" && <a href="#results">Results</a>}
    <a href="#performance">Performance</a>
    {round.status === "resolved" && attributionRows.length > 0 && <a href="#attribution">Attribution</a>}
    <a href="#inputs">Inputs</a>
    <a href="#outputs">Outputs</a>
    <a href="#picks">Picks</a>
    <a href="#prices">Prices</a>
    <a href="#audit">Proof</a>
  </nav>

  <section class="dashboard-grid" id="overview">
    <div class="panel">
      <div class="panel-header">
        <div>
          <span class="panel-kicker">Test state</span>
          <h2>{roundStateTitle}</h2>
          <p>
            {round.status === "resolved"
              ? "This test has model portfolios, starting prices, ending prices, and final scores."
              : "This test has saved inputs and model portfolios. The scoreboard remains unavailable until ending prices are collected."}
          </p>
        </div>
        <span class={`status-badge status-${round.status}`}>{statusLabel}</span>
      </div>
      <div class="panel-body">
        <div class="grid-3">
          <article class="feature">
            <span class="metric-label">Model portfolios</span>
            <h3>{roundSubmissions.length} valid {decisionNoun}</h3>
            <p>No invalid parsed submissions are published for the public run.</p>
          </article>
          <article class="feature">
            <span class="metric-label">Asset list</span>
            <h3>{universeOptionCount} saved choices</h3>
            <p>{round.universe_version ?? "Round-specific asset list"} is preserved exactly as the model-facing list.</p>
          </article>
          <article class="feature">
            <span class="metric-label">Scoring</span>
            <h3>{round.status === "resolved" ? "Published" : "Ending prices pending"}</h3>
            <p>Portfolio return, S&P 500 return, maximum possible return, CapitalBench context, and regret publish after scoring.</p>
          </article>
        </div>
        <div class="audit-checklist" aria-label="Round audit checklist">
          <div class="check-item complete">
            <span aria-hidden="true"></span>
            <strong>Input proof hashes</strong>
            <p>{roundAuditHashes.length} artifacts published.</p>
          </div>
          <div class="check-item complete">
            <span aria-hidden="true"></span>
            <strong>Public run selected</strong>
            <p>{round.official_run_id}</p>
          </div>
          <div class="check-item complete">
            <span aria-hidden="true"></span>
            <strong>Model-facing prompt available</strong>
            <p>{sharedPromptPacket.length.toLocaleString()} shared prompt characters.</p>
          </div>
          <div class={`check-item ${round.status === "resolved" ? "complete" : "pending"}`}>
            <span aria-hidden="true"></span>
            <strong>{round.status === "resolved" ? "Ending prices saved" : "Ending prices pending"}</strong>
            <p>
              {round.status === "resolved"
                ? `${scoringPriceRows.length} entry and exit price rows support the final score.`
                : "Scoreboard rows remain withheld until the exit close is priced."}
            </p>
          </div>
        </div>
      </div>
    </div>

    <aside class="rail">
      <div class="rail-panel highlight-panel">
        <span class="metric-label">Most common pick</span>
        <h3>{consensusPick}</h3>
        <p>{consensusCount} of {roundSubmissions.length} models selected this primary {decisionNounSingular}.</p>
        <dl class="mini-facts">
          <div>
            <dt>Symbol</dt>
            <dd>{consensusOption?.symbol}</dd>
          </div>
          <div>
            <dt>Asset Class</dt>
            <dd>{consensusOption?.asset_class}</dd>
          </div>
          <div>
            <dt>Risk</dt>
            <dd>{consensusOption?.risk_bucket}</dd>
          </div>
          <div>
            <dt>Start</dt>
            <dd>{consensusPrice ? `$${consensusPrice.price.toFixed(2)}` : "Pending"}</dd>
          </div>
        </dl>
      </div>
      <div class="rail-panel">
        <span class="metric-label">Methodology</span>
        <h3>{round.methodology_version}</h3>
        <p>{round.submission_format === "portfolio" ? "Portfolio format." : "Single-pick format."} Consistency checks remain separate.</p>
      </div>
      <div class="rail-panel">
        <span class="metric-label">Display rule</span>
        <p>{allocationDisplayNote}</p>
      </div>
      <div class="rail-panel">
        <span class="metric-label">Asset list</span>
        <h3>{round.universe_version ?? "Round-specific"}</h3>
        <p>{universeOptionCount} model-facing choices saved before provider calls.</p>
      </div>
      <div class="rail-panel">
        <span class="metric-label">Boundary</span>
        <p>Benchmark output is research data and should not be interpreted as a trading recommendation.</p>
      </div>
    </aside>
  </section>

  <section class="section round-consensus-section" id="consensus">
    <div class="panel consensus-panel">
      <div class="panel-header">
        <div>
          <span class="panel-kicker">Model consensus</span>
          <h2>Where Models Concentrated In This Test</h2>
          <p>
            Each model has equal weight. This shows the combined portfolio created by averaging all valid model
            portfolios in this {benchmarkTrackLabel.toLowerCase()} test.
          </p>
        </div>
        <span class={`status-badge status-${round.status}`}>
          {round.status === "resolved" ? "Pre-score consensus" : "Score pending"}
        </span>
      </div>

      {runConcentration.assets.length > 0 ? (
        <div class="consensus-body">
          <div class="consensus-summary-grid" aria-label="Run concentration summary">
            <article>
              <span>Top exposure</span>
              <strong>{formatAllocationPct(runConcentration.topAssetSharePct)}</strong>
              <p>{runConcentration.topAsset ? optionDisplayName(runConcentration.topAsset.optionId, roundOptionsById) : "None"}</p>
            </article>
            <article>
              <span>Top 3 exposures</span>
              <strong>{formatAllocationPct(runConcentration.topThreeSharePct)}</strong>
              <p>Combined average allocation to the three largest assets.</p>
            </article>
            <article>
              <span>Effective spread</span>
              <strong>{effectiveSpreadLabel(runConcentration.effectiveAssetCount)}</strong>
              <p>Higher means model capital was spread across more assets.</p>
            </article>
          </div>

          <div class="consensus-layout">
            <div class="consensus-bars" aria-label="Average model allocation by asset">
              <div class="consensus-subhead">
                <span>Average allocation across {runConcentration.modelCount} model portfolios</span>
                <strong>Assets</strong>
              </div>
              <div class="consensus-bar-list">
                {topConcentrationAssets.map((asset) => (
                  <div class="consensus-bar-row">
                    <div class="consensus-asset-label">
                      <strong>{optionDisplayName(asset.optionId, roundOptionsById)}</strong>
                      <span>{asset.modelCount} model{asset.modelCount === 1 ? "" : "s"}: {holderSummary(asset)}</span>
                    </div>
                    <div class="consensus-bar-track" aria-hidden="true">
                      <span
                        class={allocationThemeClass(asset.optionId)}
                        style={`width: ${runConcentration.topAsset ? Math.max(3, (asset.averagePct / runConcentration.topAsset.averagePct) * 100) : 0}%`}
                      />
                    </div>
                    <strong>{formatAllocationPct(asset.averagePct)}</strong>
                  </div>
                ))}
              </div>
            </div>

            <aside class="consensus-category-panel" aria-label="Consensus category mix">
              <div class="consensus-subhead">
                <span>Broader allocation mix</span>
                <strong>Categories</strong>
              </div>
              <div class="consensus-category-stack" aria-hidden="true">
                {runConcentration.categories.map((category) => (
                  <span
                    class={`consensus-category-${category.key}`}
                    style={`width: ${category.averagePct}%`}
                    title={`${category.label} ${formatAllocationPct(category.averagePct)}`}
                  />
                ))}
              </div>
              <div class="consensus-category-list">
                {runConcentration.categories.map((category) => (
                  <div>
                    <span class={`consensus-category-dot consensus-category-${category.key}`} aria-hidden="true"></span>
                    <strong>{category.label}</strong>
                    <em>{formatAllocationPct(category.averagePct)}</em>
                  </div>
                ))}
              </div>
            </aside>
          </div>
        </div>
      ) : (
        <div class="pending-state compact">
          <strong>No model portfolios are available yet.</strong>
          <span>Consensus concentration appears after valid model outputs are saved.</span>
        </div>
      )}
    </div>
  </section>

  <section class="section" id="performance">
    <div class="panel">
      <div class="panel-header">
        <div>
          <span class="panel-kicker">{round.status === "resolved" ? "Realized asset returns" : "Interim tracking"}</span>
          <h2>{round.status === "resolved" ? "What Moved During The Test" : "Live Portfolio And S&P 500 Returns"}</h2>
          <p>
            {round.status === "resolved"
              ? "The table shows the top realized asset returns over the official scoring window. These returns explain the opportunity set behind the model scores."
              : "Once at least one post-entry price snapshot exists, this chart tracks each saved model portfolio against S&P 500 from the test start date. It is interim research context, not the final score."}
          </p>
        </div>
      </div>
      {round.status === "resolved" ? (
        <TableIsland
          client:visible
          rows={resultReturnRows}
          columns={assetReturnColumns}
          emptyText="No realized asset returns are published for this round yet."
          tableLabel="Realized asset returns"
          csvFilename={`${round.round_id}-asset-returns.csv`}
          initialSortKey="rank"
        />
      ) : (
        <RoundPerformanceChart
          client:visible
          fallbackRows={weeklyPerformanceRows}
          roundId={round.round_id}
          runId={round.official_run_id}
        />
      )}
    </div>
  </section>

  {round.status === "resolved" && attributionRows.length > 0 && (
    <section class="section" id="attribution">
      <div class="panel">
        <div class="panel-header">
          <div>
            <span class="panel-kicker">Portfolio attribution</span>
            <h2>How Each Holding Contributed</h2>
            <p>Contribution equals submitted allocation multiplied by the asset return over the scoring window.</p>
          </div>
        </div>
        <TableIsland
          client:visible
          rows={attributionRows}
          columns={attributionColumns}
          emptyText="No portfolio attribution rows are published for this round yet."
          tableLabel="Portfolio attribution"
          csvFilename={`${round.round_id}-portfolio-attribution.csv`}
        />
      </div>
    </section>
  )}

  <section class="section" id="inputs">
    <div class="panel">
      <div class="panel-header">
        <div>
          <span class="panel-kicker">Saved model-facing context</span>
          <h2>Prompt And Input Packet</h2>
          <p>
            The shared packet below is the prompt body common to every model call. Each provider call appends a
            small model-specific identifier block shown after the artifacts.
          </p>
        </div>
      </div>
      <div class="audit-packet">
        <details class="artifact-card artifact-primary">
          <summary>
            <span>Shared Model-Facing Prompt Packet</span>
            <small>{sharedPromptPacket.length.toLocaleString()} characters</small>
          </summary>
          <pre class="artifact-pre"><code>{sharedPromptPacket}</code></pre>
        </details>

        <div class="artifact-grid">
          {inputArtifacts.map((artifact) => (
            <details class="artifact-card">
              <summary>
                <span>{artifact.label}</span>
                <small>{artifact.path}</small>
              </summary>
              <pre class="artifact-pre"><code>{artifact.text}</code></pre>
            </details>
          ))}
        </div>

        <details class="artifact-card">
          <summary>
            <span>Per-Model Prompt Suffixes</span>
            <small>{modelOutputs.length} model calls</small>
          </summary>
          <div class="suffix-list">
            {modelOutputs.map((output) => (
              <article class="suffix-card">
                <strong>{modelLabel(output.model_id)}</strong>
                <pre class="artifact-pre compact-pre"><code>{modelSuffix(output, allowedOptionIds)}</code></pre>
              </article>
            ))}
          </div>
        </details>
      </div>
    </div>
  </section>

  <section class="section" id="outputs">
    <div class="panel">
      <div class="panel-header">
        <div>
          <span class="panel-kicker">Parsed provider responses</span>
          <h2>Model Outputs</h2>
          <p>
            These are the validated JSON submissions used by CapitalBench. Raw provider response text remains excluded
            from the public site.
          </p>
        </div>
      </div>
      <div class="model-output-grid">
        {modelOutputs.map((output) => {
          const allocations = outputAllocations(output);
          const primaryAllocation = outputPrimaryAllocation(output);
          return (
            <article class={`model-output-card model-output-${output.provider}`}>
              <div class="model-output-head">
                <div>
                  <span class={`provider-badge provider-${output.provider}`}>{providerLabel(output.provider)}</span>
                  <h3>{modelLabel(output.model_id)}</h3>
                  <p class="mono">{output.model_id}</p>
                </div>
                <div class="output-allocation-summary">
                  <span>{allocations.length > 1 ? `${allocations.length} holdings` : "Portfolio"}</span>
                  <strong>
                    {primaryAllocation
                      ? optionDisplayName(primaryAllocation.option_id, roundOptionsById)
                      : outputPickLabel(output) || "No portfolio"}
                  </strong>
                  {allocations.length > 0 && (
                    <div class="allocation-chip-row compact" aria-label="Portfolio holdings">
                      {allocations.map((allocation) => (
                        <span
                          class="allocation-chip"
                          title={`${optionDisplayName(allocation.option_id, roundOptionsById)} ${formatAllocationPct(allocation.allocation_pct)}`}
                        >
                          <span class={`allocation-dot ${allocationThemeClass(allocation.option_id)}`} aria-hidden="true"></span>
                          <strong>{optionShortDisplayName(allocation.option_id, roundOptionsById)}</strong>
                          <span>{formatAllocationPct(allocation.allocation_pct)}</span>
                        </span>
                      ))}
                    </div>
                  )}
                </div>
              </div>
              <div class="allocation-stack output-stack" aria-hidden="true">
                {allocations.map((allocation) => (
                  <span
                    class={allocationThemeClass(allocation.option_id)}
                    style={`width: ${Math.max(3, allocation.allocation_pct)}%`}
                    title={`${optionDisplayName(allocation.option_id, roundOptionsById)} ${formatAllocationPct(allocation.allocation_pct)}`}
                  />
                ))}
              </div>
              <dl class="output-facts">
                <div>
                  <dt>Confidence</dt>
                  <dd>{Number(output.confidence).toFixed(2)}</dd>
                </div>
                <div>
                  <dt>Run Type</dt>
                  <dd>{String(output.run_type ?? "official")}</dd>
                </div>
              </dl>
              <div class="output-copy">
                <span class="metric-label">Rationale</span>
                {output.portfolio_rationale && <p>{output.portfolio_rationale}</p>}
                <p>{output.rationale_summary}</p>
              </div>
              {allocations.length > 0 && (
                <div class="output-copy">
                  <span class="metric-label">Portfolio</span>
                  <ul>
                    {allocations.map((allocation) => (
                      <li>
                        <strong>{optionDisplayName(allocation.option_id, roundOptionsById)}</strong>:{" "}
                        {formatAllocationPct(allocation.allocation_pct)}
                        {allocation.rationale ? ` - ${allocation.rationale}` : ""}
                      </li>
                    ))}
                  </ul>
                </div>
              )}
              <div class="output-copy">
                <span class="metric-label">Key Risks</span>
                <ul>
                  {(output.key_risks ?? []).map((risk) => <li>{risk}</li>)}
                </ul>
              </div>
              <details class="json-details">
                <summary>Validated JSON</summary>
                <pre class="artifact-pre compact-pre"><code>{JSON.stringify(output, null, 2)}</code></pre>
              </details>
            </article>
          );
        })}
      </div>
    </div>
  </section>

  <section class="section" id="picks">
    <div class="panel">
      <div class="panel-header">
        <div>
          <span class="panel-kicker">Public model run</span>
          <h2>Model Portfolios</h2>
          <p>{allocationDisplayNote} Expand a row to inspect rationale and risk lists without crowding the main table.</p>
        </div>
      </div>
      <OfficialPicksTable
        client:visible
        fallbackRows={roundSubmissions}
        roundId={round.round_id}
        runId={round.official_run_id}
        options={roundUniverseOptions}
      />
    </div>
  </section>

  <section class="section" id="prices">
    <div class="panel">
      <div class="panel-header">
        <div>
          <span class="panel-kicker">Pricing</span>
          <h2>{round.status === "resolved" ? "Scoring Prices" : "Starting Prices"}</h2>
          <p>
            {round.status === "resolved"
              ? "Entry and exit prices are shown for the completed close-to-close scoring window."
              : "Ending prices are intentionally absent until the test is complete."}
          </p>
        </div>
      </div>
      <TableIsland
        client:visible
        rows={priceTableRows}
        columns={priceColumns}
        emptyText="No pricing rows are published yet."
        tableLabel={round.status === "resolved" ? "Scoring prices" : "Starting prices"}
        csvFilename={round.status === "resolved" ? "capitalbench-scoring-prices.csv" : "capitalbench-starting-prices.csv"}
      />
    </div>
  </section>

  <section class="section" id="audit">
    <div class="panel">
      <div class="panel-header">
        <div>
          <span class="panel-kicker">Proof</span>
          <h2>Published Hashes</h2>
          <p>Test inputs are hashed before model calls and mirrored into the public read model.</p>
        </div>
      </div>
      <HashTable client:visible rows={roundAuditHashes} />
    </div>
  </section>
</BaseLayout>
