---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
---

<BaseLayout
  title="CapitalBench Pro"
  description="CapitalBench Pro is a future gated product shell for exports, API access, and advanced benchmark analytics."
  noindex
>
  <PageHeader
    eyebrow="Future Pro"
    title="CapitalBench Pro"
    summary="Public benchmark results stay free. Future Pro work is reserved for gated exports, API access, raw artifact access, and advanced historical analytics."
  />
  <section class="section">
    <div class="resolution-callout">
      <div>
        <span class="panel-kicker">Future workspace</span>
        <h2>Not Available Yet</h2>
        <p>
          Billing, account management, API keys, private exports, and advanced analytics are intentionally deferred.
          The public benchmark, round packets, and leaderboards remain the canonical product surface.
        </p>
      </div>
      <a class="action-link action-primary" href="/leaderboards/latest">View public results</a>
    </div>
  </section>
</BaseLayout>
