---
import BaseLayout from "../layouts/BaseLayout.astro";
import { ArrowRight, CalendarClock, CheckCircle2, CreditCard, LockKeyhole, ReceiptText } from "lucide-react";
import { fundingUses, monthlyContributionTiers, oneTimeContributionTiers } from "../data/contributions";

const faqs = [
  {
    question: "Is this customer support?",
    answer:
      "No. This page is for voluntary financial contributions to CapitalBench. For operational questions, use the contact details in Stripe receipts or the public repository."
  },
  {
    question: "Are contributions tax deductible?",
    answer:
      "Contributions are not tax-deductible charitable donations unless explicitly stated. CapitalBench is presented here as public benchmark infrastructure, not as a registered charity."
  },
  {
    question: "Can I cancel a monthly contribution?",
    answer:
      "Yes. Monthly contributions are processed by Stripe. Stripe receipts and billing emails provide the payment record; contact CapitalBench if you need subscription help."
  },
  {
    question: "Does contributing affect the benchmark?",
    answer:
      "No. Contributions do not affect model selection, methodology, scoring, publication timing, or results."
  }
];

const assuranceItems = [
  {
    icon: LockKeyhole,
    title: "Independence",
    text:
      "Funding does not affect methodology, model inclusion, scoring, publication timing, or benchmark results."
  },
  {
    icon: ReceiptText,
    title: "Billing",
    text:
      "Payments are processed by Stripe. Monthly contributions renew automatically until cancelled."
  },
  {
    icon: CreditCard,
    title: "Security",
    text:
      "CapitalBench does not collect or store card details on this website."
  }
];
---

<BaseLayout
  title="Contribute to CapitalBench"
  description="Contribute to CapitalBench public benchmark infrastructure through monthly or one-time Stripe-hosted contributions."
>
  <section class="contribute-hero refined" aria-labelledby="contribute-title">
    <div class="contribute-hero-copy">
      <p class="eyebrow">Independent public benchmark</p>
      <h1 id="contribute-title">Fund CapitalBench</h1>
      <p class="contribute-lede">
        CapitalBench publishes auditable LLM market benchmark rounds. Contributions help pay for model calls, market
        data, hosting, audit tooling, and public reporting.
      </p>
      <div class="contribute-actions" aria-label="Contribution shortcuts">
        <a class="action-link action-primary" href="#monthly">
          <CalendarClock size={17} aria-hidden="true" />
          Monthly contribution
        </a>
        <a class="action-link" href="#one-time">
          One-time contribution
          <ArrowRight size={15} aria-hidden="true" />
        </a>
      </div>
      <p class="contribute-note">
        Contributions are voluntary, processed by Stripe, and do not buy access, influence, or leaderboard placement.
      </p>
    </div>

    <aside class="contribute-summary" aria-label="Contribution summary">
      <div>
        <span class="panel-kicker">What funding covers</span>
        <h2>Public Research Operations</h2>
      </div>
      <ul>
        {fundingUses.slice(0, 4).map((item) => (
          <li><CheckCircle2 size={16} aria-hidden="true" /> {item}</li>
        ))}
      </ul>
      <div class="summary-boundary">
        <LockKeyhole size={17} aria-hidden="true" />
        <span>No influence over benchmark design, scoring, or publication.</span>
      </div>
    </aside>
  </section>

  <section id="monthly" class="section contribute-section contribution-feature" aria-labelledby="monthly-title">
    <div class="contribute-section-head">
      <span class="panel-kicker">Recurring funding</span>
      <h2 id="monthly-title">Choose a monthly level</h2>
      <p>Recurring contributions make future public rounds easier to plan and maintain.</p>
    </div>
    <div class="contribution-grid monthly-grid">
      {monthlyContributionTiers.map((tier) => (
        <article class:list={["contribution-card", tier.featured && "featured"]}>
          <div>
            <span class="metric-label">{tier.name}</span>
            <h3>{tier.amount}<small>/mo</small></h3>
            <p>{tier.description}</p>
          </div>
          <a class="contribution-button" href={tier.href} target="_blank" rel="noreferrer">
            <span>{tier.cta}</span>
            <ArrowRight size={15} aria-hidden="true" />
          </a>
        </article>
      ))}
    </div>
  </section>

  <section id="one-time" class="section contribute-section" aria-labelledby="one-time-title">
    <div class="one-time-panel">
      <div class="one-time-copy">
        <span class="panel-kicker">One-time funding</span>
        <h2 id="one-time-title">Make a one-time contribution</h2>
        <p>Use a fixed amount or choose a custom one-time amount through Stripe-hosted checkout.</p>
      </div>
      <div class="one-time-options" aria-label="One-time contribution options">
        {oneTimeContributionTiers.map((tier) => (
          <a class="amount-option" href={tier.href} target="_blank" rel="noreferrer">
            <span>{tier.amount}</span>
            <small>{tier.cta}</small>
            <ArrowRight size={15} aria-hidden="true" />
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="contribute-assurance" aria-label="Contribution assurances">
    {assuranceItems.map((item) => {
      const Icon = item.icon;
      return (
        <div>
          <Icon size={20} aria-hidden="true" />
          <h2>{item.title}</h2>
          <p>{item.text}</p>
        </div>
      );
    })}
  </section>

  <section class="section contribute-faq" aria-labelledby="contribute-faq-title">
    <div class="contribute-section-head">
      <span class="panel-kicker">Questions</span>
      <h2 id="contribute-faq-title">Contribution FAQ</h2>
    </div>
    <div class="faq-list">
      {faqs.map((item) => (
        <details>
          <summary>{item.question}</summary>
          <p>{item.answer}</p>
        </details>
      ))}
    </div>
  </section>
</BaseLayout>
