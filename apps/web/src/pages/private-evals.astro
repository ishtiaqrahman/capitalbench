---

<BaseLayout
  title="Private AI Investment Benchmark Evaluations"
  description={pageDescription}
  ogTitle="Benchmark Your AI Investment System"
  ogDescription="A fixed-scope, private CapitalBench evaluation against frontier AI models."
  hideFooterSignup
  structuredData={serviceSchema}
>
  <section class="private-evals-hero" aria-labelledby="private-evals-title">
    <div class="private-evals-hero-copy">
      <p class="eyebrow">PRIVATE CAPITALBENCH EVALS</p>
      <h1 id="private-evals-title">Private AI capital allocation evals.</h1>
      <p>
        CapitalBench independently evaluates your model, agent, or workflow using the same frozen market brief,
        portfolio constraints, and outcome window as leading AI systems.
      </p>
      <div class="private-evals-actions">
        <a class="action-link action-primary" href="#request">
          Request Scope Review
        </a>
        <a
          class="action-link"
          href="/private-eval-sample-report/"
          data-analytics-event="private_eval_sample_report_click"
        >
          View Sample Report
        </a>
      </div>
      <p class="private-evals-commercial">
        Launch price: <strong>$3,000 USD</strong> · Typical completion: <strong>10-14 calendar days</strong> · Fixed scope
      </p>
      <p>
        You receive a private comparative scorecard, consistency analysis, failure-mode review, machine-readable
        results, and a complete audit packet.
      </p>
      <p class="private-evals-trust">Private by default · No source code or model weights required · No real capital traded</p>
    </div>

    <aside class="private-evals-scorecard" aria-label="Illustrative CapitalBench scorecard preview">
      <div class="private-evals-scorecard-head">
        <div>
          <span class="panel-kicker">Private scorecard preview</span>
          <h2>Illustrative scorecard · Actual results vary</h2>
        </div>
        <span>{sampleRound?.round_id ?? "Public round"}</span>
      </div>
      <div class="private-evals-dossier-tabs" aria-label="Private evaluation dossier artifacts">
        <span>Scorecard</span>
        <span>Audit</span>
        <span>Consistency</span>
        <span>Readout</span>
      </div>
      <div class="private-evals-scorecard-table" role="table" aria-label="Illustrative scorecard metrics">
        <div role="row" class="private-evals-scorecard-row private-evals-scorecard-header">
          <span role="columnheader">Metric</span>
          <span role="columnheader">Sample leader</span>
          <span role="columnheader">Public median</span>
          <span role="columnheader">Context</span>
        </div>
        {sampleScorecardRows.map(([metric, leader, median, context]) => (
          <div role="row" class="private-evals-scorecard-row">
            <span role="cell">{metric}</span>
            <span role="cell">{leader}</span>
            <span role="cell">{median}</span>
            <span role="cell">{context}</span>
          </div>
        ))}
      </div>
      <dl class="private-evals-dossier-meta">
        <div>
          <dt>Evaluation type</dt>
          <dd>Private sprint</dd>
        </div>
        <div>
          <dt>Official run</dt>
          <dd>Weekly window</dd>
        </div>
        <div>
          <dt>Execution</dt>
          <dd>No real capital</dd>
        </div>
      </dl>
      <div class="private-evals-stat-strip" aria-label="Current public benchmark statistics">
        {publicStats.map((stat) => (
          <div>
            <strong>{stat.value}</strong>
            <span>{stat.label}</span>
          </div>
        ))}
      </div>
      <div class="private-evals-comparator-strip" aria-label="Dynamic comparator roster example">
        <span>Current comparator source</span>
        <div>
          {comparatorLabels.map((label) => <small>{label}</small>)}
        </div>
      </div>
    </aside>
  </section>

  <nav class="private-evals-sticky-nav" aria-label="Private eval page sections">
    <div>
      <a href="#overview">Overview</a>
      <a href="#scope">Scope</a>
      <a href="#process">Process</a>
      <a href="#metrics">Metrics</a>
      <a href="#deliverables">Deliverables</a>
      <a href="#security">Security</a>
      <a href="#pricing">Pricing</a>
      <a href="#faq">FAQ</a>
    </div>
    <a class="private-evals-sticky-button" href="#request">Request Scope Review</a>
