const processSteps = [
  [
    "Scope review",
    "Before purchase",
    "CapitalBench confirms the system, business question, access method, comparator roster, and whether the evaluation can be run fairly.",
    "15-20 minutes",
    "fit confirmation and fixed scope"
  ],
