---
import BaseLayout from "../layouts/BaseLayout.astro";
import apiReadModel from "../generated/apiReadModel.js";
import { siteConfig, type JsonLdRecord } from "../lib/seo";

const pageDescription =
  "Privately benchmark AI investment models with frozen inputs, real market outcomes, consistency testing, and auditable results.";

const rounds = apiReadModel.rounds ?? [];
const models = (apiReadModel.models ?? []).filter((model: any) => model.active !== false);
const assets = (apiReadModel.assets ?? []).filter((asset: any) => asset.in_current_universe !== false);
const results = apiReadModel.results ?? [];
const latestActiveWeeklyRound =
  rounds.find((round: any) => round.track === "weekly" && round.status === "active") ??
  rounds.find((round: any) => round.track === "weekly");
const sampleRound =
  rounds.find((round: any) => round.round_id === "CB-2026-05-28-1W") ??
  rounds.find((round: any) => round.track === "weekly" && round.status === "resolved") ??
  rounds[0];
const sampleRoundHref = sampleRound?.proof?.round_page_url ?? `/rounds/${sampleRound?.round_id ?? "CB-2026-05-28-1W"}/`;
const currentComparators = models
  .filter((model: any) => model.latest_round_id === latestActiveWeeklyRound?.round_id)
  .slice(0, 4);
const comparatorLabels = currentComparators.length
  ? currentComparators.map((model: any) => model.label)
  : models.slice(0, 4).map((model: any) => model.label);

const publicStats = [
  { value: String(rounds.length), label: "public rounds in the read model" },
  { value: String(models.length), label: "supported public model profiles" },
  { value: String(assets.length), label: "current ETF and cash universe entries" },
  { value: String(results.length), label: "scored public result rows" }
];

const modelLabelById = new Map(models.map((model: any) => [model.model_id, model.label]));
const sampleRoundResults = results
  .filter((result: any) => result.round_id === sampleRound?.round_id)
  .sort((left: any, right: any) => (left.rank ?? 999) - (right.rank ?? 999));
const sampleRoundReturns = (apiReadModel.returns ?? [])
  .filter((result: any) => result.round_id === sampleRound?.round_id)
  .sort((left: any, right: any) => (left.rank ?? 999) - (right.rank ?? 999));
const topSampleResult = sampleRoundResults[0];
const bestSampleAsset = sampleRoundReturns.find((row: any) => row.rank === 1) ?? sampleRoundReturns[0];
const benchmarkSampleReturn =
  topSampleResult?.benchmark_return_pct ??
  sampleRoundReturns.find((row: any) => row.is_benchmark)?.return_pct;
const medianNumber = (values: number[]) => {
  const cleanValues = values.filter((value) => Number.isFinite(value)).sort((left, right) => left - right);
  if (!cleanValues.length) return null;
  const middle = Math.floor(cleanValues.length / 2);
  return cleanValues.length % 2
    ? cleanValues[middle]
    : (cleanValues[middle - 1] + cleanValues[middle]) / 2;
};
const formatPct = (value: number | null | undefined) =>
  typeof value === "number" && Number.isFinite(value) ? `${value.toFixed(2)}%` : "Reported privately";
const formatScore = (value: number | null | undefined) =>
  typeof value === "number" && Number.isFinite(value) ? value.toFixed(1) : "Reported privately";
const topSampleModel = topSampleResult
  ? (modelLabelById.get(topSampleResult.model_id) ?? topSampleResult.model_id)
  : "Top public model";
const medianPortfolioReturn = medianNumber(sampleRoundResults.map((result: any) => result.portfolio_return_pct));
const medianScore = medianNumber(sampleRoundResults.map((result: any) => result.capitalbench_score));
const medianAlpha = medianNumber(sampleRoundResults.map((result: any) => result.alpha_pp));
const sampleScorecardRows = [
  ["Best public model", topSampleModel, `${sampleRoundResults.length || "Current"} public systems`, bestSampleAsset?.label ?? "Best eligible asset"],
  ["Portfolio return", formatPct(topSampleResult?.portfolio_return_pct), formatPct(medianPortfolioReturn), `${bestSampleAsset?.ticker ?? bestSampleAsset?.label ?? "Oracle"} ${formatPct(bestSampleAsset?.return_pct)}`],
  ["CapitalBench Score", formatScore(topSampleResult?.capitalbench_score), formatScore(medianScore), "100.0 oracle"],
  ["S&P difference", formatPct(topSampleResult?.alpha_pp), formatPct(medianAlpha), `S&P 500 ${formatPct(benchmarkSampleReturn)}`],
  ["Consistency evidence", "5 repeated runs", "Overlap and dispersion", "Raw outputs audited"],
  ["Private delivery", "Report + CSV/JSON", "Failure register", "Audit packet"]
];

const proofCells = [
  ["Same frozen inputs", "Every system receives the same approved evaluation packet."],
  ["Current comparators", "Compare against up to four supported frontier models."],
  ["Real outcomes", "Official performance resolves using actual market prices."],
  ["Consistency testing", "Repeated runs reveal unstable or highly variable decisions."],
  ["Auditable files", "Inputs, outputs, timestamps, hashes, prices, and calculations are preserved."]
];

const valueCards = [
  [
    "Choose the right model",
    "Compare your current system with frontier alternatives under identical conditions."
  ],
  [
    "Validate a release",
    "Test the exact model, prompt, workflow, and configuration you are considering shipping."
  ],
  [
    "Diagnose behavior",
    "Identify concentration, instability, invalid outputs, excessive risk-taking, weak diversification, or poor cost-performance trade-offs."
  ],
  [
    "Support internal claims",
    "Give product leaders, investors, research teams, and customers evidence that is more defensible than screenshots or selected examples."
  ]
];

const decisionQuestions = [
  "Which model should power our investment product?",
  "Did our fine-tune or new prompt actually improve the system?",
  "Is the model's allocation stable when the same decision is repeated?",
  "Does a more expensive model produce meaningfully better results?",
  "Is the system too concentrated, aggressive, or consensus-driven?",
  "What should we fix before launching or retesting?"
];

const scopeRows = [
  ["Client system", "One model, agent, workflow, or configuration"],
  ["Comparator roster", "Up to four currently supported frontier models"],
  ["Official evaluation", "One live weekly CapitalBench allocation round"],
  ["Consistency evaluation", "Five separate non-official repeated runs per system"],
  ["Asset universe", "Current CapitalBench public ETF and cash universe"],
  ["Portfolio format", "One to five holdings, fixed allocation increments, 100% total"],
  ["Information access", "Same frozen brief, prompt, universe, and market-data packet"],
  ["Base evaluation mode", "Browsing, tools, and live retrieval disabled"],
  ["Performance window", "Approximately one week"],
  ["Final output", "Report, scorecard, data export, audit bundle, and readout"],
  ["Confidentiality", "Private unless the client approves publication in writing"]
];

const evaluationPlanRows = [
  ["System under test", "Model name, version, endpoint, prompt configuration, and relevant settings"],
  ["Primary business question", "The decision the company wants the evaluation to support"],
  ["Comparator roster", "Exact comparator models and versions"],
  ["Evaluation mode", "Controlled or production workflow"],
  ["Input packet", "Prompt, briefing, market data, asset universe, and schema"],
  ["Portfolio constraints", "Holdings limit, allocation increments, cash rules, and total weight"],
  ["Official-run policy", "Number of official calls and allowed retry conditions"],
