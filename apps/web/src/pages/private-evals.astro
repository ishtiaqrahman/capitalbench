            <input name="model_or_system_name" type="text" />
          </label>
          <label>
            Current model provider
            <input name="current_model_provider" type="text" />
          </label>
          <label>
            Tools or browsing used?
            <select name="tools_or_browsing">
              <option value="">Select one</option>
              <option>No</option>
              <option>Yes</option>
              <option>Not sure</option>
            </select>
            <small class="private-evals-field-note">Select yes if the normal workflow retrieves live data, uses tools, or browses.</small>
          </label>
          <label>
            Custom asset universe required?
            <select name="custom_asset_universe_required">
              <option value="">Select one</option>
              <option>No</option>
              <option>Yes</option>
              <option>Not sure</option>
            </select>
            <small class="private-evals-field-note">The standard sprint uses the current public CapitalBench ETF and cash universe.</small>
          </label>
        </div>
      </div>
      <div class="private-evals-form-group">
        <div class="private-evals-form-group-head">
          <span>03</span>
          <h3>Access and timing</h3>
        </div>
        <div class="private-evals-form-grid">
          <label>
            Preferred access method <span class="private-evals-required" aria-hidden="true">*</span>
            <select name="access_method" required>
              <option value="">Select one</option>
              {accessOptions.map((option) => <option value={option}>{option}</option>)}
            </select>
            <small class="private-evals-field-note">Choose the closest option; access is finalized only after scope review.</small>
          </label>
          <label>
            Desired start period <span class="private-evals-required" aria-hidden="true">*</span>
            <select name="start_period" required>
              <option value="">Select one</option>
              {startOptions.map((option) => <option value={option}>{option}</option>)}
            </select>
          </label>
          <label>
            NDA required before discussion?
            <select name="nda_required">
              <option value="">Select one</option>
              <option>No</option>
              <option>Yes</option>
              <option>Not sure</option>
            </select>
          </label>
          <label>
            Sensitive or regulated data involved?
            <select name="sensitive_or_regulated_data">
              <option value="">Select one</option>
              <option>No</option>
              <option>Yes</option>
              <option>Not sure</option>
            </select>
            <small class="private-evals-field-note">Do not submit sensitive data in this form.</small>
          </label>
          <label>
            Procurement or security review required?
            <select name="procurement_or_security_review">
              <option value="">Select one</option>
              <option>No</option>
              <option>Yes</option>
              <option>Not sure</option>
            </select>
          </label>
        </div>
      </div>
      <div class="private-evals-form-group">
        <div class="private-evals-form-group-head">
          <span>04</span>
          <h3>Project summary</h3>
        </div>
        <label class="private-evals-form-wide">
          Project summary <span class="private-evals-required" aria-hidden="true">*</span>
          <textarea
            name="project_summary"
            rows="6"
            minlength="20"
            required
            placeholder="Tell us what system you want tested, the decision this supports, and any timing or access constraints."
          ></textarea>
        </label>
      </div>
      <label class="private-evals-consent">
        <input type="checkbox" name="consent" value="yes" required />
        <span>
          By submitting, you agree that CapitalBench may contact you about this evaluation request. Do not submit API
          keys, passwords, source code, customer data, or other secrets through this form.
        </span>
      </label>
      <div class="private-evals-form-footer">
        <button type="submit">Request Scope Review</button>
        <p data-private-eval-form-status role="status" aria-live="polite"></p>
      </div>
    </form>
  </section>

  <section id="procurement" class="private-evals-section private-evals-procurement" aria-labelledby="procurement-title">
    <div class="private-evals-section-head">
      <span class="panel-kicker">Procurement</span>
      <h2 id="procurement-title">Procurement and billing</h2>
    </div>
    <div class="private-evals-procurement-grid">
      {procurementRows.map(([label, value]) => (
        <div>
          <span>{label}</span>
          {
            value.includes("@") ? (
              <a
                href={`mailto:${value}`}
                data-analytics-event={value.startsWith("evals@") ? "private_eval_email_click" : undefined}
              >
                {value}
              </a>
            ) : (
              <strong>{value}</strong>
            )
          }
        </div>
      ))}
    </div>
  </section>

  <section id="final-disclaimer" class="private-evals-disclaimer" aria-label="CapitalBench private eval disclaimer">
    <p>
      CapitalBench provides AI-model evaluation and research services. Results apply only to the tested system, version,
      configuration, inputs, constraints, and evaluation window. Results do not constitute investment advice, a
      recommendation to trade, certification, regulatory approval, endorsement, or a guarantee of future performance.
      Short market windows may be affected by noise and unusual events. The applicable SOW governs confidentiality, data
      handling, permitted use, payment, and delivery.
    </p>
    <nav aria-label="Private eval footer links">
      <a href="/methodology/">Methodology</a>
      <a href={sampleRoundHref}>Audit</a>
      <a href="/private-eval-sample-report/" data-analytics-event="private_eval_sample_report_click">Sample Report</a>
      <a href="#security">Data Handling</a>
      <a href="/privacy/">Privacy</a>
      <a href="#procurement">Terms</a>
      <a href="mailto:evals@capitalbench.org" data-analytics-event="private_eval_email_click">Contact</a>
    </nav>
  </section>

  <a class="private-evals-mobile-cta" href="#request">Request Scope Review</a>

  <script is:inline>
    (() => {
      const eventNameRe = /^[a-z][a-z0-9_]{0,39}$/;
      const track = (name, params = {}) => {
        if (!eventNameRe.test(name)) return;
        if (window.capitalbenchAnalytics && typeof window.capitalbenchAnalytics.track === "function") {
          window.capitalbenchAnalytics.track(name, params);
          return;
        }
        if (typeof window.gtag === "function") {
          window.gtag("event", name, {
            ...params,
            page_path: window.location.pathname || "/",
            page_location: `${window.location.origin}${window.location.pathname || "/"}`,
            transport_type: "beacon"
          });
        }
      };

      const onReady = (callback) => {
        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", callback, { once: true });
        } else {
          callback();
        }
      };

      onReady(() => {
        track("private_eval_page_view");

        const observeOnce = (selector, eventName) => {
          const element = document.querySelector(selector);
          if (!element || !("IntersectionObserver" in window)) return;
          const observer = new IntersectionObserver(
            (entries) => {
              if (!entries.some((entry) => entry.isIntersecting)) return;
              track(eventName);
              observer.disconnect();
            },
            { threshold: 0.35 }
          );
          observer.observe(element);
        };

        observeOnce("[data-private-eval-pricing]", "private_eval_pricing_view");
        observeOnce("[data-private-eval-addons]", "private_eval_addon_view");

        const mobileCta = document.querySelector(".private-evals-mobile-cta");
        const hero = document.querySelector(".private-evals-hero");
        const requestSection = document.querySelector("#request");
        if (mobileCta && hero) {
          const toggleMobileCta = () => {
            const heroBottom = hero.getBoundingClientRect().bottom;
            const requestTop = requestSection?.getBoundingClientRect().top ?? Number.POSITIVE_INFINITY;
            mobileCta.classList.toggle("is-visible", heroBottom < 80 && requestTop > window.innerHeight * 0.82);
          };
          toggleMobileCta();
          window.addEventListener("scroll", toggleMobileCta, { passive: true });
          window.addEventListener("resize", toggleMobileCta);
        }

        document.querySelectorAll("[data-private-eval-faq]").forEach((details) => {
          details.addEventListener("toggle", () => {
            if (details.open) {
              track("private_eval_faq_open", {
                question: details.getAttribute("data-private-eval-faq") || ""
              });
            }
          });
        });

        const form = document.querySelector("[data-private-eval-form]");
        if (!form) return;
        const status = form.querySelector("[data-private-eval-form-status]");
        let started = false;

        form.addEventListener("input", () => {
          if (started) return;
          started = true;
          track("private_eval_form_start");
        });

        form.addEventListener("submit", async (event) => {
          event.preventDefault();
          const button = form.querySelector("button[type='submit']");
          const originalButtonText = button ? button.textContent : "";
          if (button) {
            button.disabled = true;
            button.textContent = "Submitting...";
          }
          if (status) status.textContent = "";

          try {
            const payload = Object.fromEntries(new FormData(form).entries());
            payload.pageUrl = window.location.href;
            const response = await fetch("/api/private-evals", {
              method: "POST",
              headers: { "content-type": "application/json" },
              body: JSON.stringify(payload)
            });
            const result = await response.json().catch(() => ({}));

            if (!response.ok || !result.ok) {
              throw new Error(result.error || "private_eval_form_error");
            }

            track("private_eval_form_submit");
            form.reset();
            if (status) {
              status.textContent =
                result.message ||
                "Your request has been received. The next step is a fit review followed by a proposed Evaluation Plan and fixed SOW. No payment or system access is requested until scope is agreed.";
            }
          } catch (error) {
            track("private_eval_form_error", {
              error: error instanceof Error ? error.message : "unknown"
            });
            if (status) {
              status.textContent =
                "The request could not be submitted. Email evals@capitalbench.org with the same details.";
            }
          } finally {
            if (button) {
              button.disabled = false;
              button.textContent = originalButtonText || "Request Scope Review";
            }
          }
        });
      });
    })();
  </script>
</BaseLayout>
