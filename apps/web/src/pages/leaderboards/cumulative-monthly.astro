---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import PendingLeaderboardGuide from "../../components/PendingLeaderboardGuide.astro";
import TrackScorecard from "../../components/TrackScorecard.astro";
import { staticRoundRecords } from "../../lib/localRoundRecords";
import { buildTrackScorecard } from "../../lib/trackScorecard";

const scorecard = buildTrackScorecard(staticRoundRecords(), "monthly");
---

<BaseLayout
  title="Overall Monthly CapitalBench Results"
  description="Overall CapitalBench results for completed one-month market rounds only."
>
  <PageHeader
    eyebrow="One-month rounds"
    title="Overall Monthly Results"
    summary="Total model return compared with total oracle return across every resolved one-month round. Weekly rounds are scored separately."
  />
  {scorecard ? (
    <section class="section">
      <TrackScorecard scorecard={scorecard} />
    </section>
  ) : (
    <section class="section">
      <PendingLeaderboardGuide kind="official" />
    </section>
  )}
  <section class="section">
    <div class="panel">
      <div class="panel-header">
        <div>
          <span class="panel-kicker">Scope</span>
          <h2>What This Scorecard Includes</h2>
          <p>Average raw return, S&amp;P 500 context, and max-possible return context appear across the same resolved monthly rounds after monthly rounds resolve. Consistency checks stay separate.</p>
        </div>
        <a class="action-link" href="/leaderboards/cumulative-stability">Consistency results</a>
      </div>
    </div>
  </section>
</BaseLayout>
