---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import StatusCards from "../../components/StatusCards.astro";
import OfficialPicksTable from "../../components/OfficialPicksTable";
import LeaderboardTable from "../../components/LeaderboardTable";
import PendingLeaderboardGuide from "../../components/PendingLeaderboardGuide.astro";
import { latestLeaderboard, rounds as fallbackRounds } from "../../data/fallback";
import { staticOfficialSubmissions, staticRoundRecords, staticUniverseOptions } from "../../lib/localRoundRecords";
import { datasetSchema } from "../../lib/seo";

const roundRows = staticRoundRecords();
const currentRound = roundRows[0] ?? fallbackRounds[0];
const officialSubmissions = staticOfficialSubmissions(currentRound.round_id, currentRound.official_run_id);
const currentUniverseOptions = staticUniverseOptions(currentRound.round_id);
const initialNowIso = new Date().toISOString();
const officialPicksDataset = datasetSchema({
  name: `${currentRound.round_id} official LLM allocations`,
  description:
    "Pending official CapitalBench one-shot LLM market decisions for the latest round, including allocations, provider, model, confidence, rationale, and risks.",
  path: "/leaderboards/latest",
  datePublished: "2026-05-17",
  temporalCoverage: `${currentRound.entry_date}/${currentRound.exit_date}`,
  keywords: ["LLM market leaderboard", "AI market allocations", "one-shot benchmark", "CapitalBench"],
  variableMeasured: ["model id", "provider", "portfolio allocation", "confidence", "pending score status"]
});
---

<BaseLayout
  title="Latest LLM Market Leaderboard"
  description="Latest CapitalBench official leaderboard for one-shot LLM market decisions, with pending allocations shown before scored performance is published."
  structuredData={officialPicksDataset}
>
  <PageHeader
    eyebrow="Latest official result"
    title="Latest Round Leaderboard"
    summary={`${currentRound.round_id} is pending. Official allocations are visible now; realized performance appears only after exit prices are available.`}
  />

  <StatusCards
    roundId={currentRound.round_id}
    status={currentRound.status}
    decisionDeadline={currentRound.decision_deadline_utc}
    entryDate={currentRound.entry_date}
    exitDate={currentRound.exit_date}
    officialRunId={currentRound.official_run_id}
  />

  <section class="section" id="official-picks">
    <PendingLeaderboardGuide
      kind="latest"
      roundId={currentRound.round_id}
      exitDate={currentRound.exit_date}
      scoreEtaUtc={currentRound.score_eta_utc}
      scoreEtaSource={currentRound.score_eta_source}
      status={currentRound.status}
      initialNowIso={initialNowIso}
    />
  </section>

  <section class="section">
    <LeaderboardTable client:visible fallbackRows={latestLeaderboard} kind="latest" />
  </section>

  <section class="section">
    <div class="panel">
      <div class="panel-header">
        <div>
          <span class="panel-kicker">Pending official run</span>
          <h2>Official Allocations</h2>
          <p>These are public decisions, not scored performance.</p>
        </div>
      </div>
      <OfficialPicksTable
        client:visible
        fallbackRows={officialSubmissions}
        roundId={currentRound.round_id}
        runId={currentRound.official_run_id}
        options={currentUniverseOptions}
      />
    </div>
  </section>
</BaseLayout>
