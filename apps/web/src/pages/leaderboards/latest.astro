---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
---

<BaseLayout
  title="Latest CapitalBench Leaderboards"
  description="Latest CapitalBench leaderboards split by weekly and monthly benchmark tracks."
>
  <PageHeader
    eyebrow="Latest official results"
    title="Choose A Track"
    summary="Weekly and monthly CapitalBench rounds are reported separately. Latest leaderboards never mix horizons."
  />

  <section class="section">
    <div class="grid-3">
      <article class="feature">
        <h3><a href="/leaderboards/latest-weekly">Latest Weekly Leaderboard</a></h3>
        <p>Newest one-week official round, with pending allocations before performance is scored.</p>
      </article>
      <article class="feature">
        <h3><a href="/leaderboards/latest-monthly">Latest Monthly Leaderboard</a></h3>
        <p>Newest one-month official round, kept separate from weekly results.</p>
      </article>
    </div>
  </section>
</BaseLayout>
