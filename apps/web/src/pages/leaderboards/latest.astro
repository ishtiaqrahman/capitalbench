---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
---

<BaseLayout
  title="Latest CapitalBench Results"
  description="Latest CapitalBench results split into one-week and one-month market tests."
>
  <PageHeader
    eyebrow="Latest results"
    title="Choose A Test"
    summary="Weekly and monthly tests are separate because they measure different time periods."
  />

  <section class="section">
    <div class="grid-3">
      <article class="feature">
        <h3><a href="/leaderboards/latest-weekly">Weekly Results</a></h3>
        <p>The latest completed one-week scoreboard. Open weekly tests are labeled separately.</p>
      </article>
      <article class="feature">
        <h3><a href="/leaderboards/latest-monthly">Monthly Results</a></h3>
        <p>The latest completed one-month scoreboard, kept separate from weekly results.</p>
      </article>
    </div>
  </section>
</BaseLayout>
