---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
---

<BaseLayout
  title="Cumulative Official CapitalBench Leaderboards"
  description="Cumulative official CapitalBench leaderboards split by weekly and monthly benchmark tracks."
>
  <PageHeader
    eyebrow="Official one-shot results"
    title="Cumulative Official By Track"
    summary="Official cumulative results are reported separately for weekly and monthly rounds. There is no combined horizon score."
  />
  <section class="section">
    <div class="grid-3">
      <article class="feature">
        <h3><a href="/leaderboards/cumulative-weekly">Weekly Cumulative</a></h3>
        <p>Official and stability cumulative tables for one-week rounds only.</p>
      </article>
      <article class="feature">
        <h3><a href="/leaderboards/cumulative-monthly">Monthly Cumulative</a></h3>
        <p>Official and stability cumulative tables for one-month rounds only.</p>
      </article>
    </div>
  </section>
</BaseLayout>
