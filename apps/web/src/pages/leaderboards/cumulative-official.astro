---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
---

<BaseLayout
  title="Overall CapitalBench Results"
  description="Overall CapitalBench results split into weekly and monthly market tests."
>
  <PageHeader
    eyebrow="Overall results"
    title="Overall Results By Test Length"
    summary="Weekly and monthly results stay separate. Each track uses CapitalBench Score inside the latest comparable model cohort."
  />
  <section class="section">
    <div class="grid-3">
      <article class="feature">
        <h3><a href="/leaderboards/cumulative-weekly">Overall Weekly</a></h3>
        <p>Comparable one-week tests on the CapitalBench Score scale.</p>
      </article>
      <article class="feature">
        <h3><a href="/leaderboards/cumulative-monthly">Overall Monthly</a></h3>
        <p>Comparable one-month tests on the CapitalBench Score scale.</p>
      </article>
    </div>
  </section>
</BaseLayout>
