---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import StatusCards from "../../components/StatusCards.astro";
import OfficialPicksTable from "../../components/OfficialPicksTable";
import LeaderboardTable from "../../components/LeaderboardTable";
import PendingLeaderboardGuide from "../../components/PendingLeaderboardGuide.astro";
import { pct } from "../../lib/format";
import {
  staticOfficialSubmissions,
  staticRoundLeaderboard,
  staticRoundRecords,
  staticUniverseOptions
} from "../../lib/localRoundRecords";
import { latestPendingRoundForTrack, latestResolvedRoundForTrack, latestSlotForTrack } from "../../lib/tracks";
import { modelLabel, providerLabel } from "../../data/fallback";

const track = "monthly" as const;
const roundRows = staticRoundRecords();
const resultRound = latestResolvedRoundForTrack(roundRows, track);
const pendingRound = latestPendingRoundForTrack(roundRows, track);
const displayRound = resultRound ?? pendingRound;
const resultRows = resultRound ? staticRoundLeaderboard(resultRound.round_id, resultRound.official_run_id) : [];
const winner = resultRows[0];
const officialSubmissions = displayRound
  ? staticOfficialSubmissions(displayRound.round_id, displayRound.official_run_id)
  : [];
const currentUniverseOptions = displayRound ? staticUniverseOptions(displayRound.round_id) : [];
const initialNowIso = new Date().toISOString();
---

<BaseLayout
  title="Latest Monthly CapitalBench Results"
  description="Latest one-month CapitalBench results with model portfolios and market returns kept separate from weekly rounds."
>
  <PageHeader
    eyebrow="One-month round"
    title="Monthly Results"
    summary={resultRound
      ? `${resultRound.round_id} is the latest completed one-month round. Current live monthly rounds are shown separately.`
      : pendingRound
        ? "No monthly result has been published yet. The current monthly round is waiting for ending prices."
        : "No monthly CapitalBench round is published yet."}
  />

  {displayRound ? (
    <>
      {resultRound && winner ? (
        <>
          <section class="section" id="latest-result">
            <div class="result-hero result-hero-monthly">
              <div>
                <span class="panel-kicker">Latest published monthly result</span>
                <h2>{modelLabel(winner.model_id)} Won {resultRound.round_id}</h2>
                <p>
                  The completed result shows portfolio return, S&amp;P 500 comparison, and regret versus the maximum
                  possible return. Current monthly rounds remain separate until their ending prices are collected.
                </p>
              </div>
              <div class="result-metrics" aria-label="Latest monthly result summary">
                <article>
                  <span>Winner</span>
                  <strong>{modelLabel(winner.model_id)}</strong>
                  <em>{providerLabel(winner.provider)}</em>
                </article>
                <article>
                  <span>Portfolio</span>
                  <strong>{pct(winner.portfolio_return ?? winner.selected_asset_return)}</strong>
                  <em>{winner.selected_option_id} primary</em>
                </article>
                <article>
                  <span>S&amp;P 500</span>
                  <strong>{pct(winner.sp500_return)}</strong>
                  <em>same window</em>
                </article>
                <article>
                  <span>Portfolio Minus S&amp;P 500</span>
                  <strong>{pct(winner.alpha_vs_sp500)}</strong>
                  <em>difference</em>
                </article>
              </div>
            </div>
            {pendingRound && pendingRound.round_id !== resultRound.round_id && (
              <div class="pending-result-note">
                <strong>Newer monthly round is live:</strong>
                <span>{pendingRound.round_id} scores after the {pendingRound.exit_date} close.</span>
                <a href={`/rounds/${pendingRound.round_id}/`}>View current portfolios</a>
              </div>
            )}
          </section>
          <StatusCards
            roundId={displayRound.round_id}
            status={displayRound.status}
            decisionDeadline={displayRound.decision_deadline_utc}
            entryDate={displayRound.entry_date}
            exitDate={displayRound.exit_date}
            officialRunId={displayRound.official_run_id}
          />
        </>
      ) : (
        <>
          <StatusCards
            roundId={displayRound.round_id}
            status={displayRound.status}
            decisionDeadline={displayRound.decision_deadline_utc}
            entryDate={displayRound.entry_date}
            exitDate={displayRound.exit_date}
            officialRunId={displayRound.official_run_id}
          />
          <section class="section" id="official-picks">
            <PendingLeaderboardGuide
              kind="latest"
              roundId={displayRound.round_id}
              exitDate={displayRound.exit_date}
              scoreEtaUtc={displayRound.score_eta_utc}
              scoreEtaSource={displayRound.score_eta_source}
              status={displayRound.status}
              initialNowIso={initialNowIso}
            />
          </section>
        </>
      )}

      <section class="section">
        <div class="panel">
          <div class="panel-header">
            <div>
              <span class="panel-kicker">Official monthly leaderboard</span>
              <h2>{resultRound ? `${resultRound.round_id} Final Scores` : "No Monthly Score Yet"}</h2>
              <p>
                {resultRound
                  ? "Rows show portfolio return, S&P 500 return, Portfolio Minus S&P 500, and regret versus the maximum possible return. The table is monthly only."
                  : "The benchmark result appears after the first monthly round is scored."}
              </p>
            </div>
          </div>
          <LeaderboardTable client:visible fallbackRows={resultRows} kind="latest" slot={latestSlotForTrack(track)} />
        </div>
      </section>

      <section class="section">
        <div class="panel">
          <div class="panel-header">
            <div>
              <span class="panel-kicker">{displayRound.status === "resolved" ? "Scored monthly portfolios" : "Current monthly portfolios"}</span>
              <h2>{displayRound.round_id} Model Portfolios</h2>
              <p>
                {displayRound.status === "resolved"
                  ? "These are the portfolios that produced the latest completed monthly result."
                  : "These are the live monthly portfolios waiting for final prices."}
              </p>
            </div>
          </div>
          <OfficialPicksTable
            client:visible
            fallbackRows={officialSubmissions}
            roundId={displayRound.round_id}
            runId={displayRound.official_run_id}
            options={currentUniverseOptions}
          />
        </div>
      </section>
    </>
  ) : (
    <section class="section">
      <div class="pending-state">
        <strong>No monthly round yet.</strong>
        <span>The monthly results page will appear after the first monthly round is locked.</span>
      </div>
    </section>
  )}
</BaseLayout>
