---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import StatusCards from "../../components/StatusCards.astro";
import OfficialPicksTable from "../../components/OfficialPicksTable";
import LeaderboardTable from "../../components/LeaderboardTable";
import PendingLeaderboardGuide from "../../components/PendingLeaderboardGuide.astro";
import { latestLeaderboard } from "../../data/fallback";
import { staticOfficialSubmissions, staticRoundRecords, staticUniverseOptions } from "../../lib/localRoundRecords";
import { latestRoundForTrack, latestSlotForTrack } from "../../lib/tracks";

const track = "monthly" as const;
const roundRows = staticRoundRecords();
const currentRound = latestRoundForTrack(roundRows, track);
const officialSubmissions = currentRound
  ? staticOfficialSubmissions(currentRound.round_id, currentRound.official_run_id)
  : [];
const currentUniverseOptions = currentRound ? staticUniverseOptions(currentRound.round_id) : [];
const initialNowIso = new Date().toISOString();
---

<BaseLayout
  title="Latest Monthly CapitalBench Leaderboard"
  description="Latest one-month CapitalBench official leaderboard with monthly allocations and results kept separate from weekly rounds."
>
  <PageHeader
    eyebrow="Monthly track"
    title="Latest Monthly Leaderboard"
    summary={currentRound
      ? `${currentRound.round_id} is the latest monthly round. Official allocations and results are shown only for the monthly track.`
      : "No monthly CapitalBench round is published yet."}
  />

  {currentRound ? (
    <>
      <StatusCards
        roundId={currentRound.round_id}
        status={currentRound.status}
        decisionDeadline={currentRound.decision_deadline_utc}
        entryDate={currentRound.entry_date}
        exitDate={currentRound.exit_date}
        officialRunId={currentRound.official_run_id}
      />

      <section class="section" id="official-picks">
        <PendingLeaderboardGuide
          kind="latest"
          roundId={currentRound.round_id}
          exitDate={currentRound.exit_date}
          scoreEtaUtc={currentRound.score_eta_utc}
          scoreEtaSource={currentRound.score_eta_source}
          status={currentRound.status}
          initialNowIso={initialNowIso}
        />
      </section>

      <section class="section">
        <LeaderboardTable client:visible fallbackRows={latestLeaderboard} kind="latest" slot={latestSlotForTrack(track)} />
      </section>

      <section class="section">
        <div class="panel">
          <div class="panel-header">
            <div>
              <span class="panel-kicker">Monthly official run</span>
              <h2>Official Allocations</h2>
              <p>These are public monthly-track decisions, not weekly results.</p>
            </div>
          </div>
          <OfficialPicksTable
            client:visible
            fallbackRows={officialSubmissions}
            roundId={currentRound.round_id}
            runId={currentRound.official_run_id}
            options={currentUniverseOptions}
          />
        </div>
      </section>
    </>
  ) : (
    <section class="section">
      <div class="pending-state">
        <strong>No monthly round yet.</strong>
        <span>The monthly leaderboard will appear after the first monthly round is locked.</span>
      </div>
    </section>
  )}
</BaseLayout>
