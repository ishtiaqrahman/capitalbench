---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import PendingLeaderboardGuide from "../../components/PendingLeaderboardGuide.astro";
import TrackScorecard from "../../components/TrackScorecard.astro";
import { staticRoundRecords } from "../../lib/localRoundRecords";
import { buildTrackScorecard } from "../../lib/trackScorecard";

const scorecard = buildTrackScorecard(staticRoundRecords(), "weekly");
---

<BaseLayout
  title="All Available Weekly History | CapitalBench"
  description="All available weekly CapitalBench history for completed one-week market rounds."
>
  <PageHeader
    eyebrow="One-week rounds"
    title="All Available Weekly History"
    summary="Context across every resolved one-week round. Fair model-vs-model rankings use equal-run comparison sets."
  />
  {scorecard ? (
    <section class="section">
      <TrackScorecard scorecard={scorecard} />
    </section>
  ) : (
    <section class="section">
      <PendingLeaderboardGuide kind="official" />
    </section>
  )}
  <section class="section">
    <div class="panel">
      <div class="panel-header">
        <div>
          <span class="panel-kicker">Scope</span>
          <h2>What This Scorecard Includes</h2>
          <p>This all-history view can include unequal model histories. Use Benchmark Comparison Sets for the fair headline ranking where every model has the exact same included rounds.</p>
        </div>
        <a class="action-link" href="/leaderboards/benchmark-sets">Comparison sets</a>
      </div>
    </div>
  </section>
</BaseLayout>
