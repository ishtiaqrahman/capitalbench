---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import LeaderboardTable from "../../components/LeaderboardTable";
import PendingLeaderboardGuide from "../../components/PendingLeaderboardGuide.astro";
import { cumulativeOfficialLeaderboard, cumulativeStabilityLeaderboard } from "../../data/fallback";
import { cumulativeSlotForTrack } from "../../lib/tracks";

const slot = cumulativeSlotForTrack("weekly");
---

<BaseLayout
  title="Overall Weekly CapitalBench Results"
  description="Overall CapitalBench results for completed one-week market tests only."
>
  <PageHeader
    eyebrow="One-week tests"
    title="Overall Weekly Results"
    summary="Only completed one-week tests are included here. Monthly tests are scored separately."
  />
  <section class="section">
    <PendingLeaderboardGuide kind="official" />
  </section>
  <section class="section">
    <div class="panel">
      <div class="panel-header">
        <div>
          <span class="panel-kicker">Weekly public picks</span>
          <h2>Overall Results</h2>
        </div>
      </div>
      <LeaderboardTable client:visible fallbackRows={cumulativeOfficialLeaderboard} kind="official" slot={slot} />
    </div>
  </section>
  <section class="section">
    <div class="panel">
      <div class="panel-header">
        <div>
          <span class="panel-kicker">Weekly consistency</span>
          <h2>Consistency Tests</h2>
        </div>
      </div>
      <LeaderboardTable client:visible fallbackRows={cumulativeStabilityLeaderboard} kind="stability" slot={slot} />
    </div>
  </section>
</BaseLayout>
