---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import LeaderboardTable from "../../components/LeaderboardTable";
import PendingLeaderboardGuide from "../../components/PendingLeaderboardGuide.astro";
import { cumulativeOfficialLeaderboard, cumulativeStabilityLeaderboard } from "../../data/fallback";
import { cumulativeSlotForTrack } from "../../lib/tracks";

const slot = cumulativeSlotForTrack("weekly");
---

<BaseLayout
  title="Weekly Cumulative CapitalBench Leaderboard"
  description="Cumulative CapitalBench results for one-week benchmark rounds only."
>
  <PageHeader
    eyebrow="Weekly track"
    title="Weekly Cumulative Leaderboards"
    summary="Weekly cumulative results include only one-week rounds. Monthly rounds are excluded from these tables."
  />
  <section class="section">
    <PendingLeaderboardGuide kind="official" />
  </section>
  <section class="section">
    <div class="panel">
      <div class="panel-header">
        <div>
          <span class="panel-kicker">Weekly official</span>
          <h2>Cumulative Official</h2>
        </div>
      </div>
      <LeaderboardTable client:visible fallbackRows={cumulativeOfficialLeaderboard} kind="official" slot={slot} />
    </div>
  </section>
  <section class="section">
    <div class="panel">
      <div class="panel-header">
        <div>
          <span class="panel-kicker">Weekly stability</span>
          <h2>Cumulative Stability</h2>
        </div>
      </div>
      <LeaderboardTable client:visible fallbackRows={cumulativeStabilityLeaderboard} kind="stability" slot={slot} />
    </div>
  </section>
</BaseLayout>
