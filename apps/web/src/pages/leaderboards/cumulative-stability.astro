---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
---

<BaseLayout
  title="Cumulative Stability CapitalBench Leaderboards"
  description="Cumulative stability CapitalBench leaderboards split by weekly and monthly benchmark tracks."
>
  <PageHeader
    eyebrow="Repeated-call results"
    title="Cumulative Stability By Track"
    summary="Stability results are reported within each benchmark horizon and remain separate from official one-shot scoring."
  />
  <section class="section">
    <div class="grid-3">
      <article class="feature">
        <h3><a href="/leaderboards/cumulative-weekly">Weekly Cumulative</a></h3>
        <p>Stability and official cumulative tables for one-week rounds only.</p>
      </article>
      <article class="feature">
        <h3><a href="/leaderboards/cumulative-monthly">Monthly Cumulative</a></h3>
        <p>Stability and official cumulative tables for one-month rounds only.</p>
      </article>
    </div>
  </section>
</BaseLayout>
