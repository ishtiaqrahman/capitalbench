---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
---

<BaseLayout
  title="AI Model Consistency Results"
  description="CapitalBench consistency results for AI model portfolios across completed weekly and monthly tests."
>
  <PageHeader
    eyebrow="Consistency rounds"
    title="Consistency Results By Horizon"
    summary="These views show repeated-call consistency. They stay separate from the public one-portfolio benchmark results."
  />
  <section class="section">
    <div class="grid-3">
      <article class="feature">
        <h3><a href="/leaderboards/cumulative-weekly">Weekly Consistency</a></h3>
        <p>Repeated-call checks for one-week rounds only.</p>
      </article>
      <article class="feature">
        <h3><a href="/leaderboards/cumulative-monthly">Monthly Consistency</a></h3>
        <p>Repeated-call checks for one-month rounds only.</p>
      </article>
    </div>
  </section>
</BaseLayout>
