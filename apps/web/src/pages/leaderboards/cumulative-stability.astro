---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import LeaderboardTable from "../../components/LeaderboardTable";
import PendingLeaderboardGuide from "../../components/PendingLeaderboardGuide.astro";
import { cumulativeStabilityLeaderboard } from "../../data/fallback";
---

<BaseLayout
  title="Cumulative Stability Leaderboard"
  description="Repeated-run CapitalBench stability results for LLM market decisions, reported separately from official one-shot scores."
>
  <PageHeader
    eyebrow="Repeated-call track"
    title="Cumulative Stability"
    summary="Repeated-run alpha and consistency metrics across resolved rounds. Stability results are reported separately from official one-shot results."
  />
  <section class="section">
    <PendingLeaderboardGuide kind="stability" />
  </section>
  <section class="section">
    <LeaderboardTable client:visible fallbackRows={cumulativeStabilityLeaderboard} kind="stability" />
  </section>
</BaseLayout>
