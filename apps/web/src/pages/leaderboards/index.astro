---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BenchmarkEvidencePanel from "../../components/BenchmarkEvidencePanel.astro";
import GitHubLogo from "../../components/GitHubLogo.astro";
import InsightStrip from "../../components/InsightStrip.astro";
import ScoreReturnChart from "../../components/ScoreReturnChart.astro";
import TrackScorecard from "../../components/TrackScorecard.astro";
import apiReadModel from "../../generated/apiReadModel.js";
import {
  ArrowRight,
  BarChart3,
  CalendarDays,
  CheckCircle2,
  FileCheck2,
  Layers3,
  LineChart,
  LockKeyhole,
  Radio,
  Trophy
} from "lucide-react";
import {
  modelLabel,
  providerLabel,
  type LeaderboardRecord,
  type RoundRecord
} from "../../data/fallback";
import { dateOnly, pct } from "../../lib/format";
import {
  staticAllOfficialSubmissions,
  staticRoundAllocations,
  staticRoundLeaderboard,
  staticRoundRecords,
  staticRoundReturns,
  staticUniverseOptions
} from "../../lib/localRoundRecords";
import { buildScoreReturnChartData, providerLogoSrc } from "../../lib/scoreReturnChart";
import { benchmarkSetToScorecard, buildBenchmarkSetsData, featuredBenchmarkSet } from "../../lib/benchmarkSets";
import { topInsightsByCategory } from "../../lib/insights.js";
import { buildTrackScorecard, type TrackScorecardData } from "../../lib/trackScorecard";
import {
  latestPendingRoundForTrack,
  latestResolvedRoundForTrack,
  roundsForTrack,
  type BenchmarkTrack
} from "../../lib/tracks";
import { siteConfig } from "../../lib/seo";

type ResultsTrackState = {
  key: BenchmarkTrack;
  label: string;
  horizon: string;
  latestResultRound?: RoundRecord;
  pendingRound?: RoundRecord;
  scorecard: TrackScorecardData | null;
  leaderboard: LeaderboardRecord[];
  winner?: LeaderboardRecord;
  winnerReturn?: number;
  completedCount: number;
  totalCount: number;
  latestHref: string;
  cumulativeHref: string;
};

const roundRows = staticRoundRecords();
const benchmarkSets = buildBenchmarkSetsData(apiReadModel) as any;
const weeklyScorecard = benchmarkSetToScorecard(featuredBenchmarkSet(apiReadModel, "weekly")) as TrackScorecardData | null;
const monthlyScorecard = benchmarkSetToScorecard(featuredBenchmarkSet(apiReadModel, "monthly")) as TrackScorecardData | null;
const weeklyAllHistoryScorecard = buildTrackScorecard(roundRows, "weekly");
const monthlyAllHistoryScorecard = buildTrackScorecard(roundRows, "monthly");
const allHistoryScorecards = {
  weekly: weeklyAllHistoryScorecard,
  monthly: monthlyAllHistoryScorecard
};
const scorecards = [weeklyScorecard, monthlyScorecard].filter(
  (scorecard): scorecard is TrackScorecardData => scorecard !== null
);
const allSubmissions = staticAllOfficialSubmissions(roundRows);
const modelCount = new Set(allSubmissions.map((submission) => submission.model_id)).size;
const completedRoundCount = roundRows.filter((round) => round.status === "resolved").length;

function leaderboardReturn(row: LeaderboardRecord | undefined): number | undefined {
  return row ? row.portfolio_return ?? row.selected_asset_return : undefined;
}

function buildTrackState(
  key: BenchmarkTrack,
  label: string,
  horizon: string,
  scorecard: TrackScorecardData | null
): ResultsTrackState {
  const latestResultRound = latestResolvedRoundForTrack(roundRows, key);
  const pendingRound = latestPendingRoundForTrack(roundRows, key);
  const leaderboard = latestResultRound
    ? staticRoundLeaderboard(latestResultRound.round_id, latestResultRound.official_run_id)
    : [];
  const winner = leaderboard[0];
  const trackRounds = roundsForTrack(roundRows, key);
  return {
    key,
    label,
    horizon,
    latestResultRound,
    pendingRound,
    scorecard,
    leaderboard,
    winner,
    winnerReturn: leaderboardReturn(winner),
    completedCount: scorecard?.comparisonRoundCount ?? trackRounds.filter((round) => round.status === "resolved").length,
    totalCount: trackRounds.length,
    latestHref: `/leaderboards/latest-${key}`,
    cumulativeHref: `/leaderboards/cumulative-${key}`
  };
}

const trackStates = [
  buildTrackState("weekly", "Weekly", "One market week", weeklyScorecard),
  buildTrackState("monthly", "Monthly", "One market month", monthlyScorecard)
];

const latestPublishedResult = trackStates
  .filter((track) => track.latestResultRound && track.winner)
  .sort((left, right) => (right.latestResultRound?.exit_date ?? "").localeCompare(left.latestResultRound?.exit_date ?? ""))[0];

const latestResultRound = latestPublishedResult?.latestResultRound;
const latestResultOptions = latestResultRound ? staticUniverseOptions(latestResultRound.round_id) : [];
const latestResultOptionsById = Object.fromEntries(latestResultOptions.map((option) => [option.option_id, option]));
const latestResultReturns = latestResultRound
  ? staticRoundReturns(latestResultRound.round_id, latestResultRound.official_run_id)
  : [];
const latestResultAllocations = latestResultRound
  ? staticRoundAllocations(latestResultRound.round_id, latestResultRound.official_run_id)
  : [];
const latestScoreChart = buildScoreReturnChartData({
  leaderboard: latestPublishedResult?.leaderboard ?? [],
  returns: latestResultReturns,
  optionsById: latestResultOptionsById,
  allocations: latestResultAllocations
});
const liveTracks = trackStates.filter((track) => track.pendingRound);
const currentLiveTestCount = roundRows.filter((round) => round.status === "pending").length;
const weeklyTrack = trackStates.find((track) => track.key === "weekly") ?? trackStates[0];
const weeklyLeaderLogoSrc = trackLeaderLogo(weeklyTrack);
const currentUniverseRound = [...roundRows].sort((left, right) => right.decision_deadline_utc.localeCompare(left.decision_deadline_utc))[0];
const currentUniverseOptionCount = currentUniverseRound
  ? staticUniverseOptions(currentUniverseRound.round_id).length
  : latestResultOptions.length;
const latestScoredRoundLabel = latestResultRound?.round_id ?? "Pending";
const liveRoundLabel = liveTracks
  .map((track) => track.pendingRound?.round_id)
  .filter(Boolean)
  .join(" / ") || "None";
const resultsHubInsights = topInsightsByCategory(
  apiReadModel,
  ["consensus_performance", "oracle_comparison", "benchmark_difficulty", "confidence_calibration"],
  3
);

function trackStateLabel(track: ResultsTrackState): string {
  if (track.scorecard) return `${track.completedCount} scored`;
  if (track.pendingRound) return "Waiting for first score";
  return "Not started";
}

function trackWindowLabel(round?: RoundRecord): string {
  if (!round) return "No window yet";
  return `${dateOnly(round.entry_date)} to ${dateOnly(round.exit_date)}`;
}

function scoreEtaLine(round?: RoundRecord): string {
  if (!round) return "No active round.";
  if (round.status === "resolved") return "Scores are published.";
  if (round.status === "overdue") return `Resolution is due; the ${dateOnly(round.exit_date)} close has passed.`;
  return `Scores after the ${dateOnly(round.exit_date)} close.`;
}

function scoreValue(track: ResultsTrackState): string {
  const value = track.scorecard?.topNormalizedRow?.averageScore;
  return typeof value === "number" && Number.isFinite(value) ? value.toFixed(1) : "n/a";
}

function averageReturnValue(track: ResultsTrackState): string {
  return pct(track.scorecard?.topAverageRow?.averageReturn) || "n/a";
}

function trackLeaderName(track: ResultsTrackState): string {
  if (track.scorecard?.topNormalizedRow?.label) return track.scorecard.topNormalizedRow.label;
  if (track.winner) return modelLabel(track.winner.model_id);
  return "Awaiting score";
}

function trackLeaderProvider(track: ResultsTrackState): string {
  return track.scorecard?.topNormalizedRow?.providerLabel ?? (track.winner ? providerLabel(track.winner.provider) : track.label);
}

function trackLeaderLogo(track: ResultsTrackState): string | undefined {
  return track.scorecard?.topNormalizedRow?.logoSrc ?? (track.winner ? providerLogoSrc(track.winner.provider) : undefined);
}

function routeDescription(track: ResultsTrackState, kind: "latest" | "overall"): string {
  if (kind === "latest") {
    if (track.latestResultRound) return `${track.latestResultRound.round_id}, ${trackWindowLabel(track.latestResultRound)}`;
    if (track.pendingRound) return `${track.pendingRound.round_id} is live. ${scoreEtaLine(track.pendingRound)}`;
    return "No published round yet.";
  }
  if (track.scorecard) {
    const allHistory = allHistoryScorecards[track.key];
    const count = allHistory?.comparisonRoundCount ?? track.scorecard.comparisonRoundCount;
    return `${count} all-available ${track.label.toLowerCase()} round${count === 1 ? "" : "s"} for context. Fair rankings use comparison sets.`;
  }
  return track.pendingRound ? "Overall chart appears after the first scored round." : "No completed rounds yet.";
}

const routeCards = trackStates.flatMap((track) => [
  {
    href: track.latestHref,
    kicker: `${track.label} result`,
    title: `Latest ${track.label}`,
    state: track.latestResultRound ? "Scored" : "Pending",
    description: routeDescription(track, "latest"),
    icon: BarChart3,
    className: `results-route-${track.key}`
  },
  {
    href: track.cumulativeHref,
    kicker: `${track.label} aggregate`,
    title: `Overall ${track.label}`,
    state: track.scorecard ? `${track.completedCount} rounds` : "Not ready",
    description: routeDescription(track, "overall"),
    icon: LineChart,
    className: `results-route-${track.key}`
  }
]);

const proofLinks = [
  {
    href: "/rounds",
    label: "Round index",
    description: `${roundRows.length} public rounds with dates, prices, and audit packets.`,
    icon: Layers3
  },
  {
    href: "/scoring",
    label: "Scoring rules",
    description: "How model portfolios are compared with market returns.",
    icon: LockKeyhole
  },
  {
    href: "/api",
    label: "API docs",
    description: "Published data endpoints for results, rounds, models, and exposures.",
    icon: FileCheck2
  }
];
---

<BaseLayout
  title="CapitalBench Results"
  description="CapitalBench benchmark results show weekly and monthly AI model portfolio scores, latest winners, live rounds, and public audit packets."
>
  <section class="results-hub-hero" aria-labelledby="results-hub-title">
    <div class="results-hub-copy">
      <p class="eyebrow">Results</p>
      <h1 id="results-hub-title">Benchmark Results</h1>
      <p>
        AI model portfolios are scored in separate weekly and monthly tracks using the same rules, frozen portfolios, and real
        public-market prices.
      </p>
      <div class="results-hub-actions" aria-label="Primary result pages">
        <a class="action-link action-primary" href="/leaderboards/latest-weekly">
          Latest weekly
          <ArrowRight size={15} aria-hidden="true" />
        </a>
        <a class="action-link" href="/leaderboards/benchmark-sets">Comparison sets</a>
        <a class="action-link" href="/leaderboards/cumulative-weekly">All weekly history</a>
        <a class="action-link" href="#combined-results">Combined results</a>
        <a class="action-link" href="#proof-data">Audit and data</a>
      </div>
    </div>

    <div class="results-hub-metrics" aria-label="Benchmark result status">
      <div class="results-status-main">
        <span class="panel-kicker">Benchmark status</span>
        <div class="results-status-counts" aria-label="Completed and live rounds">
          <span>
            <strong>{completedRoundCount}</strong>
            <em>completed</em>
          </span>
          <span class="results-status-live-count">
            <i aria-hidden="true"></i>
            <strong>{currentLiveTestCount}</strong>
            <em>live</em>
          </span>
        </div>
        <p>Weekly and monthly tracks are scored separately.</p>
      </div>

      <div class="results-status-leader">
        <span class="metric-label">Current weekly benchmark leader</span>
        <div class="results-status-leader-row">
          {weeklyLeaderLogoSrc ? (
            <span class="results-track-logo">
              <img src={weeklyLeaderLogoSrc} alt={trackLeaderProvider(weeklyTrack)} width="48" height="48" loading="eager" />
            </span>
          ) : (
            <span class="results-track-logo results-track-logo-empty">W</span>
          )}
          <div>
            <strong>{trackLeaderName(weeklyTrack)}</strong>
            <span>{scoreValue(weeklyTrack)} CapitalBench Score</span>
          </div>
        </div>
      </div>

      <div class="results-status-facts" aria-label="Benchmark facts">
        <span>
          <em>Latest scored</em>
          <strong>{latestScoredRoundLabel}</strong>
        </span>
        <span>
          <em>Latest live</em>
          <strong>{liveRoundLabel}</strong>
        </span>
        <span>
          <em>Models</em>
          <strong>{modelCount}</strong>
        </span>
        <span>
          <em>Universe</em>
          <strong>{currentUniverseOptionCount} options</strong>
        </span>
      </div>

      <ol class="results-status-flow" aria-label="Benchmark scoring flow">
        <li>
          <CheckCircle2 size={15} aria-hidden="true" />
          <span>Completed</span>
        </li>
        <li>
          <Radio size={15} aria-hidden="true" />
          <span>Live</span>
        </li>
        <li>
          <Trophy size={15} aria-hidden="true" />
          <span>Scored</span>
        </li>
      </ol>

      <div class="results-status-actions" aria-label="Benchmark status links">
        <a class="small-button" href={weeklyTrack.latestHref}>Latest weekly result</a>
        <a class="small-button" href="/leaderboards/benchmark-sets">Comparison sets</a>
        <a class="small-button" href="/rounds">All rounds</a>
      </div>
    </div>
  </section>

  <InsightStrip
    id="results-insights"
    kicker="Results insights"
    title="How To Read The Latest Benchmark Results"
    description="Signals generated from scored rounds, oracle comparisons, benchmark difficulty, and model confidence behavior."
    insights={resultsHubInsights}
    viewAllHref="/insights"
    viewAllLabel="All insights"
  />

  <section class="results-track-leaders" aria-label="Current track leaders">
    {trackStates.map((track) => {
      const logoSrc = trackLeaderLogo(track);
      return (
        <article class={`results-track-card results-track-card-${track.key}`}>
          <div class="results-track-card-head">
            <div>
              <span class="panel-kicker">{track.label} track</span>
              <h2>{track.scorecard ? `${trackLeaderName(track)} Leads` : `${track.label} Track`}</h2>
              <p>{track.scorecard ? "CapitalBench Score leader inside the featured equal-run comparison set." : "Waiting for enough shared rounds."}</p>
            </div>
            <span class={`status-badge ${track.scorecard ? "status-resolved" : "status-pending"}`}>{trackStateLabel(track)}</span>
          </div>

          <div class="results-track-leader-row">
            {logoSrc ? (
              <span class="results-track-logo">
                <img src={logoSrc} alt={trackLeaderProvider(track)} width="48" height="48" loading="eager" />
              </span>
            ) : (
              <span class="results-track-logo results-track-logo-empty">{track.label.slice(0, 1)}</span>
            )}
            <div>
              <strong>{trackLeaderName(track)}</strong>
              <span>{trackLeaderProvider(track)}</span>
            </div>
          </div>

          <div class="results-track-stat-grid" aria-label={`${track.label} summary`}>
            <span>
              <small>CapitalBench Score</small>
              <strong>{scoreValue(track)}</strong>
            </span>
            <span>
              <small>Avg return leader</small>
              <strong>{averageReturnValue(track)}</strong>
            </span>
            <span>
              <small>Shared rounds</small>
              <strong>{track.scorecard?.comparisonRoundCount ?? 0}</strong>
            </span>
            <span>
              <small>Timeline</small>
              <strong>{track.horizon}</strong>
            </span>
          </div>

          <div class="track-card-actions">
            <a class="small-button" href={track.latestHref}>Latest result</a>
            <a class="small-button" href="/leaderboards/benchmark-sets">Comparison sets</a>
            <a class="small-button" href={track.cumulativeHref}>All history</a>
            {track.latestResultRound && <a class="small-button" href={`/rounds/${track.latestResultRound.round_id}/`}>Audit packet</a>}
          </div>
        </article>
      );
    })}
  </section>

  {scorecards.length > 0 && (
    <>
      <section class="home-section-heading home-section-heading-with-action" id="combined-results" aria-labelledby="combined-results-title">
        <div>
          <span class="panel-kicker">Completed results</span>
          <h2 id="combined-results-title">Current Benchmark Scores</h2>
          <p>
            These are equal-run comparison sets. Every ranked model completed every included round, and missed rounds are excluded
            from the set for everyone.
          </p>
        </div>
        <a class="section-profile-link" href="/leaderboards/benchmark-sets">Open comparison sets</a>
      </section>

      <div class="track-scorecard-stack results-scorecard-stack" aria-label="Combined completed result charts">
        {scorecards.map((scorecard) => <TrackScorecard scorecard={scorecard} />)}
      </div>

      <BenchmarkEvidencePanel
        evidence={apiReadModel.benchmark_evidence}
        tracks={["weekly", "monthly"]}
        title="Evidence Behind The Current Benchmarks"
      />
    </>
  )}

  <section class="home-section-heading home-section-heading-with-action" aria-labelledby="benchmark-sets-title">
    <div>
      <span class="panel-kicker">Fair model comparisons</span>
      <h2 id="benchmark-sets-title">Benchmark Comparison Sets</h2>
      <p>
        Sets are living groups. Older sets keep adding shared rounds, while newer model rosters become current automatically
        after enough shared results.
      </p>
    </div>
    <a class="section-profile-link" href="/leaderboards/benchmark-sets">View all sets</a>
  </section>

  <section class="results-route-grid" aria-label="Benchmark comparison sets">
    {benchmarkSets.sets.map((set: any) => (
      <a class={`results-route-card results-route-${set.track}`} href={`/leaderboards/benchmark-sets/${set.set_id}/`}>
        <span class="results-route-icon" aria-hidden="true"><Layers3 size={18} /></span>
        <span class="panel-kicker">{set.is_current ? "Current benchmark" : set.is_qualified ? "Qualified set" : "Forming set"}</span>
        <strong>{set.label}</strong>
        <p>{set.comparison.comparison_round_count} shared resolved rounds across {set.models.length} models.</p>
        <em>{set.is_qualified ? `Qualified at ${set.qualification_threshold}+ shared rounds` : `${Math.max(0, set.qualification_threshold - set.comparison.comparison_round_count)} more shared rounds to qualify`}</em>
      </a>
    ))}
  </section>

  {latestPublishedResult && latestResultRound && latestScoreChart.rows.length > 0 && (
    <>
      <section class="home-section-heading" aria-labelledby="latest-scored-result-title">
        <span class="panel-kicker">Latest scored round</span>
        <h2 id="latest-scored-result-title">Most Recent Published Result</h2>
        <p>
          This chart shows the newest completed round only. Live rounds stay out of this chart until ending prices are
          collected.
        </p>
      </section>

      <section class="published-score-panel results-latest-score-panel" aria-label="Most recent scored round chart">
        <ScoreReturnChart
          chart={latestScoreChart}
          label={`${latestPublishedResult.label} result`}
          title={`${latestPublishedResult.label} Portfolio Returns`}
          description="Models, S&P 500, and maximum possible return are shown on one scale."
        />

        <div class="published-score-summary published-score-run-details">
          <div class="published-score-summary-head">
            <div class="published-result-head">
              <div>
                <span class="panel-kicker">Run details</span>
                <h3>{latestResultRound.round_id}</h3>
                <p>{trackWindowLabel(latestResultRound)}</p>
              </div>
            </div>
            <div class="track-card-actions">
              <a class="small-button" href={`/rounds/${latestResultRound.round_id}/`}>Full result</a>
              <a class="small-button" href={latestPublishedResult.latestHref}>Benchmark results</a>
            </div>
          </div>

          <div class="published-score-context" aria-label="Latest result context">
            <span><strong>Winner</strong>{latestPublishedResult.winner ? modelLabel(latestPublishedResult.winner.model_id) : "n/a"}</span>
            <span><strong>Return</strong>{pct(latestPublishedResult.winnerReturn) || "n/a"}</span>
            <span><strong>Models</strong>{latestPublishedResult.leaderboard.length}</span>
            <span><strong>Eligible assets</strong>{latestResultOptions.length}</span>
          </div>
        </div>
      </section>
    </>
  )}

  <section class="home-section-heading home-section-heading-with-action" aria-labelledby="results-routes-title">
    <div>
      <span class="panel-kicker">Benchmark result paths</span>
      <h2 id="results-routes-title">Choose The Result View</h2>
      <p>Latest pages show one completed round. All-history pages are context. Comparison sets are the fair ranking view.</p>
    </div>
    <a class="section-profile-link" href="/rounds">All rounds</a>
  </section>

  <section class="results-route-grid" aria-label="Leaderboard pages">
    {routeCards.map((card) => {
      const Icon = card.icon;
      return (
        <a class={`results-route-card ${card.className}`} href={card.href}>
          <span class="results-route-icon" aria-hidden="true"><Icon size={18} /></span>
          <span class="panel-kicker">{card.kicker}</span>
          <strong>{card.title}</strong>
          <p>{card.description}</p>
          <em>{card.state}</em>
        </a>
      );
    })}
  </section>

  {liveTracks.length > 0 && (
    <>
      <section class="home-section-heading" aria-labelledby="live-tests-title">
        <span class="panel-kicker">Live rounds</span>
        <h2 id="live-tests-title">Waiting For Final Prices</h2>
        <p>These rounds are live or pending score. They are not counted in completed result charts yet.</p>
      </section>

      <section class="results-live-grid" aria-label="Live rounds waiting for scoring">
        {liveTracks.map((track) => (
          <article class={`results-live-card results-live-card-${track.key}`}>
            <div>
              <span class="panel-kicker">{track.label} live round</span>
              <h3>{track.pendingRound?.round_id}</h3>
              <p>{scoreEtaLine(track.pendingRound)}</p>
            </div>
            <div class="results-live-meta">
              <span>
                <CalendarDays size={15} aria-hidden="true" />
                {trackWindowLabel(track.pendingRound)}
              </span>
              <span>{track.pendingRound?.official_run_id}</span>
            </div>
            <a class="small-button" href={track.pendingRound ? `/rounds/${track.pendingRound.round_id}/` : "/rounds"}>
              View locked portfolios
            </a>
          </article>
        ))}
      </section>
    </>
  )}

  <section class="results-proof-panel" id="proof-data" aria-labelledby="results-proof-title">
    <div>
      <span class="panel-kicker">Audit and data</span>
      <h2 id="results-proof-title">Every Result Has An Audit Packet</h2>
      <p>
        Results link back to prompts, model outputs, portfolio decisions, prices, audit hashes, and scoring records.
      </p>
    </div>

    <div class="results-proof-links">
      {proofLinks.map((link) => {
        const Icon = link.icon;
        return (
          <a href={link.href}>
            <span aria-hidden="true"><Icon size={17} /></span>
            <strong>{link.label}</strong>
            <em>{link.description}</em>
          </a>
        );
      })}
      <a href={siteConfig.githubUrl} target="_blank" rel="noreferrer">
        <span aria-hidden="true"><GitHubLogo size={17} /></span>
        <strong>GitHub repository</strong>
        <em>Source files, generated reports, and public benchmark artifacts.</em>
      </a>
    </div>
  </section>
</BaseLayout>
