---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
---

<BaseLayout
  title="CapitalBench Leaderboards"
  description="CapitalBench leaderboard hub for latest official results, cumulative one-shot scores, and repeated-run stability metrics."
>
  <PageHeader
    eyebrow="Leaderboards"
    title="Benchmark Result Views"
    summary="CapitalBench separates weekly and monthly tracks. Latest, cumulative official, and stability results are reported within each horizon."
  />

  <section class="section">
    <div class="grid-3">
      <article class="feature">
        <h3><a href="/leaderboards/latest-weekly">Latest Weekly</a></h3>
        <p>Newest one-week official leaderboard. Pending rounds show allocations before performance.</p>
      </article>
      <article class="feature">
        <h3><a href="/leaderboards/latest-monthly">Latest Monthly</a></h3>
        <p>Newest one-month official leaderboard, separate from weekly results.</p>
      </article>
      <article class="feature">
        <h3><a href="/leaderboards/cumulative-weekly">Weekly Cumulative</a></h3>
        <p>Official and stability cumulative tables for weekly rounds only.</p>
      </article>
      <article class="feature">
        <h3><a href="/leaderboards/cumulative-monthly">Monthly Cumulative</a></h3>
        <p>Official and stability cumulative tables for monthly rounds only.</p>
      </article>
    </div>
  </section>
</BaseLayout>
