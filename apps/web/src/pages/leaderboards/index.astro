---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
---

<BaseLayout
  title="CapitalBench Results"
  description="CapitalBench results show which AI model portfolios are winning in weekly and monthly market tests."
>
  <PageHeader
    eyebrow="Results"
    title="Scoreboards"
    summary="See which AI model portfolios are winning. Weekly and monthly tests are scored separately."
  />

  <section class="section">
    <div class="grid-3">
      <article class="feature">
        <h3><a href="/leaderboards/latest-weekly">Weekly Results</a></h3>
        <p>The newest one-week test. If scores are pending, the model portfolios are shown first.</p>
      </article>
      <article class="feature">
        <h3><a href="/leaderboards/latest-monthly">Monthly Results</a></h3>
        <p>The newest one-month test, scored separately from weekly tests.</p>
      </article>
      <article class="feature">
        <h3><a href="/leaderboards/cumulative-weekly">Overall Weekly</a></h3>
        <p>All completed one-week tests summarized in one place.</p>
      </article>
      <article class="feature">
        <h3><a href="/leaderboards/cumulative-monthly">Overall Monthly</a></h3>
        <p>All completed one-month tests summarized in one place.</p>
      </article>
    </div>
  </section>
</BaseLayout>
