---
import BaseLayout from "../layouts/BaseLayout.astro";
import GitHubLogo from "../components/GitHubLogo.astro";
import LeaderboardTable from "../components/LeaderboardTable";
import OfficialPicksTable from "../components/OfficialPicksTable";
import {
  ArrowRight,
  BarChart3,
  Database,
  ExternalLink,
  FileCheck2,
  Layers3,
  ShieldCheck,
  TimerReset
} from "lucide-react";
import { auditHashes, latestLeaderboard, officialSubmissions, rounds, universeOptions } from "../data/fallback";
import { siteConfig } from "../lib/seo";

const currentRound = rounds[0];
const consensusPick = "SEMICONDUCTORS";
const consensusCount = officialSubmissions.filter((row) => row.selected_option_id === consensusPick).length;
const providerCount = new Set(officialSubmissions.map((row) => row.provider)).size;
const publishedArtifactCount = auditHashes.length + officialSubmissions.length + universeOptions.length;
const currentRoundUrl = `/rounds/${currentRound.round_id}/`;
const confidenceValues = officialSubmissions
  .map((row) => row.confidence)
  .filter((value): value is number => Number.isFinite(value));
const confidenceRange =
  confidenceValues.length > 0
    ? `${Math.min(...confidenceValues).toFixed(2)}-${Math.max(...confidenceValues).toFixed(2)}`
    : "not reported";
const heroMetrics = [
  { label: "Official models", value: `${officialSubmissions.length}/${providerCount}` },
  { label: "Frozen universe", value: `${universeOptions.length} assets` },
  { label: "Public hashes", value: String(auditHashes.length) },
  { label: "Score window", value: `Ends ${currentRound.exit_date}` }
];
const resultViews = [
  {
    href: "/leaderboards/latest",
    icon: BarChart3,
    label: "Latest Round",
    description: "The newest resolved official round. Pending rounds show locked decisions only.",
    state: "Pending"
  },
  {
    href: "/leaderboards/cumulative-official",
    icon: Layers3,
    label: "Cumulative Official",
    description: "Average official alpha across resolved rounds where each model participated.",
    state: "Official"
  },
  {
    href: "/leaderboards/cumulative-stability",
    icon: TimerReset,
    label: "Cumulative Stability",
    description: "Repeated-call alpha and consistency, kept separate from official results.",
    state: "Stability"
  }
];
const protocolHighlights = [
  {
    label: "Same packet",
    title: "Identical prompt and market context",
    description: "Every official model receives the same frozen briefing, option universe, dates, and response schema."
  },
  {
    label: "No hindsight",
    title: "Picks locked before outcomes",
    description: "Submissions are collected and published while the round is still unresolved."
  },
  {
    label: "Declared scoring",
    title: "Return and alpha after the exit date",
    description: "Scores are calculated only after exit prices are available for the full option universe."
  },
  {
    label: "Public audit",
    title: "Inputs, decisions, hashes, and reports",
    description: "Readers can inspect the round packet, model outputs, artifacts, and repository history."
  }
];
const audiences = [
  {
    title: "AI labs",
    description: "Compare model behavior on the same uncertainty-heavy decision task without private prompts or hidden judging."
  },
  {
    title: "Researchers",
    description: "Study reasoning, calibration, consensus, and brittleness using timestamped public artifacts."
  },
  {
    title: "Investors and analysts",
    description: "See how models translate market context into concrete allocations without treating outputs as advice."
  },
  {
    title: "Builders",
    description: "Use the protocol as a reference for auditable evaluation, repeat runs, and production monitoring."
  }
];
const safeguards = [
  {
    icon: ShieldCheck,
    label: "Run isolation",
    title: "One official call per model",
    description: "Official results are never mixed with repeated stability runs, mock output, or provider smoke tests."
  },
  {
    icon: Database,
    label: "Inspection",
    title: `${publishedArtifactCount} published records`,
    description: "Round metadata, options, submissions, and hashes are published as a readable public audit surface."
  },
  {
    icon: FileCheck2,
    label: "Score boundary",
    title: "No performance before resolution",
    description: "Pending rounds show decisions and artifacts, but realized alpha appears only after prices are collected."
  }
];
---

<BaseLayout
  title="CapitalBench - LLM Market Benchmark and Leaderboards"
  description="CapitalBench tests AI models on the same market prompt and frozen data, then publishes their picks, scores, and audit trail."
>
  <section class="home-hero" aria-labelledby="home-title">
    <div class="home-hero-copy">
      <p class="eyebrow">Auditable AI market benchmark</p>
      <h1 id="home-title">CapitalBench</h1>
      <p class="home-hero-lede">
        CapitalBench measures whether AI models can make disciplined market allocations from the same frozen
        information before outcomes are known. Every round publishes the prompt, model decisions, scores, and audit
        trail.
      </p>
    </div>

    <div class="home-hero-actions" aria-label="Project resources">
      <a class="action-link action-primary" href={currentRoundUrl}>
        View current round
        <ArrowRight size={15} aria-hidden="true" />
      </a>
      <a
        class="action-link"
        href="/methodology"
        data-analytics-event="methodology_click"
        data-analytics-param-location="home_hero"
      >
        Read methodology
      </a>
      <a
        class="action-link"
        href={siteConfig.githubUrl}
        target="_blank"
        rel="noreferrer"
        data-analytics-event="github_repository_click"
        data-analytics-param-location="home_hero"
      >
        <GitHubLogo size={17} />
        GitHub repository
        <ExternalLink size={14} aria-hidden="true" />
      </a>
    </div>

    <div class="home-hero-console" aria-label="Current benchmark state">
      <div class="console-header">
        <div class="console-title">
          <img src="/benchmark-panel.svg" alt="" width="42" height="42" loading="eager" />
          <div>
            <span>Current Public Round</span>
            <strong>{currentRound.round_id}</strong>
          </div>
        </div>
        <span class="status-badge status-pending">Score pending</span>
      </div>

      <div class="console-metrics">
        {heroMetrics.map((metric) => (
          <div>
            <span>{metric.label}</span>
            <strong>{metric.value}</strong>
          </div>
        ))}
      </div>

      <div class="console-ledger" aria-label="Round 1 evidence ledger">
        <div>
          <span>Locked decision state</span>
          <strong>{consensusCount} of {officialSubmissions.length} models selected {consensusPick}</strong>
        </div>
        <div>
          <span>Observation window</span>
          <strong>Scores publish after {currentRound.exit_date} exit prices are collected</strong>
        </div>
        <div>
          <span>Scoring basis</span>
          <strong>Realized return and alpha versus S&amp;P 500 and cash baselines</strong>
        </div>
      </div>
    </div>
  </section>

  <section class="trust-strip" aria-label="Benchmark protocol snapshot">
    {protocolHighlights.map((item) => (
      <article>
        <span>{item.label}</span>
        <strong>{item.title}</strong>
        <p>{item.description}</p>
      </article>
    ))}
  </section>

  <section class="phase-band" aria-labelledby="round-progress-title">
    <div class="phase-intro">
      <span class="panel-kicker">Round 1 lifecycle</span>
      <h2 id="round-progress-title">A Clear Line Between Decisions And Performance</h2>
      <p>
        Round 1 is in its observation window. Picks and entry prices are public now; realized returns stay absent until
        the pre-declared exit date resolves.
      </p>
    </div>
    <ol class="phase-list">
      <li class="phase-complete">
        <span>1</span>
        <strong>Inputs frozen</strong>
        <p>Briefing, prompt, universe, and market context hashed before model calls.</p>
      </li>
      <li class="phase-complete">
        <span>2</span>
        <strong>Submissions collected</strong>
        <p>{officialSubmissions.length} valid official one-shot picks are published.</p>
      </li>
      <li class="phase-complete">
        <span>3</span>
        <strong>Entry prices published</strong>
        <p>Entry side is visible for selected options, S&amp;P 500, and cash.</p>
      </li>
      <li class="phase-current">
        <span>4</span>
        <strong>Exit prices pending</strong>
        <p>Performance unlocks after {currentRound.exit_date} prices are collected and scored.</p>
      </li>
    </ol>
  </section>

  <section class="home-section-heading" aria-labelledby="audience-title">
    <span class="panel-kicker">Who it is for</span>
    <h2 id="audience-title">A Benchmark For Decisions Under Uncertainty</h2>
    <p>
      CapitalBench is designed for readers who need more than a demo answer: they need comparable behavior, a timestamp,
      and enough public evidence to audit what each model saw and selected.
    </p>
  </section>

  <section class="rule-matrix home-audience" aria-label="Who uses CapitalBench">
    {audiences.map((item) => (
      <article>
        <h3>{item.title}</h3>
        <p>{item.description}</p>
      </article>
    ))}
  </section>

  <section class="home-section-heading" aria-labelledby="safeguards-title">
    <span class="panel-kicker">Benchmark safeguards</span>
    <h2 id="safeguards-title">Built To Be Hard To Game</h2>
    <p>
      The trust model is deliberately simple: fixed inputs, isolated official runs, public hashes, and no provisional
      performance claims.
    </p>
  </section>

  <section class="evidence-grid enhanced" aria-label="Benchmark safeguards">
    {safeguards.map((item) => {
      const Icon = item.icon;
      return (
        <article>
          <div class="evidence-icon" aria-hidden="true">
            <Icon size={19} />
          </div>
          <span class="metric-label">{item.label}</span>
          <h3>{item.title}</h3>
          <p>{item.description}</p>
        </article>
      );
    })}
  </section>

  <nav class="view-switcher enhanced" aria-label="Primary result views">
    {resultViews.map((view) => {
      const Icon = view.icon;
      return (
        <a href={view.href}>
          <span class="view-icon" aria-hidden="true"><Icon size={18} /></span>
          <span class="view-copy">
            <strong>{view.label}</strong>
            <span>{view.description}</span>
          </span>
          <span class="view-state">{view.state}</span>
        </a>
      );
    })}
  </nav>

  <section class="dashboard-grid">
    <div class="panel">
      <div class="panel-header">
        <div>
          <span class="panel-kicker">Current round</span>
          <h2>Official Picks</h2>
          <p>
            Round 1 produced full consensus: all {officialSubmissions.length} official models selected Semiconductors,
            with confidence ranging from {confidenceRange}. The table shows decisions, rationales, and risks without
            presenting performance while the round is pending.
          </p>
        </div>
        <span class="status-badge status-pending">Pending score</span>
      </div>
      <OfficialPicksTable client:visible fallbackRows={officialSubmissions} roundId={currentRound.round_id} runId={currentRound.official_run_id} />
    </div>

    <aside class="rail" aria-label="Round audit summary">
      <div class="rail-panel highlight-panel">
        <span class="metric-label">Round 1 consensus</span>
        <h3>{consensusPick}</h3>
        <p>{consensusCount} of {officialSubmissions.length} official submissions selected Semiconductors.</p>
      </div>
      <div class="rail-panel">
        <span class="metric-label">Official protocol</span>
        <h3>{currentRound.methodology_version}</h3>
        <p>One call per model. No tools, browsing, or post-cutoff retrieval.</p>
      </div>
      <div class="rail-panel">
        <span class="metric-label">Audit trail</span>
        <h3>{auditHashes.length} hashed inputs</h3>
        <p>{universeOptions.length} frozen options with public hashes and validation metadata.</p>
      </div>
      <div class="rail-panel rail-checklist">
        <span class="metric-label">Reader path</span>
        <ul>
          <li><a href={currentRoundUrl}>Review the round packet</a></li>
          <li><a href="/universe">Inspect the frozen universe</a></li>
          <li><a href="/fairness">Read fairness controls</a></li>
        </ul>
      </div>
    </aside>
  </section>

  <section class="section resolution-section">
    <div class="panel">
      <div class="panel-header">
        <div>
          <span class="panel-kicker">Latest leaderboard</span>
          <h2>Resolution Pending</h2>
          <p>
            The official leaderboard appears here after exit prices are available and the selected run is scored. Until
            then, the benchmark publishes decisions without implying realized performance.
          </p>
        </div>
      </div>
      <LeaderboardTable client:visible fallbackRows={latestLeaderboard} kind="latest" />
    </div>
  </section>
</BaseLayout>
