---
import BaseLayout from "../layouts/BaseLayout.astro";
import GitHubLogo from "../components/GitHubLogo.astro";
import ScoreCountdown from "../components/ScoreCountdown";
import {
  ArrowRight,
  BarChart3,
  Database,
  ExternalLink,
  FileCheck2,
  Layers3,
  ShieldCheck,
  TimerReset
} from "lucide-react";
import {
  modelLabel,
  providerLabel,
  rounds as fallbackRounds,
  type RoundRecord,
  type SubmissionRecord,
  type UniverseOption
} from "../data/fallback";
import {
  allocationThemeClass,
  decisionAllocations,
  formatAllocationPct,
  optionDisplayName
} from "../lib/allocations";
import { dateOnly } from "../lib/format";
import {
  staticAllOfficialSubmissions,
  staticOfficialSubmissions,
  staticRoundRecords,
  staticUniverseOptions
} from "../lib/localRoundRecords";
import { siteConfig } from "../lib/seo";
import { latestRoundForTrack, roundsForTrack, type BenchmarkTrack } from "../lib/tracks";

type TrackHomeState = {
  key: BenchmarkTrack;
  label: string;
  horizonLabel: string;
  round?: RoundRecord;
  submissions: SubmissionRecord[];
  options: UniverseOption[];
  optionsById: Record<string, UniverseOption | undefined>;
  exposures: Array<{ optionId: string; averagePct: number }>;
  topExposure?: { optionId: string; averagePct: number };
  latestHref: string;
  cumulativeHref: string;
  roundHref?: string;
  roundCount: number;
};

const roundRows = staticRoundRecords();
const weeklyRounds = roundsForTrack(roundRows, "weekly");
const monthlyRounds = roundsForTrack(roundRows, "monthly");
const latestWeeklyRound = latestRoundForTrack(roundRows, "weekly");
const latestMonthlyRound = latestRoundForTrack(roundRows, "monthly");
const allOfficialSubmissions = staticAllOfficialSubmissions(roundRows);
const pendingRoundCount = roundRows.filter((round) => round.status === "pending").length;
const initialNowIso = new Date().toISOString();

function aggregateExposure(submissions: SubmissionRecord[]) {
  const totals = new Map<string, number>();
  for (const submission of submissions) {
    for (const allocation of decisionAllocations(submission)) {
      totals.set(allocation.option_id, (totals.get(allocation.option_id) ?? 0) + allocation.allocation_bps);
    }
  }
  return Array.from(totals.entries())
    .map(([optionId, totalBps]) => ({
      optionId,
      averagePct: submissions.length > 0 ? totalBps / submissions.length / 100 : 0
    }))
    .sort((a, b) => b.averagePct - a.averagePct);
}

function buildTrackState(
  key: BenchmarkTrack,
  label: string,
  horizonLabel: string,
  round: RoundRecord | undefined,
  roundCount: number
): TrackHomeState {
  const submissions = round ? staticOfficialSubmissions(round.round_id, round.official_run_id) : [];
  const options = round ? staticUniverseOptions(round.round_id) : [];
  const exposures = aggregateExposure(submissions).slice(0, 6);
  return {
    key,
    label,
    horizonLabel,
    round,
    submissions,
    options,
    optionsById: Object.fromEntries(options.map((option) => [option.option_id, option])),
    exposures,
    topExposure: exposures[0],
    latestHref: `/leaderboards/latest-${key}`,
    cumulativeHref: `/leaderboards/cumulative-${key}`,
    roundHref: round ? `/rounds/${round.round_id}/` : undefined,
    roundCount
  };
}

const trackStates = [
  buildTrackState("weekly", "Weekly", "One-week close-to-close", latestWeeklyRound, weeklyRounds.length),
  buildTrackState("monthly", "Monthly", "One-month close-to-close", latestMonthlyRound, monthlyRounds.length)
];
const latestUniverseOptionCount = Math.max(0, ...trackStates.map((track) => track.options.length));
const currentRound = latestMonthlyRound ?? latestWeeklyRound ?? roundRows[0] ?? fallbackRounds[0];
const heroMetrics = [
  { label: "Weekly rounds", value: String(weeklyRounds.length) },
  { label: "Monthly rounds", value: String(monthlyRounds.length) },
  { label: "Locked decisions", value: String(allOfficialSubmissions.length) },
  { label: "Latest universe", value: `${latestUniverseOptionCount || staticUniverseOptions(currentRound.round_id).length} assets` }
];
const exploreLinks = [
  {
    href: "/leaderboards/latest",
    icon: BarChart3,
    label: "Latest leaderboards",
    description: "Choose weekly or monthly latest results without mixing horizons.",
    state: "By track"
  },
  {
    href: "/rounds",
    icon: Layers3,
    label: "All rounds",
    description: "Round packets, prompts, model outputs, entry prices, hashes, and status history.",
    state: `${roundRows.length} rounds`
  },
  {
    href: "/methodology",
    icon: TimerReset,
    label: "Methodology",
    description: "Scoring rules, safeguards, data boundaries, and official-run separation.",
    state: "Audit"
  }
];
const protocolHighlights = [
  {
    label: "Separate tracks",
    title: "Weekly and monthly never combine",
    description: "Each horizon has its own latest view, cumulative table, round packet, and score window."
  },
  {
    label: "No hindsight",
    title: "Decisions publish before outcomes",
    description: "Allocations are public while exit prices and realized returns remain unavailable."
  },
  {
    label: "Same inputs",
    title: "Frozen prompt and market packet",
    description: "Every official model receives the same briefing, option universe, dates, and response schema."
  },
  {
    label: "Public audit",
    title: "Prompts, outputs, hashes public",
    description: "Readers can inspect model-facing inputs, validated outputs, price files, and run metadata."
  }
];
const safeguards = [
  {
    icon: ShieldCheck,
    label: "Run isolation",
    title: "One official call per model",
    description: "Official results are never mixed with repeated stability runs, mock output, or provider smoke tests."
  },
  {
    icon: Database,
    label: "Inspection",
    title: `${latestUniverseOptionCount} current options`,
    description: "Each track preserves the frozen model-facing universe, prompt, outputs, entry prices, and audit hashes."
  },
  {
    icon: FileCheck2,
    label: "Score boundary",
    title: `${pendingRoundCount} pending score windows`,
    description: "Realized alpha appears only after exit prices are collected and the scorer publishes official results."
  }
];

function statusLabel(round?: RoundRecord): string {
  if (!round) return "Not started";
  if (round.status === "resolved") return "Resolved";
  if (round.status === "archived") return "Archived";
  return "Pending score";
}

function statusClass(round?: RoundRecord): string {
  return round ? `status-${round.status}` : "status-archived";
}

function windowLabel(round?: RoundRecord): string {
  if (!round) return "Awaiting first round";
  return `${dateOnly(round.entry_date)} close to ${dateOnly(round.exit_date)} close`;
}

function scoreLine(round?: RoundRecord): string {
  if (!round) return "No score window declared yet.";
  if (round.status === "resolved") return "Official scores are published.";
  return `Scores publish after the ${dateOnly(round.exit_date)} exit close.`;
}

function topHoldings(submission: SubmissionRecord, optionsById: TrackHomeState["optionsById"]): string {
  const allocations = decisionAllocations(submission)
    .sort((a, b) => b.allocation_bps - a.allocation_bps)
    .slice(0, 2);
  if (allocations.length === 0) return "No allocation";
  return allocations
    .map((allocation) => `${optionDisplayName(allocation.option_id, optionsById)} ${formatAllocationPct(allocation.allocation_pct)}`)
    .join(" / ");
}
---

<BaseLayout
  title="CapitalBench - LLM Market Benchmark and Leaderboards"
  description="CapitalBench measures capital allocation ability across leading AI models using separate weekly and monthly public-market benchmark tracks."
>
  <section class="home-hero" aria-labelledby="home-title">
    <div class="home-hero-copy">
      <p class="eyebrow">Auditable AI market benchmark</p>
      <h1 id="home-title">CapitalBench</h1>
      <p class="home-hero-lede">
        CapitalBench measures how leading AI models allocate capital in real public markets. Weekly and monthly
        tracks are run separately: models receive identical frozen inputs, commit before outcomes are known, and are
        scored only after each declared exit close.
      </p>
      <p class="hero-disclaimer">Benchmark and research project. Not financial advice.</p>
    </div>

    <div class="home-hero-actions" aria-label="Project resources">
      <a class="action-link action-primary" href="/leaderboards/latest-weekly">
        Weekly track
        <ArrowRight size={15} aria-hidden="true" />
      </a>
      <a class="action-link" href="/leaderboards/latest-monthly">Monthly track</a>
      <a class="action-link" href="/rounds">All rounds</a>
      <a
        class="action-link"
        href={siteConfig.githubUrl}
        target="_blank"
        rel="noreferrer"
        data-analytics-event="github_repository_click"
        data-analytics-param-location="home_hero"
      >
        <GitHubLogo size={17} />
        GitHub repository
        <ExternalLink size={14} aria-hidden="true" />
      </a>
    </div>

    <div class="home-hero-console" aria-label="Current benchmark state">
      <div class="console-header">
        <div class="console-title">
          <img src="/benchmark-panel.svg" alt="" width="42" height="42" loading="eager" />
          <div>
            <span>Benchmark Tracks</span>
            <strong>Weekly and Monthly</strong>
          </div>
        </div>
        <span class="status-badge status-pending">Separated</span>
      </div>

      <div class="console-track-list">
        {trackStates.map((track) => (
          <div class="console-track-row">
            <div>
              <span>{track.label} latest</span>
              <strong>{track.round?.round_id ?? "Not started"}</strong>
              <p>{track.round ? `${windowLabel(track.round)}; ${track.submissions.length} official decisions` : "No round locked yet."}</p>
            </div>
            {track.round && (
              <ScoreCountdown
                client:visible
                status={track.round.status}
                scoreEtaUtc={track.round.score_eta_utc}
                source={track.round.score_eta_source}
                exitDate={track.round.exit_date}
                label="Score target"
                variant="inline"
                precision={track.key === "weekly" ? "hours" : "days"}
                initialNowIso={initialNowIso}
              />
            )}
          </div>
        ))}
      </div>

      <div class="console-metrics">
        {heroMetrics.map((metric) => (
          <div>
            <span>{metric.label}</span>
            <strong>{metric.value}</strong>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="track-summary" aria-label="CapitalBench track summary">
    {trackStates.map((track) => (
      <article class={`track-card track-card-${track.key}`}>
        <div class="track-card-head">
          <div>
            <span class="panel-kicker">{track.label} track</span>
            <h2>{track.round?.round_id ?? "No round yet"}</h2>
          </div>
          <span class={`status-badge ${statusClass(track.round)}`}>{statusLabel(track.round)}</span>
        </div>
        {track.round ? (
          <>
            <p>{track.horizonLabel}. {scoreLine(track.round)}</p>
            <div class="track-card-grid">
              <span>Window <strong>{windowLabel(track.round)}</strong></span>
              <span>Official decisions <strong>{track.submissions.length}</strong></span>
              <span>Universe <strong>{track.options.length} assets</strong></span>
              <span>Official run <strong>{track.round.official_run_id}</strong></span>
            </div>
          </>
        ) : (
          <p>No {track.label.toLowerCase()} round is published yet.</p>
        )}
        <div class="track-card-actions">
          <a class="small-button" href={track.latestHref}>Latest</a>
          <a class="small-button" href={track.cumulativeHref}>Cumulative</a>
          {track.roundHref && <a class="small-button" href={track.roundHref}>Round Packet</a>}
        </div>
      </article>
    ))}
  </section>

  <section class="home-section-heading" aria-labelledby="latest-decisions-title">
    <span class="panel-kicker">Official decisions</span>
    <h2 id="latest-decisions-title">Latest Allocations By Track</h2>
    <p>
      Weekly and monthly decisions are displayed in separate lanes. A weekly round is its own benchmark, not an interim
      monthly score.
    </p>
  </section>

  <section class="decision-track-grid" aria-label="Latest weekly and monthly allocations">
    {trackStates.map((track) => (
      <article class="decision-track">
        <div class="decision-track-header">
          <div>
            <span class="panel-kicker">{track.label} decisions</span>
            <h3>{track.round?.round_id ?? "Awaiting round"}</h3>
            <p>{track.round ? windowLabel(track.round) : "No decisions are locked yet."}</p>
          </div>
          <span class={`status-badge ${statusClass(track.round)}`}>{statusLabel(track.round)}</span>
        </div>

        {track.submissions.length > 0 ? (
          <>
            <div class="decision-row-list">
              {track.submissions.map((submission) => {
                const allocations = decisionAllocations(submission);
                return (
                  <div class="decision-row">
                    <div class="decision-row-meta">
                      <span class={`provider-badge provider-${submission.provider}`}>{providerLabel(submission.provider)}</span>
                      <strong>{modelLabel(submission.model_id)}</strong>
                      <p>{topHoldings(submission, track.optionsById)}</p>
                    </div>
                    <div class="allocation-stack mini" aria-hidden="true">
                      {allocations.map((allocation) => (
                        <span
                          class={allocationThemeClass(allocation.option_id)}
                          style={`width: ${Math.max(3, allocation.allocation_pct)}%`}
                          title={`${optionDisplayName(allocation.option_id, track.optionsById)} ${formatAllocationPct(allocation.allocation_pct)}`}
                        />
                      ))}
                    </div>
                  </div>
                );
              })}
            </div>

            <div class="track-exposure">
              <div>
                <span class="metric-label">Aggregate exposure</span>
                <strong>{track.topExposure ? optionDisplayName(track.topExposure.optionId, track.optionsById) : "None"}</strong>
              </div>
              <div class="exposure-bars compact">
                {track.exposures.slice(0, 4).map((item) => (
                  <div class="exposure-bar-row">
                    <span>{optionDisplayName(item.optionId, track.optionsById)}</span>
                    <div class="exposure-bar-track" aria-hidden="true">
                      <span
                        class={allocationThemeClass(item.optionId)}
                        style={`width: ${track.topExposure ? Math.max(4, (item.averagePct / track.topExposure.averagePct) * 100) : 0}%`}
                      />
                    </div>
                    <strong>{formatAllocationPct(item.averagePct)}</strong>
                  </div>
                ))}
              </div>
            </div>
          </>
        ) : (
          <div class="pending-state compact">
            <strong>No official decisions yet.</strong>
            <span>The latest {track.label.toLowerCase()} allocations will appear after the round is locked.</span>
          </div>
        )}

        <div class="track-card-actions">
          <a class="small-button" href={track.latestHref}>Open {track.label} Table</a>
          {track.roundHref && <a class="small-button" href={track.roundHref}>Audit Packet</a>}
        </div>
      </article>
    ))}
  </section>

  <section class="leaderboard-lanes" aria-labelledby="leaderboard-lanes-title">
    <div class="leaderboard-lanes-copy">
      <span class="panel-kicker">Scores and leaderboards</span>
      <h2 id="leaderboard-lanes-title">No Combined Horizon Score</h2>
      <p>
        Latest and cumulative views are split by horizon. Pending tracks show official allocations first; performance
        appears only after the declared exit close is priced.
      </p>
    </div>
    <div class="leaderboard-lane-links">
      <a href="/leaderboards/latest-weekly">
        <span>Latest Weekly</span>
        <strong>{latestWeeklyRound?.status === "resolved" ? "Scores live" : "Pending score"}</strong>
      </a>
      <a href="/leaderboards/latest-monthly">
        <span>Latest Monthly</span>
        <strong>{latestMonthlyRound?.status === "resolved" ? "Scores live" : "Pending score"}</strong>
      </a>
      <a href="/leaderboards/cumulative-weekly">
        <span>Cumulative Weekly</span>
        <strong>Weekly only</strong>
      </a>
      <a href="/leaderboards/cumulative-monthly">
        <span>Cumulative Monthly</span>
        <strong>Monthly only</strong>
      </a>
    </div>
  </section>

  <section class="timeline-lanes" aria-labelledby="track-timeline-title">
    <div class="home-section-heading">
      <span class="panel-kicker">{roundRows.length}-round record</span>
      <h2 id="track-timeline-title">Two Timelines, Two Score Windows</h2>
      <p>
        Each track has its own locked decision point, price window, and resolution job. The website keeps these lanes
        separate from first impression through cumulative reporting.
      </p>
    </div>
    <div class="timeline-lane-grid">
      {trackStates.map((track) => (
        <article class="timeline-lane">
          <div class="timeline-lane-head">
            <span class="panel-kicker">{track.label} timeline</span>
            <strong>{track.round?.round_id ?? "Awaiting round"}</strong>
          </div>
          <ol>
            <li class={track.round ? "phase-complete" : ""}>
              <span>1</span>
              <div>
                <strong>Decision locked</strong>
                <p>{track.round ? dateOnly(track.round.decision_deadline_utc) : "Pending"}</p>
              </div>
            </li>
            <li class={track.round ? "phase-current" : ""}>
              <span>2</span>
              <div>
                <strong>{track.horizonLabel} window</strong>
                <p>{track.round ? windowLabel(track.round) : "No window declared"}</p>
              </div>
            </li>
            <li class={track.round?.status === "resolved" ? "phase-complete" : "phase-current"}>
              <span>3</span>
              <div>
                <strong>{track.round?.status === "resolved" ? "Scores published" : "Score after exit close"}</strong>
                <p>{track.round ? scoreLine(track.round) : "Resolution pending."}</p>
              </div>
            </li>
          </ol>
        </article>
      ))}
    </div>
  </section>

  <section class="trust-strip" aria-label="Benchmark protocol snapshot">
    {protocolHighlights.map((item) => (
      <article>
        <span>{item.label}</span>
        <strong>{item.title}</strong>
        <p>{item.description}</p>
      </article>
    ))}
  </section>

  <nav class="view-switcher enhanced" aria-label="Explore CapitalBench">
    {exploreLinks.map((view) => {
      const Icon = view.icon;
      return (
        <a href={view.href}>
          <span class="view-icon" aria-hidden="true"><Icon size={18} /></span>
          <span class="view-copy">
            <strong>{view.label}</strong>
            <span>{view.description}</span>
          </span>
          <span class="view-state">{view.state}</span>
        </a>
      );
    })}
  </nav>

  <section class="audit-preview" aria-labelledby="audit-preview-title">
    <div>
      <span class="panel-kicker">Audit snapshot</span>
      <h2 id="audit-preview-title">Inspect Each Track Packet</h2>
      <p>
        The homepage previews the current state. Round pages carry the evidence: model-facing inputs, prompts, parsed
        outputs, entry prices, source reports, hashes, run manifests, and automation status.
      </p>
    </div>
    <div class="audit-preview-actions">
      {latestWeeklyRound && <a class="action-link action-primary" href={`/rounds/${latestWeeklyRound.round_id}/`}>Open latest weekly packet</a>}
      {latestMonthlyRound && <a class="action-link" href={`/rounds/${latestMonthlyRound.round_id}/`}>Open latest monthly packet</a>}
      <a class="action-link" href="/rounds">View all rounds</a>
      <a class="action-link" href={siteConfig.githubUrl} target="_blank" rel="noreferrer">
        <GitHubLogo size={15} />
        Repository
      </a>
    </div>
  </section>

  <section class="home-section-heading" aria-labelledby="safeguards-title">
    <span class="panel-kicker">Benchmark safeguards</span>
    <h2 id="safeguards-title">Built For Public Audit, Not Advice</h2>
    <p>
      The trust model is deliberately simple: fixed inputs, isolated official runs, public hashes, and no provisional
      performance claims before the scoring window resolves.
    </p>
  </section>

  <section class="evidence-grid enhanced" aria-label="Benchmark safeguards">
    {safeguards.map((item) => {
      const Icon = item.icon;
      return (
        <article>
          <div class="evidence-icon" aria-hidden="true">
            <Icon size={19} />
          </div>
          <span class="metric-label">{item.label}</span>
          <h3>{item.title}</h3>
          <p>{item.description}</p>
        </article>
      );
    })}
  </section>
</BaseLayout>
