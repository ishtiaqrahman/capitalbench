    <div class="audit-preview-actions">
      {latestWeeklyRound && <a class="action-link action-primary" href={`/rounds/${latestWeeklyRound.round_id}/`}>Open weekly saved files</a>}
      {latestMonthlyRound && <a class="action-link" href={`/rounds/${latestMonthlyRound.round_id}/`}>Open monthly saved files</a>}
      <a class="action-link" href="/rounds">View all tests</a>
      <a class="action-link" href={siteConfig.githubUrl} target="_blank" rel="noreferrer">
        <GitHubLogo size={15} />
        Repository
      </a>
    </div>
  </section>

  <section class="home-section-heading" aria-labelledby="safeguards-title">
    <span class="panel-kicker">Why it is fair</span>
    <h2 id="safeguards-title">Simple Rules, Public Proof</h2>
    <p>
      CapitalBench keeps the comparison narrow: same report, same asset list, saved picks, and no final result before
      the test ends.
    </p>
  </section>

  <section class="evidence-grid enhanced" aria-label="Benchmark safeguards">
    {safeguards.map((item) => {
      const Icon = item.icon;
      return (
        <article>
          <div class="evidence-icon" aria-hidden="true">
            <Icon size={19} />
          </div>
          <span class="metric-label">{item.label}</span>
          <h3>{item.title}</h3>
          <p>{item.description}</p>
        </article>
      );
    })}
  </section>
</BaseLayout>
