---
import BaseLayout from "../layouts/BaseLayout.astro";
import ActiveExposureMap from "../components/ActiveExposureMap";
import GitHubLogo from "../components/GitHubLogo.astro";
import LivePerformanceChart from "../components/LivePerformanceChart";
import ScoreReturnChart from "../components/ScoreReturnChart.astro";
import TrackScorecard from "../components/TrackScorecard.astro";
import {
  ArrowRight,
  BarChart3,
  ClipboardCheck,
  Database,
  FileCheck2,
  Layers3,
  LineChart,
  LockKeyhole,
  ShieldCheck,
  TimerReset
} from "lucide-react";
import {
  modelLabel,
  providerLabel,
  rounds as fallbackRounds,
  type RoundRecord,
  type SubmissionRecord,
  type UniverseOption
} from "../data/fallback";
import apiReadModel from "../generated/apiReadModel.js";
import {
  allocationThemeClass,
  decisionAllocations,
  formatAllocationPct,
  optionDisplayName,
  optionShortDisplayName
} from "../lib/allocations";
import { dateOnly } from "../lib/format";
import {
  staticAllOfficialSubmissions,
  staticAllWeeklyPerformance,
  staticOfficialSubmissions,
  staticRoundAllocations,
  staticRoundLeaderboard,
  staticRoundReturns,
  staticRoundRecords,
  staticUniverseOptions
} from "../lib/localRoundRecords";
import { buildScoreReturnChartData, providerLogoSrc } from "../lib/scoreReturnChart";
import { buildTrackScorecard } from "../lib/trackScorecard";
import { buildRunConcentration, type ConcentrationAsset, type RunConcentration } from "../lib/runConcentration";
import { siteConfig } from "../lib/seo";
import { staticModelProfiles } from "../lib/modelProfiles";
import {
  latestResolvedRoundForTrack,
  latestRoundForTrack,
  roundTrack,
  roundsForTrack,
  type BenchmarkTrack
} from "../lib/tracks";

type TrackHomeState = {
  key: BenchmarkTrack;
  label: string;
  horizonLabel: string;
  round?: RoundRecord;
  submissions: SubmissionRecord[];
  options: UniverseOption[];
  optionsById: Record<string, UniverseOption | undefined>;
  concentration: RunConcentration;
  exposures: ConcentrationAsset[];
  topExposure?: ConcentrationAsset;
  latestHref: string;
  cumulativeHref: string;
  roundHref?: string;
  roundCount: number;
};

const roundRows = staticRoundRecords();
const weeklyRounds = roundsForTrack(roundRows, "weekly");
const monthlyRounds = roundsForTrack(roundRows, "monthly");
const latestWeeklyRound = latestRoundForTrack(roundRows, "weekly");
const latestMonthlyRound = latestRoundForTrack(roundRows, "monthly");
const latestResolvedWeeklyRound = latestResolvedRoundForTrack(roundRows, "weekly");
const latestResolvedMonthlyRound = latestResolvedRoundForTrack(roundRows, "monthly");
const modelProfiles = staticModelProfiles();
const allOfficialSubmissions = staticAllOfficialSubmissions(roundRows);
const pendingRoundCount = roundRows.filter((round) => round.status === "pending").length;

function buildTrackState(
  key: BenchmarkTrack,
  label: string,
  horizonLabel: string,
  round: RoundRecord | undefined,
  roundCount: number
): TrackHomeState {
  const submissions = round ? staticOfficialSubmissions(round.round_id, round.official_run_id) : [];
  const options = round ? staticUniverseOptions(round.round_id) : [];
  const optionsById = Object.fromEntries(options.map((option) => [option.option_id, option]));
  const concentration = buildRunConcentration(submissions, optionsById);
  const exposures = concentration.assets.slice(0, 6);
  return {
    key,
    label,
    horizonLabel,
    round,
    submissions,
    options,
    optionsById,
    concentration,
    exposures,
    topExposure: concentration.topAsset,
    latestHref: `/leaderboards/latest-${key}`,
    cumulativeHref: `/leaderboards/cumulative-${key}`,
    roundHref: round ? `/rounds/${round.round_id}/` : undefined,
    roundCount
  };
}

const trackStates = [
  buildTrackState("weekly", "Weekly", "One-week test", latestWeeklyRound, weeklyRounds.length),
  buildTrackState("monthly", "Monthly", "One-month test", latestMonthlyRound, monthlyRounds.length)
];
const weeklyScorecard = buildTrackScorecard(roundRows, "weekly");
const monthlyScorecard = buildTrackScorecard(roundRows, "monthly");
const aggregateScorecards = [
  weeklyScorecard,
  monthlyScorecard
].filter((scorecard): scorecard is NonNullable<typeof scorecard> => scorecard !== null);
const publishedResults = [
  {
    key: "weekly" as const,
    label: "Weekly",
    round: latestResolvedWeeklyRound,
    leaderboard: latestResolvedWeeklyRound
      ? staticRoundLeaderboard(latestResolvedWeeklyRound.round_id, latestResolvedWeeklyRound.official_run_id)
      : []
  },
  {
    key: "monthly" as const,
    label: "Monthly",
    round: latestResolvedMonthlyRound,
    leaderboard: latestResolvedMonthlyRound
      ? staticRoundLeaderboard(latestResolvedMonthlyRound.round_id, latestResolvedMonthlyRound.official_run_id)
      : []
  }
].map((item) => ({ ...item, winner: item.leaderboard[0] }));
const completedPublishedResults = publishedResults
  .filter((result) => result.round && result.winner)
  .sort((a, b) => (b.round?.exit_date ?? "").localeCompare(a.round?.exit_date ?? ""));
const latestPublishedResult = completedPublishedResults[0];
const latestCompletedRound = latestPublishedResult?.round;
const latestCompletedWinner = latestPublishedResult?.winner;
const latestResultOptions = latestCompletedRound ? staticUniverseOptions(latestCompletedRound.round_id) : [];
const latestResultOptionsById: Record<string, UniverseOption | undefined> = Object.fromEntries(
  latestResultOptions.map((option) => [option.option_id, option])
);
const latestResultReturns = latestCompletedRound
  ? staticRoundReturns(latestCompletedRound.round_id, latestCompletedRound.official_run_id)
  : [];
const latestResultAllocations = latestCompletedRound
  ? staticRoundAllocations(latestCompletedRound.round_id, latestCompletedRound.official_run_id)
  : [];
const latestScoreChart = buildScoreReturnChartData({
  leaderboard: latestPublishedResult?.leaderboard ?? [],
  returns: latestResultReturns,
  optionsById: latestResultOptionsById,
  allocations: latestResultAllocations
});
const latestResultEligibleAssetCount = latestResultOptions.length;
const activeExposureRounds = roundRows
  .filter((round) => round.status === "pending" && round.official_run_id)
  .map((round) => {
    const track = roundTrack(round);
    return {
      round,
      track,
      submissions: staticOfficialSubmissions(round.round_id, round.official_run_id),
      options: staticUniverseOptions(round.round_id)
    };
  })
  .filter((item) => (item.track === "weekly" || item.track === "monthly") && item.submissions.length > 0);
const livePerformanceRows = staticAllWeeklyPerformance(roundRows).filter((row) => row.status === "pending");
const openRoundCounts = {
  all: activeExposureRounds.length,
  weekly: activeExposureRounds.filter((item) => item.track === "weekly").length,
  monthly: activeExposureRounds.filter((item) => item.track === "monthly").length
};
const liveRiskSnapshot = apiReadModel.risk_appetite;
const currentRiskPulse = liveRiskSnapshot.current_decision_pulse;
const outstandingBookRisk = liveRiskSnapshot.outstanding_live_book;
const riskPulseTopAssets = currentRiskPulse.top_assets.slice(0, 6);
const riskPulseRegimes = currentRiskPulse.regime_exposure.slice(0, 5);
const riskAppetiteProfiles = [...modelProfiles]
  .filter((profile) => profile.fingerprint.riskAppetite.score !== null)
  .sort(
    (a, b) =>
      (a.fingerprint.riskAppetite.score ?? 0) - (b.fingerprint.riskAppetite.score ?? 0) ||
      a.label.localeCompare(b.label)
  );
const riskScores = riskAppetiteProfiles
  .map((profile) => profile.fingerprint.riskAppetite.score)
  .filter((score): score is number => score !== null && Number.isFinite(score));
const riskMinScore = riskScores.length > 0 ? Math.min(...riskScores) : null;
const riskMaxScore = riskScores.length > 0 ? Math.max(...riskScores) : null;
const rawRiskRange = riskMinScore !== null && riskMaxScore !== null ? riskMaxScore - riskMinScore : 0;
const riskFocusPadding = Math.max(0.06, Math.min(0.18, rawRiskRange * 0.18));
let riskFocusMin = riskMinScore !== null ? Math.max(1, riskMinScore - riskFocusPadding) : 1;
let riskFocusMax = riskMaxScore !== null ? Math.min(5, riskMaxScore + riskFocusPadding) : 5;
if (riskFocusMax - riskFocusMin < 0.36) {
  const center = riskMinScore !== null && riskMaxScore !== null ? (riskMinScore + riskMaxScore) / 2 : 3;
  riskFocusMin = Math.max(1, center - 0.18);
  riskFocusMax = Math.min(5, center + 0.18);
  if (riskFocusMax - riskFocusMin < 0.36) {
    if (riskFocusMin <= 1) riskFocusMax = Math.min(5, riskFocusMin + 0.36);
    if (riskFocusMax >= 5) riskFocusMin = Math.max(1, riskFocusMax - 0.36);
  }
}
const lowestRiskProfile = riskAppetiteProfiles[0];
const highestRiskProfile = riskAppetiteProfiles[riskAppetiteProfiles.length - 1];
const riskLabelSet = Array.from(new Set(riskAppetiteProfiles.map((profile) => profile.fingerprint.riskAppetite.label)));
const riskClusterLabel = riskLabelSet.length === 1 ? `All ${riskLabelSet[0]}` : riskLabelSet.join(" / ");
const riskPortfolioCount = riskAppetiteProfiles.reduce((total, profile) => total + profile.fingerprint.portfolioCount, 0);
const latestUniverseOptionCount = Math.max(0, ...trackStates.map((track) => track.options.length));
const currentRound = latestMonthlyRound ?? latestWeeklyRound ?? roundRows[0] ?? fallbackRounds[0];
const currentUniverseOptionCount = latestUniverseOptionCount || staticUniverseOptions(currentRound.round_id).length;
const modelRoster = Array.from(new Map(allOfficialSubmissions.map((submission) => [submission.model_id, submission])).values())
  .sort((a, b) => providerLabel(a.provider).localeCompare(providerLabel(b.provider)));
const scoringWindows = [
  { label: "Weekly", value: "7 days" },
  { label: "Monthly", value: "1 month" }
];
const exploreLinks = [
  {
    href: "/leaderboards/latest",
    icon: BarChart3,
    label: "Latest scores",
    description: "See which model did best in finished tests.",
    state: "Results"
  },
  {
    href: "/rounds",
    icon: Layers3,
    label: "All tests",
    description: "Open saved reports, model picks, prices, and results.",
    state: `${roundRows.length} tests`
  },
  {
    href: "/scoring",
    icon: TimerReset,
    label: "How the test works",
    description: "Same report, same choices, saved picks, real prices.",
    state: "Plain rules"
  }
];
const heroTestSteps = [
  {
    icon: ClipboardCheck,
    label: "1",
    title: "Same report",
    description: "Every model reads the same market report."
  },
  {
    icon: Database,
    label: "2",
    title: "Same choices",
    description: `Every model chooses from the same ${currentUniverseOptionCount} assets.`
  },
  {
    icon: LockKeyhole,
    label: "3",
    title: "Models pick",
    description: "Each model saves one portfolio."
  },
  {
    icon: TimerReset,
    label: "4",
    title: "We wait",
    description: "The test runs for 7 days or 1 month."
  },
  {
    icon: LineChart,
    label: "5",
    title: "Prices score it",
    description: "Real market prices show which model did best."
  }
];
const howItWorks = [
  {
    label: "1",
    title: "Same report",
    description: "Every model gets the same market report."
  },
  {
    label: "2",
    title: "Same choices",
    description: "Every model picks from the same asset list."
  },
  {
    label: "3",
    title: "Saved picks",
    description: "The picks are locked before results are known."
  },
  {
    label: "4",
    title: "Real prices score",
    description: "After 7 days or 1 month, real prices decide the result."
  }
];
const safeguards = [
  {
    icon: ShieldCheck,
    label: "Same rules",
    title: "One saved pick per model",
    description: "The public score uses the saved portfolio, not private retries or experiments."
  },
  {
    icon: Database,
    label: "Same choices",
    title: `${latestUniverseOptionCount} current assets`,
    description: "Each test keeps the exact asset list, report, model output, starting prices, and proof hashes."
  },
  {
    icon: FileCheck2,
    label: "No early winner",
    title: `${pendingRoundCount} tests waiting for results`,
    description: "Final results appear only after ending prices are available."
  }
];

function statusLabel(round?: RoundRecord): string {
  if (!round) return "Not started";
  if (round.status === "resolved") return "Scored";
  if (round.status === "archived") return "Archived";
  return "Waiting for result";
}

function statusClass(round?: RoundRecord): string {
  return round ? `status-${round.status}` : "status-archived";
}

function windowLabel(round?: RoundRecord): string {
  if (!round) return "Awaiting first round";
  return `${dateOnly(round.entry_date)} to ${dateOnly(round.exit_date)}`;
}

function scoreLine(round?: RoundRecord): string {
  if (!round) return "No score window declared yet.";
  if (round.status === "resolved") return "Scores are published.";
  return `Results publish after the ${dateOnly(round.exit_date)} ending close.`;
}

function shortMonthDay(value?: string): string {
  if (!value) return "";
  const [year, month, day] = value.slice(0, 10).split("-").map(Number);
  if (!year || !month || !day) return dateOnly(value);
  return new Intl.DateTimeFormat("en-US", { month: "short", day: "numeric", timeZone: "UTC" }).format(
    new Date(Date.UTC(year, month - 1, day))
  );
}

function scoreShortLine(round?: RoundRecord): string {
  if (!round) return "No score date";
  if (round.status === "resolved") return "Scored";
  return `Results after ${shortMonthDay(round.exit_date)} close`;
}

function modelProfileHref(modelId: string): string {
  return `/models/${modelId}/#live-holdings`;
}

function modelFingerprintHref(modelId: string): string {
  return `/models/${modelId}/#model-fingerprint`;
}

function pctValue(value: number | null | undefined): string {
  if (value === null || value === undefined || !Number.isFinite(value)) return "n/a";
  if (Math.abs(value) >= 10) return `${value.toFixed(1)}%`;
  if (Math.abs(value) >= 1) return `${value.toFixed(1)}%`;
  return `${value.toFixed(2)}%`;
}

function riskScoreValue(value: number | null | undefined): string {
  if (value === null || value === undefined || !Number.isFinite(value)) return "n/a";
  return `${value.toFixed(2)} / 5`;
}

function riskScoreShort(value: number | null | undefined): string {
  if (value === null || value === undefined || !Number.isFinite(value)) return "n/a";
  return value.toFixed(2);
}

function pulseScore(value: number | null | undefined): string {
  if (value === null || value === undefined || !Number.isFinite(value)) return "n/a";
  return value.toFixed(1);
}

function signedPulseChange(value: number | null | undefined): string {
  if (value === null || value === undefined || !Number.isFinite(value)) return "n/a";
  return `${value > 0 ? "+" : ""}${value.toFixed(1)}`;
}

function riskWidth(value: number | null | undefined): string {
  if (value === null || value === undefined || !Number.isFinite(value)) return "0%";
  return `${Math.min(100, Math.max(0, value)).toFixed(2)}%`;
}

function riskFocusWidth(value: number | null | undefined): string {
  if (value === null || value === undefined || !Number.isFinite(value)) return "0%";
  const denominator = riskFocusMax - riskFocusMin;
  if (denominator <= 0) return "50%";
  return riskWidth(((value - riskFocusMin) / denominator) * 100);
}

function topHoldings(submission: SubmissionRecord, optionsById: TrackHomeState["optionsById"]): string {
  const allocations = decisionAllocations(submission)
    .sort((a, b) => b.allocation_bps - a.allocation_bps);
  if (allocations.length === 0) return "No pick";
  return allocations
    .map((allocation) => `${optionShortDisplayName(allocation.option_id, optionsById)} ${formatAllocationPct(allocation.allocation_pct)}`)
    .join(", ");
}

const trackLaneCards = trackStates.map((track) => {
  const trackRounds = track.key === "weekly" ? weeklyRounds : monthlyRounds;
  const scorecard = track.key === "weekly" ? weeklyScorecard : monthlyScorecard;
  const resolvedRounds = trackRounds.filter((round) => round.status === "resolved");
  const liveRounds = trackRounds
    .filter((round) => round.status === "pending")
    .sort((left, right) => right.decision_deadline_utc.localeCompare(left.decision_deadline_utc));
  const latestResolvedRound = track.key === "weekly" ? latestResolvedWeeklyRound : latestResolvedMonthlyRound;
  const latestLiveRound = liveRounds[0];
  const leader = scorecard?.topNormalizedRow;
  const score = leader?.averageScore;
  const resolvedScoreCount = scorecard?.comparisonRoundCount ?? 0;
  return {
    ...track,
    scorecard,
    leader,
    leaderScore: typeof score === "number" && Number.isFinite(score) ? score.toFixed(1) : null,
    resolvedScoreCount,
    leaderLogo: leader?.logoSrc,
    completedCount: resolvedRounds.length,
    liveCount: liveRounds.length,
    latestResolvedRound,
    latestLiveRound,
    latestScoredLabel: latestResolvedRound?.round_id ?? "No completed score yet",
    latestLiveLabel: latestLiveRound?.round_id ?? "No live round",
    nextScoreLabel: latestLiveRound
      ? `After ${shortMonthDay(latestLiveRound.exit_date)} close`
      : latestResolvedRound
        ? "No open round"
        : "Waiting for first score"
  };
});
---

<BaseLayout
  title="CapitalBench - AI Market Picks Scoreboard"
  description="CapitalBench gives AI models the same market report and asset list, saves their portfolios, and scores them using real market prices."
>
  <section class="home-hero" aria-labelledby="home-title">
    <div class="home-hero-copy">
      <p class="eyebrow">CapitalBench</p>
      <h1 id="home-title">Benchmarking AI Models With Public Market Portfolios</h1>
      <p class="home-hero-lede">
        Every AI model gets the same market report and the same asset list. Each model picks a portfolio. After 7 days
        or 1 month, real market prices show which model did best.
      </p>
      <p class="hero-disclaimer">Research benchmark. Not financial advice.</p>

      <div class="home-hero-actions" aria-label="Project resources">
        <a class="action-link action-primary" href="/leaderboards/latest">
          Latest scores
          <ArrowRight size={15} aria-hidden="true" />
        </a>
        <a class="action-link" href="#how-it-works">How it works</a>
        <a class="action-link" href="#current-picks">Open picks</a>
        <a class="action-link" href="#proof-and-data">Saved files</a>
      </div>
    </div>

    <div class="home-hero-console benchmark-process-card" id="how-it-works" aria-label="How CapitalBench tests AI models">
      <div class="console-header">
        <div class="console-title">
          <img src="/benchmark-panel.svg" alt="" width="42" height="42" loading="eager" />
          <div>
            <span>How the test works</span>
            <strong>Same report, same choices, real prices</strong>
          </div>
        </div>
        <span class="status-badge status-pending">Running</span>
      </div>

      <ol class="benchmark-process-list">
        {heroTestSteps.map((step) => {
          const Icon = step.icon;
          return (
          <li>
            <span class="benchmark-process-index">{step.label}</span>
            <div>
              <strong>
                <Icon size={15} aria-hidden="true" />
                {step.title}
              </strong>
              <p>{step.description}</p>
            </div>
          </li>
          );
        })}
      </ol>

      <div class="benchmark-process-note">
        <strong>No guessing after the fact.</strong>
        <span>Picks are saved first. Results appear only after the test period ends.</span>
      </div>
    </div>
  </section>

  {aggregateScorecards.length > 0 && (
    <>
      <section class="home-section-heading home-section-heading-with-action" id="track-scorecards" aria-labelledby="track-scorecards-title">
        <div>
          <span class="panel-kicker">Resolved tests</span>
          <h2 id="track-scorecards-title">Model Scores</h2>
          <p>
            Each bar is an average across all resolved tests in that track. The latest single-test result is shown
            separately below.
          </p>
        </div>
        <a class="section-profile-link" href="/leaderboards">All scores</a>
      </section>

      <div class="track-scorecard-stack" aria-label="Combined completed track scorecards">
        {aggregateScorecards.map((scorecard) => <TrackScorecard scorecard={scorecard} />)}
      </div>
    </>
  )}

  {latestPublishedResult && latestCompletedRound && latestCompletedWinner && (
    <>
      <section class="home-section-heading" aria-labelledby="published-results-title">
        <span class="panel-kicker">Latest result</span>
        <h2 id="published-results-title">Most Recent Finished Test</h2>
        <p>
          This chart shows how each saved portfolio performed after the test ended. Open tests stay out until final
          prices are available.
        </p>
      </section>

      <section
        class="published-score-panel"
        aria-label={`Latest scored ${latestPublishedResult.label.toLowerCase()} result`}
      >
        <ScoreReturnChart chart={latestScoreChart} label={`${latestPublishedResult.label} result`} />

        <div class="published-score-summary published-score-run-details">
          <div class="published-score-summary-head">
            <div class="published-result-head">
              <div>
                <span class="panel-kicker">Saved test</span>
                <h3>{latestCompletedRound.round_id}</h3>
                <p>Dates, asset choices, and saved files.</p>
              </div>
            </div>

            <div class="track-card-actions">
              <a class="small-button" href={`/rounds/${latestCompletedRound.round_id}/`}>Full result</a>
              <a class="small-button" href={`/leaderboards/latest-${latestPublishedResult.key}`}>Leaderboard</a>
            </div>
          </div>

          <div class="published-score-context" aria-label="Scoring context">
            <span><strong>Dates</strong>{dateOnly(latestCompletedRound.entry_date)} to {dateOnly(latestCompletedRound.exit_date)}</span>
            <span><strong>Models</strong>{latestPublishedResult.leaderboard.length}</span>
            <span><strong>Asset choices</strong>{latestResultEligibleAssetCount}</span>
            <span><strong>Test length</strong>{latestPublishedResult.label}</span>
          </div>
        </div>
      </section>
    </>
  )}

  <section class="current-setup-panel" aria-labelledby="current-setup-title">
    <div class="current-setup-head">
      <span class="panel-kicker">Current setup</span>
      <h2 id="current-setup-title">What Models Are Picking From</h2>
      <p>
        Models get the same report, choose from the same assets, and wait for weekly or monthly results.
      </p>
    </div>

    <div class="current-setup-stat-row" aria-label="Current CapitalBench setup summary">
      <div>
        <span>Models</span>
        <strong>{modelRoster.length}</strong>
      </div>
      <div>
        <span>Asset choices</span>
        <strong>{currentUniverseOptionCount}</strong>
      </div>
      <div>
        <span>Test lengths</span>
        <strong>2</strong>
      </div>
      <div>
        <span>Open tests</span>
        <strong>{pendingRoundCount}</strong>
      </div>
    </div>

    <div class="current-setup-detail-grid" aria-label="Current CapitalBench test details">
      <article class="current-setup-detail-card current-setup-model-card">
        <div class="current-setup-detail-head">
          <div>
            <span class="panel-kicker">Models in the test</span>
            <strong>{modelRoster.length} AI models</strong>
          </div>
          <a href="/models">Model pages</a>
        </div>
        <div class="current-setup-model-list" aria-label="Models currently compared">
          {modelRoster.map((submission) => (
            <a href={modelProfileHref(submission.model_id)} aria-label={`${providerLabel(submission.provider)}: ${modelLabel(submission.model_id)}`}>
              {providerLogoSrc(submission.provider) && (
                <img src={providerLogoSrc(submission.provider)} alt={providerLabel(submission.provider)} width="34" height="34" loading="lazy" />
              )}
              <span>
                <strong>{modelLabel(submission.model_id)}</strong>
                <em>{providerLabel(submission.provider)}</em>
              </span>
            </a>
          ))}
        </div>
      </article>

      <article class="current-setup-detail-card current-setup-live-card">
        <div class="current-setup-detail-head">
          <div>
            <span class="panel-kicker">Open tests waiting for results</span>
            <strong>Latest weekly and monthly tests</strong>
          </div>
          <span class="current-setup-count-badge">{pendingRoundCount} open total</span>
        </div>
        <div class="current-setup-rule-strip" aria-label="Shared setup rules">
          <span>
            <strong>{currentUniverseOptionCount}</strong>
            asset choices
          </span>
          {scoringWindows.map((window) => (
            <span>
              <strong>{window.label}</strong>
              {window.value}
            </span>
          ))}
        </div>
        <div class="current-setup-round-list">
          {trackStates.map((track) => (
            <a href={track.roundHref ?? "/rounds"}>
              <span>{track.label}</span>
              <strong>{track.round?.round_id ?? "Not started"}</strong>
              <em>{scoreShortLine(track.round)}</em>
            </a>
          ))}
        </div>
      </article>
