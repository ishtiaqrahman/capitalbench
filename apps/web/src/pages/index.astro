---
import BaseLayout from "../layouts/BaseLayout.astro";
import GitHubLogo from "../components/GitHubLogo.astro";
import LeaderboardTable from "../components/LeaderboardTable";
import OfficialPicksTable from "../components/OfficialPicksTable";
import {
  ArrowRight,
  BarChart3,
  Database,
  ExternalLink,
  FileCheck2,
  Layers3,
  Scale,
  ShieldCheck,
  TimerReset
} from "lucide-react";
import { latestLeaderboard, modelLabel, providerLabel, rounds as fallbackRounds } from "../data/fallback";
import {
  allocationThemeClass,
  decisionAllocations,
  formatAllocationPct,
  optionDisplayName,
  protocolLabel
} from "../lib/allocations";
import {
  staticAllOfficialSubmissions,
  staticOfficialSubmissions,
  staticRoundRecords,
  staticUniverseOptions
} from "../lib/localRoundRecords";
import { siteConfig } from "../lib/seo";

const roundRows = staticRoundRecords();
const currentRound = roundRows[0] ?? fallbackRounds[0];
const previousRound = roundRows.find((round) => round.round_id !== currentRound.round_id);
const currentRoundSubmissions = staticOfficialSubmissions(currentRound.round_id, currentRound.official_run_id);
const previousRoundSubmissions = previousRound
  ? staticOfficialSubmissions(previousRound.round_id, previousRound.official_run_id)
  : [];
const allOfficialSubmissions = staticAllOfficialSubmissions(roundRows);
const currentUniverseOptions = staticUniverseOptions(currentRound.round_id);
const currentOptionsById = Object.fromEntries(currentUniverseOptions.map((option) => [option.option_id, option]));
const resolvedRoundCount = roundRows.filter((round) => round.status === "resolved").length;
const pendingRoundCount = roundRows.filter((round) => round.status === "pending").length;
const currentRoundUrl = `/rounds/${currentRound.round_id}/`;
const confidenceValues = currentRoundSubmissions
  .map((row) => row.confidence)
  .filter((value): value is number => Number.isFinite(value));
const confidenceRange =
  confidenceValues.length > 0
    ? `${Math.min(...confidenceValues).toFixed(2)}-${Math.max(...confidenceValues).toFixed(2)}`
    : "not reported";
const semiconductorAllocationCount = previousRoundSubmissions.filter((row) =>
  decisionAllocations(row).some((allocation) => allocation.option_id === "SEMICONDUCTORS" && allocation.allocation_pct === 100)
).length;
const allocationTotals = new Map<string, number>();
for (const submission of currentRoundSubmissions) {
  for (const allocation of decisionAllocations(submission)) {
    allocationTotals.set(allocation.option_id, (allocationTotals.get(allocation.option_id) ?? 0) + allocation.allocation_bps);
  }
}
const currentRoundExposure = Array.from(allocationTotals.entries())
  .map(([optionId, totalBps]) => ({
    optionId,
    averagePct: currentRoundSubmissions.length > 0 ? totalBps / currentRoundSubmissions.length / 100 : 0
  }))
  .sort((a, b) => b.averagePct - a.averagePct)
  .slice(0, 7);
const heroMetrics = [
  { label: "Official rounds", value: String(roundRows.length) },
  { label: "Locked decisions", value: String(allOfficialSubmissions.length) },
  { label: "Latest universe", value: `${currentUniverseOptions.length} assets` },
  { label: "Resolved scores", value: String(resolvedRoundCount) }
];
const resultViews = [
  {
    href: "/leaderboards/latest",
    icon: BarChart3,
    label: "Latest Round",
    description: "Newest official round. Pending rounds show locked allocations before scored performance.",
    state: currentRound.status === "resolved" ? "Scored" : "Pending"
  },
  {
    href: "/leaderboards/cumulative-official",
    icon: Layers3,
    label: "Cumulative Official",
    description: "Average official alpha once at least one score window has resolved.",
    state: resolvedRoundCount > 0 ? "Live" : "Awaiting scores"
  },
  {
    href: "/leaderboards/cumulative-stability",
    icon: TimerReset,
    label: "Cumulative Stability",
    description: "Repeated-call alpha and consistency, kept separate from official one-shot results.",
    state: "Separate"
  }
];
const protocolHighlights = [
  {
    label: "Same packet",
    title: "Identical prompt and market context",
    description: "Every official model receives the same frozen briefing, option universe, dates, and response schema."
  },
  {
    label: "Locked first",
    title: "Decisions publish before outcomes",
    description: "Allocations are public while the score window is still unresolved, so hindsight cannot shape the record."
  },
  {
    label: "Portfolio aware",
    title: "Single picks and portfolios compare cleanly",
    description: "Round 1 is displayed as a 100% one-holding allocation; Round 2 uses submitted multi-asset portfolios."
  },
  {
    label: "Public audit",
    title: "Prompts, outputs, hashes, and repo history",
    description: "Readers can inspect model-facing inputs, validated outputs, artifacts, and implementation changes."
  }
];
const safeguards = [
  {
    icon: ShieldCheck,
    label: "Run isolation",
    title: "One official call per model",
    description: "Official results are never mixed with repeated stability runs, mock output, or provider smoke tests."
  },
  {
    icon: Database,
    label: "Inspection",
    title: `${currentUniverseOptions.length} current options`,
    description: "The latest round expands the market universe while preserving the original Round 1 packet."
  },
  {
    icon: FileCheck2,
    label: "Score boundary",
    title: `${pendingRoundCount} pending score windows`,
    description: "Realized alpha appears only after exit prices are collected and the scorer publishes official results."
  }
];
---

<BaseLayout
  title="CapitalBench - LLM Market Benchmark and Leaderboards"
  description="CapitalBench tests AI models on the same frozen market packet, then publishes their allocations, scores, and audit trail."
>
  <section class="home-hero" aria-labelledby="home-title">
    <div class="home-hero-copy">
      <p class="eyebrow">Auditable AI market benchmark</p>
      <h1 id="home-title">CapitalBench</h1>
      <p class="home-hero-lede">
        CapitalBench gives leading AI models the same frozen market packet, asks them to make a one-month market
        allocation before outcomes are known, then publishes the decisions, realized returns, and audit trail.
      </p>
    </div>

    <div class="home-hero-actions" aria-label="Project resources">
      <a class="action-link action-primary" href={currentRoundUrl}>
        View latest round
        <ArrowRight size={15} aria-hidden="true" />
      </a>
      <a class="action-link" href="/rounds">See all rounds</a>
      <a
        class="action-link"
        href={siteConfig.githubUrl}
        target="_blank"
        rel="noreferrer"
        data-analytics-event="github_repository_click"
        data-analytics-param-location="home_hero"
      >
        <GitHubLogo size={17} />
        GitHub repository
        <ExternalLink size={14} aria-hidden="true" />
      </a>
    </div>

    <div class="home-hero-console" aria-label="Current benchmark state">
      <div class="console-header">
        <div class="console-title">
          <img src="/benchmark-panel.svg" alt="" width="42" height="42" loading="eager" />
          <div>
            <span>Latest Official Round</span>
            <strong>{currentRound.round_id}</strong>
          </div>
        </div>
        <span class="status-badge status-pending">Score pending</span>
      </div>

      <div class="console-metrics">
        {heroMetrics.map((metric) => (
          <div>
            <span>{metric.label}</span>
            <strong>{metric.value}</strong>
          </div>
        ))}
      </div>

      <div class="console-ledger" aria-label="Benchmark evidence ledger">
        <div>
          <span>Latest protocol</span>
          <strong>{currentRound.methodology_version} with {currentRoundSubmissions.length} official portfolios</strong>
        </div>
        <div>
          <span>Observation window</span>
          <strong>Scores publish after {currentRound.exit_date} exit prices are collected</strong>
        </div>
        <div>
          <span>Round 1 compatibility</span>
          <strong>{semiconductorAllocationCount} of {previousRoundSubmissions.length} models display as SEMICONDUCTORS 100%</strong>
        </div>
      </div>
    </div>
  </section>

  <section class="trust-strip" aria-label="Benchmark protocol snapshot">
    {protocolHighlights.map((item) => (
      <article>
        <span>{item.label}</span>
        <strong>{item.title}</strong>
        <p>{item.description}</p>
      </article>
    ))}
  </section>

  <section class="home-section-heading" aria-labelledby="latest-allocation-title">
    <span class="panel-kicker">Latest round</span>
    <h2 id="latest-allocation-title">Round 2 Moves From Picks To Portfolios</h2>
    <p>
      The current official round lets models allocate across multiple assets. The site now reports every model decision
      as an allocation, which keeps Round 1 comparable without rewriting its original single-pick protocol.
    </p>
  </section>

  <section class="allocation-showcase" aria-label="Latest round model allocations">
    <div class="allocation-board">
      {currentRoundSubmissions.map((submission) => {
        const allocations = decisionAllocations(submission);
        return (
          <article class="allocation-card">
            <div class="allocation-card-head">
              <div>
                <span class={`provider-badge provider-${submission.provider}`}>{providerLabel(submission.provider)}</span>
                <h3>{modelLabel(submission.model_id)}</h3>
                <p class="mono">{submission.model_id}</p>
              </div>
              <span class="badge badge-blue">{protocolLabel(submission)}</span>
            </div>
            <div class="allocation-stack" aria-hidden="true">
              {allocations.map((allocation) => (
                <span
                  class={allocationThemeClass(allocation.option_id)}
                  style={`width: ${Math.max(3, allocation.allocation_pct)}%`}
                  title={`${optionDisplayName(allocation.option_id, currentOptionsById)} ${formatAllocationPct(allocation.allocation_pct)}`}
                />
              ))}
            </div>
            <ul class="allocation-list">
              {allocations.map((allocation) => (
                <li>
                  <span class={`allocation-dot ${allocationThemeClass(allocation.option_id)}`}></span>
                  <strong>{optionDisplayName(allocation.option_id, currentOptionsById)}</strong>
                  <span>{formatAllocationPct(allocation.allocation_pct)}</span>
                </li>
              ))}
            </ul>
          </article>
        );
      })}
    </div>

    <aside class="allocation-summary" aria-label="Latest round allocation summary">
      <span class="panel-kicker">Aggregate exposure</span>
      <h3>Where Round 2 Concentrated</h3>
      <p>
        Across {currentRoundSubmissions.length} official models, energy and real-asset exposure replaced the Round 1
        all-semiconductor consensus, while semiconductors remained present in every portfolio.
      </p>
      <div class="exposure-list">
        {currentRoundExposure.map((item) => (
          <div>
            <span>{optionDisplayName(item.optionId, currentOptionsById)}</span>
            <strong>{formatAllocationPct(item.averagePct)}</strong>
          </div>
        ))}
      </div>
    </aside>
  </section>

  <section class="phase-band" aria-labelledby="round-progress-title">
    <div class="phase-intro">
      <span class="panel-kicker">Two-round record</span>
      <h2 id="round-progress-title">Decisions Are Public; Scores Wait For Exit Prices</h2>
      <p>
        Both official rounds are locked and auditable. Performance stays absent until each pre-declared exit date
        resolves.
      </p>
    </div>
    <ol class="phase-list">
      <li class="phase-complete">
        <span>1</span>
        <strong>Round 1 locked</strong>
        <p>{previousRoundSubmissions.length} models selected Semiconductors; displayed as 100% allocations.</p>
      </li>
      <li class="phase-complete">
        <span>2</span>
        <strong>Round 2 locked</strong>
        <p>{currentRoundSubmissions.length} valid official portfolios are public.</p>
      </li>
      <li class="phase-current">
        <span>3</span>
        <strong>Round 1 exit pending</strong>
        <p>Performance unlocks after {previousRound?.exit_date ?? "the declared exit date"} prices are collected.</p>
      </li>
      <li class="phase-current">
        <span>4</span>
        <strong>Round 2 exit pending</strong>
        <p>Portfolio returns and alpha publish after {currentRound.exit_date}.</p>
      </li>
    </ol>
  </section>

  <nav class="view-switcher enhanced" aria-label="Primary result views">
    {resultViews.map((view) => {
      const Icon = view.icon;
      return (
        <a href={view.href}>
          <span class="view-icon" aria-hidden="true"><Icon size={18} /></span>
          <span class="view-copy">
            <strong>{view.label}</strong>
            <span>{view.description}</span>
          </span>
          <span class="view-state">{view.state}</span>
        </a>
      );
    })}
  </nav>

  <section class="dashboard-grid">
    <div class="panel">
      <div class="panel-header">
        <div>
          <span class="panel-kicker">Latest official round</span>
          <h2>Official Allocations</h2>
          <p>
            Round 2 contains {currentRoundSubmissions.length} valid one-shot portfolios, with confidence ranging from
            {" "}{confidenceRange}. These are locked decisions, not realized performance.
          </p>
        </div>
        <span class="status-badge status-pending">Pending score</span>
      </div>
      <OfficialPicksTable
        client:visible
        fallbackRows={currentRoundSubmissions}
        roundId={currentRound.round_id}
        runId={currentRound.official_run_id}
        options={currentUniverseOptions}
      />
    </div>

    <aside class="rail" aria-label="Round audit summary">
      <div class="rail-panel highlight-panel">
        <span class="metric-label">Latest protocol</span>
        <h3>{currentRound.submission_format === "portfolio" ? "Portfolio allocations" : "Single-pick decisions"}</h3>
        <p>{currentRound.methodology_version}. One official call per model; no post-cutoff retrieval.</p>
      </div>
      <div class="rail-panel">
        <span class="metric-label">Round 1 display</span>
        <h3>SEMICONDUCTORS 100%</h3>
        <p>Round 1 remains a single-pick round, shown as one-holding allocations for cross-round readability.</p>
      </div>
      <div class="rail-panel">
        <span class="metric-label">Audit trail</span>
        <h3>{allOfficialSubmissions.length} public decisions</h3>
        <p>{roundRows.length} rounds with frozen prompts, option files, entry prices, and validation artifacts.</p>
      </div>
      <div class="rail-panel rail-checklist">
        <span class="metric-label">Reader path</span>
        <ul>
          <li><a href={currentRoundUrl}>Review the latest round packet</a></li>
          <li><a href="/rounds">Compare all rounds</a></li>
          <li><a href="/methodology">Read methodology</a></li>
        </ul>
      </div>
    </aside>
  </section>

  <section class="home-section-heading" aria-labelledby="safeguards-title">
    <span class="panel-kicker">Benchmark safeguards</span>
    <h2 id="safeguards-title">Built For Public Audit, Not Advice</h2>
    <p>
      The trust model is deliberately simple: fixed inputs, isolated official runs, public hashes, and no provisional
      performance claims before the scoring window resolves.
    </p>
  </section>

  <section class="evidence-grid enhanced" aria-label="Benchmark safeguards">
    {safeguards.map((item) => {
      const Icon = item.icon;
      return (
        <article>
          <div class="evidence-icon" aria-hidden="true">
            <Icon size={19} />
          </div>
          <span class="metric-label">{item.label}</span>
          <h3>{item.title}</h3>
          <p>{item.description}</p>
        </article>
      );
    })}
  </section>

  <section class="section resolution-section">
    <div class="panel">
      <div class="panel-header">
        <div>
          <span class="panel-kicker">Latest leaderboard</span>
          <h2>No Resolved Scores Yet</h2>
          <p>
            The first official leaderboard appears after exit prices are available and the selected run is scored. Until
            then, CapitalBench publishes allocations without implying realized performance.
          </p>
        </div>
        <Scale size={22} aria-hidden="true" />
      </div>
      <LeaderboardTable client:visible fallbackRows={latestLeaderboard} kind="latest" />
    </div>
  </section>
</BaseLayout>
