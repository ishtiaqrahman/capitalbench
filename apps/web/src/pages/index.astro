---
import BaseLayout from "../layouts/BaseLayout.astro";
import GitHubLogo from "../components/GitHubLogo.astro";
import StatusCards from "../components/StatusCards.astro";
import LeaderboardTable from "../components/LeaderboardTable";
import OfficialPicksTable from "../components/OfficialPicksTable";
import {
  ArrowRight,
  BarChart3,
  Database,
  ExternalLink,
  FileCheck2,
  Layers3,
  ShieldCheck,
  TimerReset
} from "lucide-react";
import { auditHashes, latestLeaderboard, officialSubmissions, rounds, universeOptions } from "../data/fallback";
import { siteConfig } from "../lib/seo";

const currentRound = rounds[0];
const consensusPick = "SEMICONDUCTORS";
const consensusCount = officialSubmissions.filter((row) => row.selected_option_id === consensusPick).length;
const providerCount = new Set(officialSubmissions.map((row) => row.provider)).size;
const publishedArtifactCount = auditHashes.length + officialSubmissions.length + universeOptions.length;
const heroMetrics = [
  { label: "Official submissions", value: `${officialSubmissions.length}/${providerCount} providers` },
  { label: "Frozen universe", value: `${universeOptions.length} options` },
  { label: "Input hashes", value: String(auditHashes.length) },
  { label: "Score state", value: "Pending" }
];
const resultViews = [
  {
    href: "/leaderboards/latest",
    icon: BarChart3,
    label: "Latest Round",
    description: "Newest resolved official one-shot leaderboard.",
    state: "Pending"
  },
  {
    href: "/leaderboards/cumulative-official",
    icon: Layers3,
    label: "Cumulative Official",
    description: "Average official alpha across participated resolved rounds.",
    state: "Separate"
  },
  {
    href: "/leaderboards/cumulative-stability",
    icon: TimerReset,
    label: "Cumulative Stability",
    description: "Repeated-call alpha and consistency, never blended with official results.",
    state: "Separate"
  }
];
const safeguards = [
  {
    icon: ShieldCheck,
    label: "Protocol",
    title: "One official call per model",
    description: "Official picks are not averaged with repeated stability runs, mock output, or private smoke tests."
  },
  {
    icon: Database,
    label: "Audit Read Model",
    title: `${publishedArtifactCount} public rows`,
    description: "Round metadata, options, official submissions, and hashes are mirrored into Supabase for the public site."
  },
  {
    icon: FileCheck2,
    label: "Boundary",
    title: "No performance before resolution",
    description: "Pending pages show decisions and artifacts without implying realized alpha."
  }
];
---

<BaseLayout
  title="CapitalBench - LLM Market Benchmark and Leaderboards"
  description="CapitalBench tests AI models on the same market prompt and frozen data, then publishes their picks, scores, and audit trail."
>
  <section class="home-hero" aria-labelledby="home-title">
    <div class="home-hero-copy">
      <p class="eyebrow">Public AI market benchmark</p>
      <h1 id="home-title">CapitalBench</h1>
      <p class="home-hero-lede">
        CapitalBench tests AI models on real market decisions. Each round gives every model the same prompt and frozen
        data, records the picks before outcomes are known, then publishes the scores and full audit trail.
      </p>
    </div>

    <div class="home-hero-actions" aria-label="Project resources">
      <a
        class="action-link action-primary"
        href={siteConfig.githubUrl}
        target="_blank"
        rel="noreferrer"
        data-analytics-event="github_repository_click"
        data-analytics-param-location="home_hero"
      >
        <GitHubLogo size={17} />
        GitHub repository
        <ExternalLink size={14} aria-hidden="true" />
      </a>
      <a class="action-link" href="/rounds">
        Inspect Round 1
        <ArrowRight size={15} aria-hidden="true" />
      </a>
      <a
        class="action-link"
        href="/methodology"
        data-analytics-event="methodology_click"
        data-analytics-param-location="home_hero"
      >
        Read methodology
      </a>
    </div>

    <div class="home-hero-console" aria-label="Current benchmark state">
      <div class="console-header">
        <div class="console-title">
          <img src="/benchmark-panel.svg" alt="" width="42" height="42" loading="eager" />
          <div>
            <span>Current Public Round</span>
            <strong>{currentRound.round_id}</strong>
          </div>
        </div>
        <span class="status-badge status-pending">Score pending</span>
      </div>

      <div class="console-metrics">
        {heroMetrics.map((metric) => (
          <div>
            <span>{metric.label}</span>
            <strong>{metric.value}</strong>
          </div>
        ))}
      </div>

      <div class="console-ledger" aria-label="Round 1 evidence ledger">
        <div>
          <span>Decision state</span>
          <strong>{consensusCount} of {officialSubmissions.length} models selected {consensusPick}</strong>
        </div>
        <div>
          <span>Resolution gate</span>
          <strong>Exit prices due after {currentRound.exit_date}</strong>
        </div>
        <div>
          <span>Reader promise</span>
          <strong>Research benchmark, not financial advice</strong>
        </div>
      </div>
    </div>
  </section>

  <StatusCards
    roundId={currentRound.round_id}
    status={currentRound.status}
    decisionDeadline={currentRound.decision_deadline_utc}
    entryDate={currentRound.entry_date}
    exitDate={currentRound.exit_date}
    officialRunId={currentRound.official_run_id}
  />

  <section class="phase-band" aria-labelledby="round-progress-title">
    <div class="phase-intro">
      <span class="panel-kicker">Round 1 lifecycle</span>
      <h2 id="round-progress-title">A Clear Line Between Decisions And Performance</h2>
      <p>
        The site distinguishes collected decisions from scored performance. Picks and entry prices are public; realized
        returns remain absent until the exit date resolves.
      </p>
    </div>
    <ol class="phase-list">
      <li class="phase-complete">
        <span>1</span>
        <strong>Inputs frozen</strong>
        <p>Briefing, prompt, universe, and market context hashed before model calls.</p>
      </li>
      <li class="phase-complete">
        <span>2</span>
        <strong>Submissions collected</strong>
        <p>{officialSubmissions.length} valid official one-shot picks are published.</p>
      </li>
      <li class="phase-complete">
        <span>3</span>
        <strong>Entry prices published</strong>
        <p>Entry side is visible for selected options, S&amp;P 500, and cash.</p>
      </li>
      <li class="phase-current">
        <span>4</span>
        <strong>Exit prices pending</strong>
        <p>Performance unlocks after {currentRound.exit_date} prices are collected and scored.</p>
      </li>
    </ol>
  </section>

  <section class="home-section-heading" aria-labelledby="safeguards-title">
    <span class="panel-kicker">Benchmark safeguards</span>
    <h2 id="safeguards-title">Built For Inspection Before Interpretation</h2>
    <p>
      The landing page should make the benchmark's trust model obvious before readers see a score: fixed inputs,
      isolated runs, public hashes, and no provisional alpha.
    </p>
  </section>

  <section class="evidence-grid enhanced" aria-label="Benchmark safeguards">
    {safeguards.map((item) => {
      const Icon = item.icon;
      return (
        <article>
          <div class="evidence-icon" aria-hidden="true">
            <Icon size={19} />
          </div>
          <span class="metric-label">{item.label}</span>
          <h3>{item.title}</h3>
          <p>{item.description}</p>
        </article>
      );
    })}
  </section>

  <nav class="view-switcher enhanced" aria-label="Primary result views">
    {resultViews.map((view) => {
      const Icon = view.icon;
      return (
        <a href={view.href}>
          <span class="view-icon" aria-hidden="true"><Icon size={18} /></span>
          <span class="view-copy">
            <strong>{view.label}</strong>
            <span>{view.description}</span>
          </span>
          <span class="view-state">{view.state}</span>
        </a>
      );
    })}
  </nav>

  <section class="dashboard-grid">
    <div class="panel">
      <div class="panel-header">
        <div>
          <span class="panel-kicker">Current round</span>
          <h2>Official Picks</h2>
          <p>
            All four official Round 1 models selected the same option. The table shows decisions, confidence, rationales,
            and risks without presenting performance while the round is pending.
          </p>
        </div>
        <span class="status-badge status-pending">Pending score</span>
      </div>
      <OfficialPicksTable client:visible fallbackRows={officialSubmissions} roundId={currentRound.round_id} runId={currentRound.official_run_id} />
    </div>

    <aside class="rail" aria-label="Round audit summary">
      <div class="rail-panel highlight-panel">
        <span class="metric-label">Consensus Pick</span>
        <h3>{consensusPick}</h3>
        <p>{consensusCount} of {officialSubmissions.length} official submissions selected Semiconductors.</p>
      </div>
      <div class="rail-panel">
        <span class="metric-label">Methodology</span>
        <h3>{currentRound.methodology_version}</h3>
        <p>One call per model. No tools, browsing, or post-cutoff retrieval.</p>
      </div>
      <div class="rail-panel">
        <span class="metric-label">Audit Surface</span>
        <h3>{auditHashes.length} hashed inputs</h3>
        <p>{universeOptions.length} frozen options. Public hashes and validation metadata are synced to Supabase.</p>
      </div>
      <div class="rail-panel rail-checklist">
        <span class="metric-label">Reader Path</span>
        <ul>
          <li><a href={`/rounds/${currentRound.round_id}/`}>Review the round packet</a></li>
          <li><a href="/universe">Inspect the frozen universe</a></li>
          <li><a href="/fairness">Read fairness controls</a></li>
        </ul>
      </div>
    </aside>
  </section>

  <section class="section resolution-section">
    <div class="panel">
      <div class="panel-header">
        <div>
          <span class="panel-kicker">Latest leaderboard</span>
          <h2>Resolution Pending</h2>
          <p>
            The official leaderboard appears here after exit prices are available, the selected run is scored, and the
            result artifacts are regenerated.
          </p>
        </div>
      </div>
      <LeaderboardTable client:visible fallbackRows={latestLeaderboard} kind="latest" />
    </div>
  </section>
</BaseLayout>
