---
import BaseLayout from "../layouts/BaseLayout.astro";
import GitHubLogo from "../components/GitHubLogo.astro";
import ScoreCountdown from "../components/ScoreCountdown";
import {
  ArrowRight,
  BarChart3,
  Database,
  ExternalLink,
  FileCheck2,
  Layers3,
  ShieldCheck,
  TimerReset
} from "lucide-react";
import { modelLabel, providerLabel, rounds as fallbackRounds } from "../data/fallback";
import {
  allocationThemeClass,
  decisionAllocations,
  formatAllocationPct,
  optionDisplayName
} from "../lib/allocations";
import {
  staticAllOfficialSubmissions,
  staticOfficialSubmissions,
  staticRoundRecords,
  staticUniverseOptions
} from "../lib/localRoundRecords";
import { siteConfig } from "../lib/seo";

const roundRows = staticRoundRecords();
const currentRound = roundRows[0] ?? fallbackRounds[0];
const previousRound = roundRows.find((round) => round.round_id !== currentRound.round_id);
const currentRoundSubmissions = staticOfficialSubmissions(currentRound.round_id, currentRound.official_run_id);
const previousRoundSubmissions = previousRound
  ? staticOfficialSubmissions(previousRound.round_id, previousRound.official_run_id)
  : [];
const allOfficialSubmissions = staticAllOfficialSubmissions(roundRows);
const currentUniverseOptions = staticUniverseOptions(currentRound.round_id);
const currentOptionsById = Object.fromEntries(currentUniverseOptions.map((option) => [option.option_id, option]));
const pendingRoundCount = roundRows.filter((round) => round.status === "pending").length;
const currentRoundUrl = `/rounds/${currentRound.round_id}/`;
const initialNowIso = new Date().toISOString();
const allocationTotals = new Map<string, number>();
for (const submission of currentRoundSubmissions) {
  for (const allocation of decisionAllocations(submission)) {
    allocationTotals.set(allocation.option_id, (allocationTotals.get(allocation.option_id) ?? 0) + allocation.allocation_bps);
  }
}
const currentRoundExposure = Array.from(allocationTotals.entries())
  .map(([optionId, totalBps]) => ({
    optionId,
    averagePct: currentRoundSubmissions.length > 0 ? totalBps / currentRoundSubmissions.length / 100 : 0
  }))
  .sort((a, b) => b.averagePct - a.averagePct)
  .slice(0, 7);
const topExposure = currentRoundExposure[0];
const heroMetrics = [
  { label: "Official rounds", value: String(roundRows.length) },
  { label: "Locked decisions", value: String(allOfficialSubmissions.length) },
  { label: "Latest universe", value: `${currentUniverseOptions.length} assets` },
  { label: "Round horizon", value: currentRound.horizon }
];
const exploreLinks = [
  {
    href: "/leaderboards/latest",
    icon: BarChart3,
    label: "Latest allocations",
    description: "Model portfolios for the newest official round, kept separate from realized performance.",
    state: currentRound.status === "resolved" ? "Scored" : "Pending score"
  },
  {
    href: "/rounds",
    icon: Layers3,
    label: "All rounds",
    description: "Round packets, prompts, model outputs, entry prices, hashes, and status history.",
    state: `${roundRows.length} rounds`
  },
  {
    href: "/methodology",
    icon: TimerReset,
    label: "Methodology",
    description: "Scoring rules, safeguards, data boundaries, and how official runs are separated.",
    state: "Audit"
  }
];
const protocolHighlights = [
  {
    label: "Same inputs",
    title: "Frozen prompt and market packet",
    description: "Every official model receives the same briefing, option universe, dates, and response schema."
  },
  {
    label: "No hindsight",
    title: "Decisions publish before outcomes",
    description: "Allocations are public while score windows remain unresolved."
  },
  {
    label: "Comparable",
    title: "Picks and portfolios normalized",
    description: "Single-pick rounds display as one-holding allocations; portfolio rounds preserve submitted weights."
  },
  {
    label: "Public audit",
    title: "Prompts, outputs, hashes public",
    description: "Readers can inspect inputs, validated outputs, artifacts, and implementation history."
  }
];
const safeguards = [
  {
    icon: ShieldCheck,
    label: "Run isolation",
    title: "One official call per model",
    description: "Official results are never mixed with repeated stability runs, mock output, or provider smoke tests."
  },
  {
    icon: Database,
    label: "Inspection",
    title: `${currentUniverseOptions.length} current options`,
    description: "The current round packet preserves the frozen model-facing universe, prompts, outputs, and audit hashes."
  },
  {
    icon: FileCheck2,
    label: "Score boundary",
    title: `${pendingRoundCount} pending score windows`,
    description: "Realized alpha appears only after exit prices are collected and the scorer publishes official results."
  }
];
---

<BaseLayout
  title="CapitalBench - LLM Market Benchmark and Leaderboards"
  description="CapitalBench measures capital allocation ability across leading AI models using real public-market outcomes."
>
  <section class="home-hero" aria-labelledby="home-title">
    <div class="home-hero-copy">
      <p class="eyebrow">Auditable AI market benchmark</p>
      <h1 id="home-title">CapitalBench</h1>
      <p class="home-hero-lede">
        CapitalBench measures capital allocation ability across leading AI models using real public-market outcomes. It
        is time-locked and auditable: models receive identical frozen inputs, commit before results are known, and are
        scored only after market prices settle.
      </p>
      <p class="hero-disclaimer">Benchmark and research project. Not financial advice.</p>
    </div>

    <div class="home-hero-actions" aria-label="Project resources">
      <a class="action-link action-primary" href={currentRoundUrl}>
        View latest round
        <ArrowRight size={15} aria-hidden="true" />
      </a>
      <a class="action-link" href="/rounds">See all rounds</a>
      <a
        class="action-link"
        href={siteConfig.githubUrl}
        target="_blank"
        rel="noreferrer"
        data-analytics-event="github_repository_click"
        data-analytics-param-location="home_hero"
      >
        <GitHubLogo size={17} />
        GitHub repository
        <ExternalLink size={14} aria-hidden="true" />
      </a>
    </div>

    <div class="home-hero-console" aria-label="Current benchmark state">
      <div class="console-header">
        <div class="console-title">
          <img src="/benchmark-panel.svg" alt="" width="42" height="42" loading="eager" />
          <div>
            <span>Latest Official Round</span>
            <strong>{currentRound.round_id}</strong>
          </div>
        </div>
        <span class="status-badge status-pending">Score pending</span>
      </div>

      <div class="console-metrics">
        {heroMetrics.map((metric) => (
          <div>
            <span>{metric.label}</span>
            <strong>{metric.value}</strong>
          </div>
        ))}
      </div>

      <div class="console-ledger" aria-label="Benchmark evidence ledger">
        <div>
          <span>Latest protocol</span>
          <strong>{currentRound.methodology_version} with {currentRoundSubmissions.length} official portfolios</strong>
        </div>
        <ScoreCountdown
          client:load
          variant="hero"
          label="Settlement target"
          scoreEtaUtc={currentRound.score_eta_utc}
          source={currentRound.score_eta_source}
          status={currentRound.status}
          exitDate={currentRound.exit_date}
          initialNowIso={initialNowIso}
          showRemaining={false}
          metaText="After market close once exit prices are available"
        />
        <div>
          <span>Audit trail</span>
          <strong>{allOfficialSubmissions.length} decisions, public prompts, outputs, hashes, and repo history</strong>
        </div>
      </div>
    </div>
  </section>

  <section class="trust-strip" aria-label="Benchmark protocol snapshot">
    {protocolHighlights.map((item) => (
      <article>
        <span>{item.label}</span>
        <strong>{item.title}</strong>
        <p>{item.description}</p>
      </article>
    ))}
  </section>

  <section class="home-section-heading" aria-labelledby="latest-allocation-title">
    <span class="panel-kicker">Latest round</span>
    <h2 id="latest-allocation-title">Latest Round: Models Built Portfolios</h2>
    <p>
      The latest portfolio round allowed 1-5 holdings in 5% increments across {currentUniverseOptions.length} assets.
      Scores remain pending until the {currentRound.exit_date} exit prices are collected.
    </p>
    <div class="round-meta-row" aria-label="Latest round summary">
      <span>{currentRound.round_id}</span>
      <span>{currentRoundSubmissions.length} official portfolios</span>
      <span>{currentUniverseOptions.length} assets</span>
      <span>Pending score</span>
    </div>
  </section>

  <section class="allocation-showcase" aria-label="Latest round model allocations">
    <div class="allocation-board">
      {currentRoundSubmissions.map((submission) => {
        const allocations = decisionAllocations(submission);
        return (
          <article class="allocation-card">
            <div class="allocation-card-head">
              <div>
                <span class={`provider-badge provider-${submission.provider}`}>{providerLabel(submission.provider)}</span>
                <h3>{modelLabel(submission.model_id)}</h3>
                <p class="mono">{submission.model_id}</p>
              </div>
              <span class="badge badge-amber">Pending score</span>
            </div>
            <div class="allocation-stack" aria-hidden="true">
              {allocations.map((allocation) => (
                <span
                  class={allocationThemeClass(allocation.option_id)}
                  style={`width: ${Math.max(3, allocation.allocation_pct)}%`}
                  title={`${optionDisplayName(allocation.option_id, currentOptionsById)} ${formatAllocationPct(allocation.allocation_pct)}`}
                />
              ))}
            </div>
            <ul class="allocation-list">
              {allocations.map((allocation) => (
                <li>
                  <span class={`allocation-dot ${allocationThemeClass(allocation.option_id)}`}></span>
                  <strong>{optionDisplayName(allocation.option_id, currentOptionsById)}</strong>
                  <span>{formatAllocationPct(allocation.allocation_pct)}</span>
                </li>
              ))}
            </ul>
          </article>
        );
      })}
    </div>

    <aside class="allocation-summary" aria-label="Latest round allocation summary">
      <span class="panel-kicker">Aggregate exposure</span>
      <h3>Where The Latest Round Concentrated</h3>
      <p>
        Average allocations below aggregate the latest official portfolios before realized performance is scored.
      </p>
      <div class="exposure-bars">
        {currentRoundExposure.map((item) => (
          <div class="exposure-bar-row">
            <span>{optionDisplayName(item.optionId, currentOptionsById)}</span>
            <div class="exposure-bar-track" aria-hidden="true">
              <span
                class={allocationThemeClass(item.optionId)}
                style={`width: ${topExposure ? Math.max(4, (item.averagePct / topExposure.averagePct) * 100) : 0}%`}
              />
            </div>
            <strong>{formatAllocationPct(item.averagePct)}</strong>
          </div>
        ))}
      </div>
      <a class="action-link" href="/leaderboards/latest">View full allocation table</a>
    </aside>
  </section>

  <section class="phase-band" aria-labelledby="round-progress-title">
    <div class="phase-intro">
      <span class="panel-kicker">{roundRows.length}-round record</span>
      <h2 id="round-progress-title">Published First, Scored After Settlement</h2>
      <p>
        Official decisions are locked before outcomes. Performance appears only after each pre-declared exit close is
        priced and scored.
      </p>
    </div>
    <ol class="phase-list">
      <li class="phase-complete">
        <span>1</span>
        <strong>Previous round locked</strong>
        <p>{previousRound?.round_id ?? "Previous round"} has {previousRoundSubmissions.length} public official decisions.</p>
      </li>
      <li class="phase-complete">
        <span>2</span>
        <strong>Latest round locked</strong>
        <p>{currentRoundSubmissions.length} valid official portfolios are public.</p>
      </li>
      <li class="phase-current">
        <span>3</span>
        <strong>Previous settlement target</strong>
        <p>Target: {previousRound?.exit_date ?? "declared exit date"} after market close.</p>
      </li>
      <li class="phase-current">
        <span>4</span>
        <strong>Latest settlement target</strong>
        <p>Target: {currentRound.exit_date} after market close.</p>
      </li>
    </ol>
  </section>

  <nav class="view-switcher enhanced" aria-label="Explore CapitalBench">
    {exploreLinks.map((view) => {
      const Icon = view.icon;
      return (
        <a href={view.href}>
          <span class="view-icon" aria-hidden="true"><Icon size={18} /></span>
          <span class="view-copy">
            <strong>{view.label}</strong>
            <span>{view.description}</span>
          </span>
          <span class="view-state">{view.state}</span>
        </a>
      );
    })}
  </nav>

  <section class="audit-preview" aria-labelledby="audit-preview-title">
    <div>
      <span class="panel-kicker">Audit snapshot</span>
      <h2 id="audit-preview-title">Inspect The Full Round Record</h2>
      <p>
        The homepage previews the current state. The round page carries the detailed evidence: model-facing input,
        prompts, parsed outputs, entry prices, source reports, and hashes.
      </p>
    </div>
    <div class="audit-preview-actions">
      <a class="action-link action-primary" href={currentRoundUrl}>Open latest round packet</a>
      <a class="action-link" href="/leaderboards/latest">Review all official allocations</a>
      <a class="action-link" href={siteConfig.githubUrl} target="_blank" rel="noreferrer">
        <GitHubLogo size={15} />
        Repository
      </a>
    </div>
  </section>

  <section class="home-section-heading" aria-labelledby="safeguards-title">
    <span class="panel-kicker">Benchmark safeguards</span>
    <h2 id="safeguards-title">Built For Public Audit, Not Advice</h2>
    <p>
      The trust model is deliberately simple: fixed inputs, isolated official runs, public hashes, and no provisional
      performance claims before the scoring window resolves.
    </p>
  </section>

  <section class="evidence-grid enhanced" aria-label="Benchmark safeguards">
    {safeguards.map((item) => {
      const Icon = item.icon;
      return (
        <article>
          <div class="evidence-icon" aria-hidden="true">
            <Icon size={19} />
          </div>
          <span class="metric-label">{item.label}</span>
          <h3>{item.title}</h3>
          <p>{item.description}</p>
        </article>
      );
    })}
  </section>

  <section class="resolution-callout" aria-labelledby="resolution-title">
    <div>
      <span class="panel-kicker">Latest leaderboard</span>
      <h2 id="resolution-title">Scores Publish After Settlement</h2>
      <p>
        No official performance table is live yet. Until exit prices are available, CapitalBench shows decisions and
        audit artifacts without implying realized returns.
      </p>
    </div>
    <a class="action-link" href="/scoring">Read scoring rules</a>
  </section>
</BaseLayout>
