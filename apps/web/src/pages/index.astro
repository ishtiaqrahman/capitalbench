                </span>
              ) : (
                <span class="leaderboard-lane-logo leaderboard-lane-logo-empty">{track.label.slice(0, 1)}</span>
              )}
              <div>
                <span>{track.leader ? "Full-history leader" : "Current state"}</span>
                <strong>{track.leader?.label ?? "Waiting for first result"}</strong>
                <em>
                  {track.leaderScore
                    ? `${track.leaderScore} score · ${track.resolvedScoreCount} resolved round${track.resolvedScoreCount === 1 ? "" : "s"}`
                    : scoreShortLine(track.latestLiveRound)}
                </em>
              </div>
            </div>

            <div class={`leaderboard-lane-facts ${track.leader ? "" : "leaderboard-lane-facts-pending"}`}>
              <span>
                <em>Latest scored</em>
                <strong>{track.latestScoredLabel}</strong>
              </span>
              <span>
                <em>Live round</em>
                <strong>{track.latestLiveLabel}</strong>
              </span>
              <span>
                <em>Next score</em>
                <strong>{track.nextScoreLabel}</strong>
              </span>
            </div>

            <ol class="leaderboard-lane-flow" aria-label={`${track.label} scoring flow`}>
              <li class={track.round ? "is-complete" : ""}><span></span>Locked</li>
              <li class={track.latestLiveRound ? "is-current" : track.latestResolvedRound ? "is-complete" : ""}><span></span>Live</li>
              <li class={track.latestResolvedRound ? "is-complete" : ""}><span></span>Scores</li>
            </ol>
          </div>

          <div class="leaderboard-lane-actions">
            <a class="small-button" href={track.latestHref}>Latest {track.label.toLowerCase()}</a>
            <a class="small-button" href={track.cumulativeHref}>Overall {track.label.toLowerCase()}</a>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="home-section-heading track-summary-heading" aria-labelledby="current-tests-title">
    <span class="panel-kicker">Live benchmark tests</span>
    <h2 id="current-tests-title">Live Benchmark Tests</h2>
    <p>
      These are the open tests you can inspect now. Models already submitted portfolios; official scores wait for final
      closing prices.
    </p>
  </section>

  <section class="track-summary live-test-summary" aria-label="Live weekly and monthly benchmark tests">
    {trackStates.map((track) => (
      <article class={`track-card track-card-${track.key} live-test-card`}>
        <div class="track-card-head">
          <div>
            <span class="panel-kicker">{track.label} test</span>
            <h3>{track.horizonLabel}</h3>
          </div>
          <span class={`status-badge ${statusClass(track.round)}`}>{calendarStatusLabel(track.round)}</span>
        </div>
        {track.round ? (
          <>
            <p class="live-test-description">{liveTestDescription(track.key)}</p>
            <p class="live-test-state">{liveTestStateLabel(track.round)}</p>
            <div class="track-card-grid live-test-grid">
              <span>Model portfolios <strong>{track.submissions.length}</strong></span>
              <span>Eligible assets <strong>{track.options.length}</strong></span>
              <span>Risk-taking score <strong>{liveTrackRiskScore(track.key)}<small>/100</small></strong></span>
              <span>
                Top consensus
                <strong>{topConsensusLabel(track)}</strong>
                {track.topExposure && <small>{formatAllocationPct(track.topExposure.averagePct)} average weight</small>}
              </span>
            </div>
          </>
        ) : (
          <p class="live-test-description">No {track.label.toLowerCase()} test is live yet.</p>
        )}
        <div class="track-card-actions live-test-actions">
          <a class="small-button" href="#current-picks">View portfolios</a>
          <a class="small-button" href="/universe">Asset universe</a>
          {track.roundHref && <a class="small-button" href={track.roundHref}>Audit packet</a>}
        </div>
      </article>
    ))}
    <p class="live-test-footnote">Internal IDs and full reproducibility files are inside each audit packet.</p>
  </section>

  <section class="timeline-lanes scoring-calendar" aria-labelledby="track-timeline-title">
    <div class="home-section-heading">
      <span class="panel-kicker">Scoring calendar</span>
      <h2 id="track-timeline-title">Current Scoring Calendar</h2>
      <p>
        Models have already picked portfolios. Official scores publish only after the market window ends and final closing
        prices are available.
      </p>
    </div>
    <div class="timeline-lane-grid scoring-calendar-grid">
      {trackStates.map((track) => (
        <article class={`timeline-lane scoring-calendar-card scoring-calendar-card-${track.key}`}>
          <div class="timeline-lane-head scoring-calendar-head">
            <div>
              <span class="panel-kicker">{track.label} test</span>
              <strong>{track.horizonLabel}</strong>
            </div>
            <span class={`status-badge ${statusClass(track.round)}`}>{calendarStatusLabel(track.round)}</span>
          </div>
          {track.round ? (
            <>
              <p class="scoring-calendar-summary">
                {track.submissions.length} model portfolio{track.submissions.length === 1 ? "" : "s"} locked and waiting for official scoring.
              </p>
              <dl class="scoring-calendar-facts">
                <div>
                  <dt>Locked</dt>
                  <dd>{lockDateLabel(track.round)}</dd>
                </div>
                <div>
                  <dt>Market window</dt>
                  <dd>{marketWindowCalendarLabel(track.round)}</dd>
                </div>
                <div>
                  <dt>Official score</dt>
                  <dd>{calendarScoreDateLabel(track.round)}</dd>
                </div>
              </dl>
              <div class="track-card-actions scoring-calendar-actions">
                <a class="small-button" href="#current-picks">View current portfolios</a>
                <a class="small-button" href={track.latestHref}>See latest results</a>
                <a class="small-button" href="#score-alert-panel-home" data-score-alert-trigger>Get score alert</a>
              </div>
            </>
          ) : (
            <p class="scoring-calendar-summary">No {track.label.toLowerCase()} test is live yet.</p>
          )}
        </article>
      ))}
    </div>
    <div class="scoring-calendar-record">
      <div>
        <strong>{roundRows.length} official rounds recorded</strong>
        <span>Internal round and run IDs stay in the public audit trail.</span>
      </div>
      <a class="small-button" href="/rounds">View audit trail</a>
    </div>
  </section>

  <nav class="view-switcher enhanced" aria-label="Explore CapitalBench">
    {exploreLinks.map((view) => {
      const Icon = view.icon;
      return (
        <a href={view.href}>
          <span class="view-icon" aria-hidden="true"><Icon size={18} /></span>
          <span class="view-copy">
            <strong>{view.label}</strong>
            <span>{view.description}</span>
          </span>
          <span class="view-state">{view.state}</span>
        </a>
      );
    })}
  </nav>

  <section class="audit-preview" id="proof-and-data" aria-labelledby="audit-preview-title">
    <div>
      <span class="panel-kicker">Audit packet</span>
      <h2 id="audit-preview-title">Check The Public Audit Trail</h2>
      <p>
        Round pages show the report, prompt, model portfolios, starting prices, source reports, hashes, and result status
        behind each public benchmark round.
      </p>
    </div>
    <div class="audit-preview-actions">
      {latestWeeklyRound && <a class="action-link action-primary" href={`/rounds/${latestWeeklyRound.round_id}/`}>Open weekly audit packet</a>}
      {latestMonthlyRound && <a class="action-link" href={`/rounds/${latestMonthlyRound.round_id}/`}>Open monthly audit packet</a>}
      <a class="action-link" href="/rounds">View all rounds</a>
      <a class="action-link" href={siteConfig.githubUrl} target="_blank" rel="noreferrer">
        <GitHubLogo size={15} />
        Repository
      </a>
    </div>
  </section>

  <section class="home-section-heading" aria-labelledby="safeguards-title">
    <span class="panel-kicker">Why it is fair</span>
    <h2 id="safeguards-title">Simple Rules, Public Audit Trail</h2>
    <p>
      CapitalBench keeps the comparison narrow: same report, same asset list, frozen portfolios, and no final result before
      the round ends.
    </p>
  </section>

  <section class="evidence-grid enhanced" aria-label="Benchmark safeguards">
    {safeguards.map((item) => {
      const Icon = item.icon;
      return (
        <article>
          <div class="evidence-icon" aria-hidden="true">
            <Icon size={19} />
          </div>
          <span class="metric-label">{item.label}</span>
          <h3>{item.title}</h3>
          <p>{item.description}</p>
        </article>
      );
    })}
  </section>
</BaseLayout>
