---
import BaseLayout from "../layouts/BaseLayout.astro";
import ActiveExposureMap from "../components/ActiveExposureMap";
import GitHubLogo from "../components/GitHubLogo.astro";
import ScoreReturnChart from "../components/ScoreReturnChart.astro";
import {
  ArrowRight,
  BarChart3,
  ClipboardCheck,
  Database,
  FileCheck2,
  Layers3,
  LineChart,
  LockKeyhole,
  ShieldCheck,
  TimerReset
} from "lucide-react";
import {
  modelLabel,
  providerLabel,
  rounds as fallbackRounds,
  type RoundRecord,
  type SubmissionRecord,
  type UniverseOption
} from "../data/fallback";
import {
  allocationThemeClass,
  decisionAllocations,
  formatAllocationPct,
  optionDisplayName,
  optionShortDisplayName
} from "../lib/allocations";
import { dateOnly } from "../lib/format";
import {
  staticAllOfficialSubmissions,
  staticOfficialSubmissions,
  staticRoundAllocations,
  staticRoundLeaderboard,
  staticRoundReturns,
  staticRoundRecords,
  staticUniverseOptions
} from "../lib/localRoundRecords";
import { buildScoreReturnChartData, providerLogoSrc } from "../lib/scoreReturnChart";
import { buildRunConcentration, type ConcentrationAsset, type RunConcentration } from "../lib/runConcentration";
import { siteConfig } from "../lib/seo";
import { staticModelProfiles } from "../lib/modelProfiles";
import {
  latestResolvedRoundForTrack,
  latestRoundForTrack,
  roundTrack,
  roundsForTrack,
  type BenchmarkTrack
} from "../lib/tracks";

type TrackHomeState = {
  key: BenchmarkTrack;
  label: string;
  horizonLabel: string;
  round?: RoundRecord;
  submissions: SubmissionRecord[];
  options: UniverseOption[];
  optionsById: Record<string, UniverseOption | undefined>;
  concentration: RunConcentration;
  exposures: ConcentrationAsset[];
  topExposure?: ConcentrationAsset;
  latestHref: string;
  cumulativeHref: string;
  roundHref?: string;
  roundCount: number;
};

const roundRows = staticRoundRecords();
const weeklyRounds = roundsForTrack(roundRows, "weekly");
const monthlyRounds = roundsForTrack(roundRows, "monthly");
const latestWeeklyRound = latestRoundForTrack(roundRows, "weekly");
const latestMonthlyRound = latestRoundForTrack(roundRows, "monthly");
const latestResolvedWeeklyRound = latestResolvedRoundForTrack(roundRows, "weekly");
const latestResolvedMonthlyRound = latestResolvedRoundForTrack(roundRows, "monthly");
const modelProfiles = staticModelProfiles();
const allOfficialSubmissions = staticAllOfficialSubmissions(roundRows);
const pendingRoundCount = roundRows.filter((round) => round.status === "pending").length;

function buildTrackState(
  key: BenchmarkTrack,
  label: string,
  horizonLabel: string,
  round: RoundRecord | undefined,
  roundCount: number
): TrackHomeState {
  const submissions = round ? staticOfficialSubmissions(round.round_id, round.official_run_id) : [];
  const options = round ? staticUniverseOptions(round.round_id) : [];
  const optionsById = Object.fromEntries(options.map((option) => [option.option_id, option]));
  const concentration = buildRunConcentration(submissions, optionsById);
  const exposures = concentration.assets.slice(0, 6);
  return {
    key,
    label,
    horizonLabel,
    round,
    submissions,
    options,
    optionsById,
    concentration,
    exposures,
    topExposure: concentration.topAsset,
    latestHref: `/leaderboards/latest-${key}`,
    cumulativeHref: `/leaderboards/cumulative-${key}`,
    roundHref: round ? `/rounds/${round.round_id}/` : undefined,
    roundCount
  };
}

const trackStates = [
  buildTrackState("weekly", "Weekly", "One-week test", latestWeeklyRound, weeklyRounds.length),
  buildTrackState("monthly", "Monthly", "One-month test", latestMonthlyRound, monthlyRounds.length)
];
const publishedResults = [
  {
    key: "weekly" as const,
    label: "Weekly",
    round: latestResolvedWeeklyRound,
    leaderboard: latestResolvedWeeklyRound
      ? staticRoundLeaderboard(latestResolvedWeeklyRound.round_id, latestResolvedWeeklyRound.official_run_id)
      : []
  },
  {
    key: "monthly" as const,
    label: "Monthly",
    round: latestResolvedMonthlyRound,
    leaderboard: latestResolvedMonthlyRound
      ? staticRoundLeaderboard(latestResolvedMonthlyRound.round_id, latestResolvedMonthlyRound.official_run_id)
      : []
  }
].map((item) => ({ ...item, winner: item.leaderboard[0] }));
const completedPublishedResults = publishedResults
  .filter((result) => result.round && result.winner)
  .sort((a, b) => (b.round?.exit_date ?? "").localeCompare(a.round?.exit_date ?? ""));
const latestPublishedResult = completedPublishedResults[0];
const latestCompletedRound = latestPublishedResult?.round;
const latestCompletedWinner = latestPublishedResult?.winner;
const latestResultOptions = latestCompletedRound ? staticUniverseOptions(latestCompletedRound.round_id) : [];
const latestResultOptionsById: Record<string, UniverseOption | undefined> = Object.fromEntries(
  latestResultOptions.map((option) => [option.option_id, option])
);
const latestResultReturns = latestCompletedRound
  ? staticRoundReturns(latestCompletedRound.round_id, latestCompletedRound.official_run_id)
  : [];
const latestResultAllocations = latestCompletedRound
  ? staticRoundAllocations(latestCompletedRound.round_id, latestCompletedRound.official_run_id)
  : [];
const latestScoreChart = buildScoreReturnChartData({
  leaderboard: latestPublishedResult?.leaderboard ?? [],
  returns: latestResultReturns,
  optionsById: latestResultOptionsById,
  allocations: latestResultAllocations
});
const latestResultEligibleAssetCount = latestResultOptions.length;
const activeExposureRounds = roundRows
  .filter((round) => round.status === "pending" && round.official_run_id)
  .map((round) => {
    const track = roundTrack(round);
    return {
      round,
      track,
      submissions: staticOfficialSubmissions(round.round_id, round.official_run_id),
      options: staticUniverseOptions(round.round_id)
    };
  })
  .filter((item) => (item.track === "weekly" || item.track === "monthly") && item.submissions.length > 0);
const riskAppetiteProfiles = [...modelProfiles]
  .filter((profile) => profile.fingerprint.riskAppetite.score !== null)
  .sort(
    (a, b) =>
      (a.fingerprint.riskAppetite.score ?? 0) - (b.fingerprint.riskAppetite.score ?? 0) ||
      a.label.localeCompare(b.label)
  );
const riskScores = riskAppetiteProfiles
  .map((profile) => profile.fingerprint.riskAppetite.score)
  .filter((score): score is number => score !== null && Number.isFinite(score));
const riskMinScore = riskScores.length > 0 ? Math.min(...riskScores) : null;
const riskMaxScore = riskScores.length > 0 ? Math.max(...riskScores) : null;
const rawRiskRange = riskMinScore !== null && riskMaxScore !== null ? riskMaxScore - riskMinScore : 0;
const riskFocusPadding = Math.max(0.06, Math.min(0.18, rawRiskRange * 0.18));
let riskFocusMin = riskMinScore !== null ? Math.max(1, riskMinScore - riskFocusPadding) : 1;
let riskFocusMax = riskMaxScore !== null ? Math.min(5, riskMaxScore + riskFocusPadding) : 5;
if (riskFocusMax - riskFocusMin < 0.36) {
  const center = riskMinScore !== null && riskMaxScore !== null ? (riskMinScore + riskMaxScore) / 2 : 3;
  riskFocusMin = Math.max(1, center - 0.18);
  riskFocusMax = Math.min(5, center + 0.18);
  if (riskFocusMax - riskFocusMin < 0.36) {
    if (riskFocusMin <= 1) riskFocusMax = Math.min(5, riskFocusMin + 0.36);
    if (riskFocusMax >= 5) riskFocusMin = Math.max(1, riskFocusMax - 0.36);
  }
}
const lowestRiskProfile = riskAppetiteProfiles[0];
const highestRiskProfile = riskAppetiteProfiles[riskAppetiteProfiles.length - 1];
const riskLabelSet = Array.from(new Set(riskAppetiteProfiles.map((profile) => profile.fingerprint.riskAppetite.label)));
const riskClusterLabel = riskLabelSet.length === 1 ? `All ${riskLabelSet[0]}` : riskLabelSet.join(" / ");
const riskPortfolioCount = riskAppetiteProfiles.reduce((total, profile) => total + profile.fingerprint.portfolioCount, 0);
const latestUniverseOptionCount = Math.max(0, ...trackStates.map((track) => track.options.length));
const currentRound = latestMonthlyRound ?? latestWeeklyRound ?? roundRows[0] ?? fallbackRounds[0];
const currentUniverseOptionCount = latestUniverseOptionCount || staticUniverseOptions(currentRound.round_id).length;
const modelRoster = Array.from(new Map(allOfficialSubmissions.map((submission) => [submission.model_id, submission])).values())
  .sort((a, b) => providerLabel(a.provider).localeCompare(providerLabel(b.provider)));
const scoringWindows = [
  { label: "Weekly", value: "One market week" },
  { label: "Monthly", value: "One market month" }
];
const exploreLinks = [
  {
    href: "/leaderboards/latest",
    icon: BarChart3,
    label: "Latest results",
    description: "See the newest weekly and monthly scoreboards.",
    state: "Scoreboards"
  },
  {
    href: "/rounds",
    icon: Layers3,
    label: "All test rounds",
    description: "Open each test's picks, dates, prices, and proof files.",
    state: `${roundRows.length} tests`
  },
  {
    href: "/scoring",
    icon: TimerReset,
    label: "How scoring works",
    description: "Returns are compared with the S&P 500 over the same period.",
    state: "Simple math"
  }
];
const heroProofSteps = [
  {
    icon: ClipboardCheck,
    title: "Same brief",
    detail: "Brief and ETF list"
  },
  {
    icon: LockKeyhole,
    title: "Locked picks",
    detail: "Saved before scoring"
  },
  {
    icon: LineChart,
    title: "Real prices",
    detail: "Closing prices score"
  }
];
const howItWorks = [
  {
    label: "1",
    title: "Same information",
    description: "Every model gets the same market brief and the same asset list."
  },
  {
    label: "2",
    title: "Models pick portfolios",
    description: "The picks are saved before the result is known."
  },
  {
    label: "3",
    title: "Markets decide",
    description: "Real prices decide which portfolio did best."
  },
  {
    label: "Proof",
    title: "You can check the run",
    description: "Prompts, model outputs, prices, and hashes are public."
  }
];
const safeguards = [
  {
    icon: ShieldCheck,
    label: "Same rules",
    title: "One public pick per model",
    description: "The public score uses the saved portfolio for that test, not private retries or experiments."
  },
  {
    icon: Database,
    label: "Same choices",
    title: `${latestUniverseOptionCount} current assets`,
    description: "Each test keeps the exact asset list, prompt, model outputs, starting prices, and proof hashes."
  },
  {
    icon: FileCheck2,
    label: "No early winner",
    title: `${pendingRoundCount} tests waiting for scores`,
    description: "Final returns appear only after ending prices are available."
  }
];

function statusLabel(round?: RoundRecord): string {
  if (!round) return "Not started";
  if (round.status === "resolved") return "Scored";
  if (round.status === "archived") return "Archived";
  return "Pending score";
}

function statusClass(round?: RoundRecord): string {
  return round ? `status-${round.status}` : "status-archived";
}

function windowLabel(round?: RoundRecord): string {
  if (!round) return "Awaiting first round";
  return `${dateOnly(round.entry_date)} to ${dateOnly(round.exit_date)}`;
}

function scoreLine(round?: RoundRecord): string {
  if (!round) return "No score window declared yet.";
  if (round.status === "resolved") return "Scores are published.";
  return `Scores publish after the ${dateOnly(round.exit_date)} ending close.`;
}

function shortMonthDay(value?: string): string {
  if (!value) return "";
  const [year, month, day] = value.slice(0, 10).split("-").map(Number);
  if (!year || !month || !day) return dateOnly(value);
  return new Intl.DateTimeFormat("en-US", { month: "short", day: "numeric", timeZone: "UTC" }).format(
    new Date(Date.UTC(year, month - 1, day))
  );
}

function scoreShortLine(round?: RoundRecord): string {
  if (!round) return "No score date";
  if (round.status === "resolved") return "Scored";
  return `Scores after ${shortMonthDay(round.exit_date)} close`;
}

function modelProfileHref(modelId: string): string {
  return `/models/${modelId}/#live-holdings`;
}

function modelFingerprintHref(modelId: string): string {
  return `/models/${modelId}/#model-fingerprint`;
}

function pctValue(value: number | null | undefined): string {
  if (value === null || value === undefined || !Number.isFinite(value)) return "n/a";
  if (Math.abs(value) >= 10) return `${value.toFixed(1)}%`;
  if (Math.abs(value) >= 1) return `${value.toFixed(1)}%`;
  return `${value.toFixed(2)}%`;
}

function riskScoreValue(value: number | null | undefined): string {
  if (value === null || value === undefined || !Number.isFinite(value)) return "n/a";
  return `${value.toFixed(2)} / 5`;
}

function riskScoreShort(value: number | null | undefined): string {
  if (value === null || value === undefined || !Number.isFinite(value)) return "n/a";
  return value.toFixed(2);
}

function riskWidth(value: number | null | undefined): string {
  if (value === null || value === undefined || !Number.isFinite(value)) return "0%";
  return `${Math.min(100, Math.max(0, value)).toFixed(2)}%`;
}

function riskFocusWidth(value: number | null | undefined): string {
  if (value === null || value === undefined || !Number.isFinite(value)) return "0%";
  const denominator = riskFocusMax - riskFocusMin;
  if (denominator <= 0) return "50%";
  return riskWidth(((value - riskFocusMin) / denominator) * 100);
}

function topHoldings(submission: SubmissionRecord, optionsById: TrackHomeState["optionsById"]): string {
  const allocations = decisionAllocations(submission)
    .sort((a, b) => b.allocation_bps - a.allocation_bps);
  if (allocations.length === 0) return "No allocation";
  return allocations
    .map((allocation) => `${optionShortDisplayName(allocation.option_id, optionsById)} ${formatAllocationPct(allocation.allocation_pct)}`)
    .join(", ");
}
---

<BaseLayout
  title="CapitalBench - AI Market Picks Scoreboard"
  description="CapitalBench gives AI models the same market information, records their portfolios, and scores them using real market returns."
>
  <section class="home-hero" aria-labelledby="home-title">
    <div class="home-hero-copy">
      <p class="eyebrow">CapitalBench</p>
      <h1 id="home-title">Benchmarking AI Models With Public Market Portfolios</h1>
      <p class="home-hero-lede">
        Same brief. Same ETF list. Each model picks a portfolio. Real prices decide the score.
      </p>
      <p class="hero-disclaimer">Research benchmark. Not financial advice.</p>

      <div class="home-hero-actions" aria-label="Project resources">
        <a class="action-link action-primary" href="/leaderboards/latest">
          Latest scores
          <ArrowRight size={15} aria-hidden="true" />
        </a>
        <a class="action-link" href="#active-exposure">Active portfolios</a>
        <a class="action-link" href="#how-it-works">Scoring rules</a>
        <a class="action-link" href="#proof-and-data">Proof files</a>
      </div>

      <div class="hero-proof-strip" aria-label="How the test works">
        <div class="hero-proof-strip-head">
          <span>How it works</span>
          <strong>Brief. Picks. Prices.</strong>
        </div>
        <ol class="hero-proof-steps">
          {heroProofSteps.map((step, index) => {
            const Icon = step.icon;
            return (
              <li class={`hero-proof-step hero-proof-step-${index + 1}`}>
                <span class="hero-proof-icon" aria-hidden="true">
                  <Icon size={16} />
                </span>
                <span class="hero-proof-copy">
                  <strong>{step.title}</strong>
                  <span>{step.detail}</span>
                </span>
              </li>
            );
          })}
        </ol>
      </div>
    </div>

    <div class="home-hero-console" aria-label="Benchmark snapshot">
      <div class="console-header">
        <div class="console-title">
          <img src="/benchmark-panel.svg" alt="" width="42" height="42" loading="eager" />
          <div>
            <span>Benchmark snapshot</span>
            <strong>Models, timelines, assets, open tests</strong>
          </div>
        </div>
        <span class="status-badge status-pending">Live</span>
      </div>

      <div class="snapshot-body">
        <section class="snapshot-section snapshot-models" aria-labelledby="snapshot-models-title">
          <div class="snapshot-section-head">
            <span id="snapshot-models-title">Models compared</span>
            <strong>{modelRoster.length} official models</strong>
          </div>
          <div class="snapshot-model-list" aria-label="Official model roster">
            {modelRoster.map((submission) => (
              <a
                class={`snapshot-model-chip snapshot-model-${submission.provider}`}
                href={modelProfileHref(submission.model_id)}
                aria-label={`${providerLabel(submission.provider)}: ${modelLabel(submission.model_id)}`}
              >
                {providerLogoSrc(submission.provider) ? (
                  <img
                    class="snapshot-lab-logo"
                    src={providerLogoSrc(submission.provider)}
                    alt={providerLabel(submission.provider)}
                    width="40"
                    height="40"
                    loading="eager"
                  />
                ) : (
                  <span>{providerLabel(submission.provider)}</span>
                )}
                <strong>{modelLabel(submission.model_id)}</strong>
              </a>
            ))}
          </div>
        </section>

        <div class="snapshot-split">
          <section class="snapshot-section" aria-labelledby="snapshot-windows-title">
            <div class="snapshot-section-head">
              <span id="snapshot-windows-title">Scoring windows</span>
              <strong>Close-to-close</strong>
            </div>
            <div class="snapshot-window-list">
              {scoringWindows.map((window) => (
                <span>
                  <strong>{window.label}</strong>
                  <span>{window.value}</span>
                </span>
              ))}
            </div>
          </section>

          <section class="snapshot-section" aria-labelledby="snapshot-assets-title">
            <div class="snapshot-section-head">
              <span id="snapshot-assets-title">Asset choices</span>
              <strong>{currentUniverseOptionCount} public-market assets</strong>
            </div>
            <p>ETFs, sectors, themes, commodities, bonds, cash, and benchmarks.</p>
            <a href="/universe">View asset list</a>
          </section>
        </div>

        <section class="snapshot-section snapshot-rounds" aria-labelledby="snapshot-rounds-title">
          <div class="snapshot-section-head">
            <span id="snapshot-rounds-title">Latest test windows</span>
            <strong>{pendingRoundCount} pending score{pendingRoundCount === 1 ? "" : "s"}</strong>
          </div>
          <div class="snapshot-round-list">
            {trackStates.map((track) => (
              <a href={track.roundHref ?? "/rounds"}>
                <span>{track.label}</span>
                <strong>{track.round?.round_id ?? "Not started"}</strong>
                <em>{scoreShortLine(track.round)}</em>
              </a>
            ))}
          </div>
        </section>
      </div>
    </div>
  </section>

  {latestPublishedResult && latestCompletedRound && latestCompletedWinner && (
    <>
      <section class="home-section-heading" aria-labelledby="published-results-title">
        <span class="panel-kicker">Published result</span>
        <h2 id="published-results-title">Latest Scored Test</h2>
        <p>
          Model portfolio returns are shown against the S&amp;P 500 benchmark on the same scale. Open weekly and monthly
          rounds stay out of this chart until ending prices are collected.
        </p>
      </section>

      <section
        class="published-score-panel"
        aria-label={`Latest scored ${latestPublishedResult.label.toLowerCase()} result`}
      >
        <ScoreReturnChart chart={latestScoreChart} label={`${latestPublishedResult.label} result`} />

        <div class="published-score-summary published-score-run-details">
          <div class="published-score-summary-head">
            <div class="published-result-head">
              <div>
                <span class="panel-kicker">Run details</span>
                <h3>{latestCompletedRound.round_id}</h3>
                <p>Round metadata and audit links.</p>
              </div>
            </div>

            <div class="track-card-actions">
              <a class="small-button" href={`/rounds/${latestCompletedRound.round_id}/`}>Full result</a>
              <a class="small-button" href={`/leaderboards/latest-${latestPublishedResult.key}`}>Leaderboard</a>
            </div>
          </div>

          <div class="published-score-context" aria-label="Scoring context">
            <span><strong>Window</strong>{dateOnly(latestCompletedRound.entry_date)} to {dateOnly(latestCompletedRound.exit_date)}</span>
            <span><strong>Models</strong>{latestPublishedResult.leaderboard.length}</span>
            <span><strong>Eligible assets</strong>{latestResultEligibleAssetCount}</span>
            <span><strong>Method</strong>{latestPublishedResult.label} close-to-close</span>
          </div>
        </div>
      </section>
    </>
  )}

  <section class="home-section-heading home-section-heading-with-action" id="active-exposure" aria-labelledby="active-exposure-title">
    <div>
      <span class="panel-kicker">Active exposure</span>
      <h2 id="active-exposure-title">Where Active Model Portfolios Are Invested</h2>
      <p>
        This counts only tests still waiting for final prices. Completed tests are excluded, so the view shows where open
        model capital is currently allocated.
      </p>
    </div>
    <a class="section-profile-link" href="/models">View model profiles</a>
  </section>

  <ActiveExposureMap client:visible rounds={activeExposureRounds} />

  {riskAppetiteProfiles.length > 0 && (
    <section class="risk-appetite-panel" aria-labelledby="risk-appetite-title">
      <div class="risk-appetite-head">
        <div>
          <span class="panel-kicker">Cumulative model style</span>
          <h3 id="risk-appetite-title">Risk Appetite By Model</h3>
          <p>
            Allocation-weighted from every official saved portfolio, including open and completed tests. It does not use
            future returns.
          </p>
        </div>
        <span class="risk-appetite-count">{riskPortfolioCount} saved portfolios</span>
      </div>

      <div class="risk-scale-stage" aria-label="Cumulative model risk appetite scale">
        <aside class="risk-focus-summary" aria-label="Risk appetite summary">
          <span class="panel-kicker">Current pattern</span>
          <strong>{riskClusterLabel}</strong>
          <p>
            Current model scores cluster near the high-risk end, so the main chart zooms into the active range instead
            of spending most of the canvas on unused defensive space.
          </p>
          <div class="risk-focus-summary-grid">
            <div>
              <span>Range</span>
              <b>{riskScoreShort(riskMinScore)}-{riskScoreShort(riskMaxScore)}</b>
            </div>
            <div>
              <span>Highest</span>
              <b>{highestRiskProfile?.label ?? "n/a"}</b>
            </div>
            <div>
              <span>Lowest</span>
              <b>{lowestRiskProfile?.label ?? "n/a"}</b>
            </div>
          </div>
        </aside>

        <div class="risk-focus-chart" aria-label="Focused cumulative model risk appetite comparison">
          <div class="risk-focus-chart-head">
            <span>Focused current range</span>
            <strong>{riskScoreShort(riskFocusMin)}-{riskScoreShort(riskFocusMax)}</strong>
          </div>
          <div class="risk-focus-list">
            {riskAppetiteProfiles.map((profile) => {
              const risk = profile.fingerprint.riskAppetite;
              return (
                <a
                  class={`risk-focus-row risk-axis-marker-${profile.provider}`}
                  href={modelFingerprintHref(profile.modelId)}
                  aria-label={`${profile.label}: ${riskScoreValue(risk.score)}, ${risk.label}`}
                  style={`--risk-focus-position: ${riskFocusWidth(risk.score)}; --risk-full-position: ${riskWidth(risk.percentile)};`}
                >
                  <span class="risk-focus-model">
                    <span class="risk-axis-logo">
                      {(profile.iconSrc ?? profile.logoSrc) && <img src={profile.iconSrc ?? profile.logoSrc} alt="" loading="lazy" />}
                    </span>
                    <span>
                      <strong>{profile.label}</strong>
                      <small>{profile.providerLabel}</small>
                    </span>
                  </span>
                  <span class="risk-focus-track" aria-hidden="true">
                    <span class="risk-focus-fill"></span>
                    <span class="risk-focus-dot"></span>
                  </span>
                  <span class="risk-focus-score">
                    <strong>{riskScoreShort(risk.score)}</strong>
                    <small>{risk.label}</small>
                  </span>
                </a>
              );
            })}
          </div>
          <div class="risk-focus-axis" aria-hidden="true">
            <span>{riskScoreShort(riskFocusMin)}</span>
            <span>zoomed comparison</span>
            <span>{riskScoreShort(riskFocusMax)}</span>
          </div>

          <div class="risk-full-context" aria-label="Full 1 to 5 risk appetite reference">
            <div class="risk-full-context-head">
              <span>Full scale reference</span>
              <strong>1-5</strong>
            </div>
            <div class="risk-full-rail" aria-hidden="true">
              {riskAppetiteProfiles.map((profile) => {
                const risk = profile.fingerprint.riskAppetite;
                return (
                  <span
                    class={`risk-full-dot risk-full-dot-${profile.provider}`}
                    style={`--risk-full-position: ${riskWidth(risk.percentile)};`}
                  ></span>
                );
              })}
            </div>
            <div class="risk-full-ticks" aria-hidden="true">
              <span>1 Defensive</span>
              <span>3 Balanced</span>
              <span>5 Aggressive</span>
            </div>
          </div>
        </div>
      </div>

      <div class="risk-mobile-scale" aria-label="Cumulative model risk appetite scale by model">
        <div class="risk-mobile-scale-axis" aria-hidden="true">
          <span>1 Defensive</span>
          <span>3 Balanced</span>
          <span>5 Aggressive</span>
        </div>
        <div class="risk-mobile-scale-list">
          {riskAppetiteProfiles.map((profile) => {
            const risk = profile.fingerprint.riskAppetite;
            return (
              <a
                class={`risk-mobile-scale-card risk-axis-marker-${profile.provider}`}
                href={modelFingerprintHref(profile.modelId)}
                aria-label={`${profile.label}: ${riskScoreValue(risk.score)}, ${risk.label}`}
                style={`--risk-position: ${riskWidth(risk.percentile)};`}
              >
                <span class="risk-axis-logo">
                  {(profile.iconSrc ?? profile.logoSrc) && <img src={profile.iconSrc ?? profile.logoSrc} alt="" loading="lazy" />}
                </span>
                <span class="risk-mobile-scale-copy">
                  <strong>{profile.label}</strong>
                  <small>{profile.providerLabel}</small>
                </span>
                <span class="risk-mobile-scale-score">
                  <strong>{riskScoreShort(risk.score)}</strong>
                  <small>{risk.label}</small>
                </span>
                <span class="risk-mobile-scale-meter" aria-hidden="true"></span>
              </a>
            );
          })}
        </div>
      </div>

      <div class="risk-scale-table" aria-label="Cumulative risk appetite detail by model">
        <div class="risk-scale-row risk-scale-row-head" aria-hidden="true">
          <span>Model</span>
          <span>Score</span>
          <span>High risk</span>
          <span>Tech</span>
          <span>Defensive</span>
        </div>
        {riskAppetiteProfiles.map((profile) => {
          const risk = profile.fingerprint.riskAppetite;
          return (
            <a class="risk-scale-row" href={modelFingerprintHref(profile.modelId)}>
              <span class="risk-scale-model">
                <span class="risk-axis-logo">
                  {(profile.iconSrc ?? profile.logoSrc) && <img src={profile.iconSrc ?? profile.logoSrc} alt="" loading="lazy" />}
                </span>
                <span>
                  <strong>{profile.label}</strong>
                  <small>{profile.providerLabel}</small>
                </span>
              </span>
              <span><strong>{riskScoreValue(risk.score)}</strong><small>{risk.label}</small></span>
              <span data-label="High risk">{pctValue(risk.highRiskPct)}</span>
              <span data-label="Tech">{pctValue(risk.techPct)}</span>
              <span data-label="Defensive">{pctValue(risk.defensivePct)}</span>
            </a>
          );
        })}
      </div>
    </section>
  )}

  <section class="home-section-heading" id="current-picks" aria-labelledby="latest-decisions-title">
    <span class="panel-kicker">Latest model portfolios</span>
    <h2 id="latest-decisions-title">What The Models Picked In The Latest Tests</h2>
    <p>
      These are the portfolios each model locked in for the most recent weekly and monthly tests only. Older tests remain
      available on the round pages.
    </p>
  </section>

  <section class="decision-track-grid" aria-label="Latest weekly and monthly model portfolios">
    {trackStates.map((track) => (
      <article class={`decision-track decision-track-${track.key}`}>
        <div class="decision-track-header">
          <div>
            <span class="panel-kicker">{track.label} picks</span>
            <h3>{track.round?.round_id ?? "Awaiting round"}</h3>
            <p>{track.round ? windowLabel(track.round) : "No picks are locked yet."}</p>
          </div>
          <span class={`status-badge ${statusClass(track.round)}`}>{statusLabel(track.round)}</span>
        </div>

        {track.submissions.length > 0 ? (
          <>
            <div class="decision-row-list">
              {track.submissions.map((submission) => {
                const allocations = decisionAllocations(submission);
                return (
                  <div class="decision-row">
                    <div class="decision-row-meta">
                      <span class={`provider-badge provider-${submission.provider}`}>{providerLabel(submission.provider)}</span>
                      <a class="decision-model-link" href={modelProfileHref(submission.model_id)}>
                        {modelLabel(submission.model_id)}
                      </a>
                      <p>{topHoldings(submission, track.optionsById)}</p>
                    </div>
                    <div class="allocation-stack mini" aria-hidden="true">
                      {allocations.map((allocation) => (
                        <span
                          class={allocationThemeClass(allocation.option_id)}
                          style={`width: ${Math.max(3, allocation.allocation_pct)}%`}
                          title={`${optionDisplayName(allocation.option_id, track.optionsById)} ${formatAllocationPct(allocation.allocation_pct)}`}
                        />
                      ))}
                    </div>
                  </div>
                );
              })}
            </div>

            <div class="track-exposure">
              <div>
                <span class="metric-label">Consensus allocation</span>
                <strong>{track.topExposure ? optionDisplayName(track.topExposure.optionId, track.optionsById) : "None"}</strong>
                <small>Average across {track.concentration.modelCount} model portfolios.</small>
              </div>
              <div>
                <div class="allocation-stack track-consensus-stack" aria-label={`${track.label} consensus allocation stack`}>
                  {track.concentration.assets.map((item) => (
                    <span
                      class={allocationThemeClass(item.optionId)}
                      style={`width: ${item.averagePct}%`}
                      title={`${optionDisplayName(item.optionId, track.optionsById)} ${formatAllocationPct(item.averagePct)}`}
                    />
                  ))}
                </div>
                <div class="track-consensus-stats" aria-label={`${track.label} concentration summary`}>
                  <span>Top 3 <strong>{formatAllocationPct(track.concentration.topThreeSharePct)}</strong></span>
                  <span>Spread <strong>{track.concentration.effectiveAssetCount.toFixed(1)} assets</strong></span>
                </div>
                <div class="exposure-bars compact">
                  {track.exposures.slice(0, 4).map((item) => (
                    <div class="exposure-bar-row">
                      <span>{optionDisplayName(item.optionId, track.optionsById)}</span>
                      <div class="exposure-bar-track" aria-hidden="true">
                        <span
                          class={allocationThemeClass(item.optionId)}
                          style={`width: ${track.topExposure ? Math.max(4, (item.averagePct / track.topExposure.averagePct) * 100) : 0}%`}
                        />
                      </div>
                      <strong>{formatAllocationPct(item.averagePct)}</strong>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </>
        ) : (
          <div class="pending-state compact">
            <strong>No model picks yet.</strong>
            <span>The latest {track.label.toLowerCase()} portfolios will appear after the test is locked.</span>
          </div>
        )}

        <div class="track-card-actions">
          <a class="small-button" href={track.latestHref}>
            {track.round?.status === "resolved" ? `Open ${track.label} Results` : `${track.label} Scoreboard`}
          </a>
          {track.roundHref && <a class="small-button" href={track.roundHref}>Proof files</a>}
        </div>
      </article>
    ))}
  </section>

  <section class="trust-strip" id="how-it-works" aria-label="How CapitalBench works">
    {howItWorks.map((item) => (
      <article>
        <span>{item.label}</span>
        <strong>{item.title}</strong>
        <p>{item.description}</p>
      </article>
    ))}
  </section>

  <section class="leaderboard-lanes" aria-labelledby="leaderboard-lanes-title">
    <div class="leaderboard-lanes-copy">
      <span class="panel-kicker">Results</span>
      <h2 id="leaderboard-lanes-title">Weekly And Monthly Are Separate</h2>
      <p>
        A one-week test and a one-month test are different contests. They get separate scoreboards and separate overall
        results.
      </p>
    </div>
    <div class="leaderboard-lane-links">
      <a href="/leaderboards/latest-weekly">
        <span>Weekly results</span>
        <strong>{latestResolvedWeeklyRound ? "Latest scored" : "Waiting for first score"}</strong>
      </a>
      <a href="/leaderboards/latest-monthly">
        <span>Monthly results</span>
        <strong>{latestResolvedMonthlyRound ? "Latest scored" : "Waiting for first score"}</strong>
      </a>
      <a href="/leaderboards/cumulative-weekly">
        <span>Overall weekly</span>
        <strong>Weekly only</strong>
      </a>
      <a href="/leaderboards/cumulative-monthly">
        <span>Overall monthly</span>
        <strong>Monthly only</strong>
      </a>
    </div>
  </section>

  <section class="home-section-heading track-summary-heading" aria-labelledby="current-tests-title">
    <span class="panel-kicker">Current test windows</span>
    <h2 id="current-tests-title">Latest Weekly And Monthly Tests</h2>
    <p>
      These cards summarize the newest open or recently scored tests for each track, with direct links to results and
      proof files.
    </p>
  </section>

  <section class="track-summary" aria-label="Latest weekly and monthly tests">
    {trackStates.map((track) => (
      <article class={`track-card track-card-${track.key}`}>
        <div class="track-card-head">
          <div>
            <span class="panel-kicker">{track.label} test</span>
            <h3>{track.round?.round_id ?? "No round yet"}</h3>
          </div>
          <span class={`status-badge ${statusClass(track.round)}`}>{statusLabel(track.round)}</span>
        </div>
        {track.round ? (
          <>
            <p>{track.horizonLabel}. {scoreLine(track.round)}</p>
            <div class="track-card-grid">
              <span>Dates <strong>{windowLabel(track.round)}</strong></span>
              <span>Portfolios <strong>{track.submissions.length}</strong></span>
              <span>Asset list <strong>{track.options.length} assets</strong></span>
              <span>Run id <strong>{track.round.official_run_id}</strong></span>
            </div>
          </>
        ) : (
          <p>No {track.label.toLowerCase()} test is published yet.</p>
        )}
        <div class="track-card-actions">
          <a class="small-button" href={track.latestHref}>Results</a>
          <a class="small-button" href={track.cumulativeHref}>Overall</a>
          {track.roundHref && <a class="small-button" href={track.roundHref}>Proof files</a>}
        </div>
      </article>
    ))}
  </section>

  <section class="timeline-lanes" aria-labelledby="track-timeline-title">
    <div class="home-section-heading">
      <span class="panel-kicker">{roundRows.length}-test record</span>
      <h2 id="track-timeline-title">When Each Test Gets Scored</h2>
      <p>
        Each test has three moments: picks are saved, the market period passes, and final scores publish after ending
        prices are available.
      </p>
    </div>
    <div class="timeline-lane-grid">
      {trackStates.map((track) => (
        <article class="timeline-lane">
          <div class="timeline-lane-head">
            <span class="panel-kicker">{track.label} timeline</span>
            <strong>{track.round?.round_id ?? "Awaiting round"}</strong>
          </div>
          <ol>
            <li class={track.round ? "phase-complete" : ""}>
              <span>1</span>
              <div>
                <strong>Picks saved</strong>
                <p>{track.round ? dateOnly(track.round.decision_deadline_utc) : "Pending"}</p>
              </div>
            </li>
            <li class={track.round ? "phase-current" : ""}>
              <span>2</span>
              <div>
                <strong>{track.horizonLabel}</strong>
                <p>{track.round ? windowLabel(track.round) : "No window declared"}</p>
              </div>
            </li>
            <li class={track.round?.status === "resolved" ? "phase-complete" : "phase-current"}>
              <span>3</span>
              <div>
                <strong>{track.round?.status === "resolved" ? "Scores published" : "Score after ending prices"}</strong>
                <p>{track.round ? scoreLine(track.round) : "Resolution pending."}</p>
              </div>
            </li>
          </ol>
        </article>
      ))}
    </div>
  </section>

  <nav class="view-switcher enhanced" aria-label="Explore CapitalBench">
    {exploreLinks.map((view) => {
      const Icon = view.icon;
      return (
        <a href={view.href}>
          <span class="view-icon" aria-hidden="true"><Icon size={18} /></span>
          <span class="view-copy">
            <strong>{view.label}</strong>
            <span>{view.description}</span>
          </span>
          <span class="view-state">{view.state}</span>
        </a>
      );
    })}
  </nav>

  <section class="audit-preview" id="proof-and-data" aria-labelledby="audit-preview-title">
    <div>
      <span class="panel-kicker">Proof and data</span>
      <h2 id="audit-preview-title">Check The Source Files</h2>
      <p>
        Test pages show the market brief, prompt, model portfolios, starting prices, source reports, hashes, and run
        status behind each public test.
      </p>
    </div>
    <div class="audit-preview-actions">
      {latestWeeklyRound && <a class="action-link action-primary" href={`/rounds/${latestWeeklyRound.round_id}/`}>Open weekly proof files</a>}
      {latestMonthlyRound && <a class="action-link" href={`/rounds/${latestMonthlyRound.round_id}/`}>Open monthly proof files</a>}
      <a class="action-link" href="/rounds">View all tests</a>
      <a class="action-link" href={siteConfig.githubUrl} target="_blank" rel="noreferrer">
        <GitHubLogo size={15} />
        Repository
      </a>
    </div>
  </section>

  <section class="home-section-heading" aria-labelledby="safeguards-title">
    <span class="panel-kicker">Why it is fair</span>
    <h2 id="safeguards-title">Simple Rules, Public Proof</h2>
    <p>
      CapitalBench keeps the comparison narrow: same information, same asset list, saved picks, and no final winner
      before the test ends.
    </p>
  </section>

  <section class="evidence-grid enhanced" aria-label="Benchmark safeguards">
    {safeguards.map((item) => {
      const Icon = item.icon;
      return (
        <article>
          <div class="evidence-icon" aria-hidden="true">
            <Icon size={19} />
          </div>
          <span class="metric-label">{item.label}</span>
          <h3>{item.title}</h3>
          <p>{item.description}</p>
        </article>
      );
    })}
  </section>
</BaseLayout>
